---
interface Props {
  ingredient: string;
  ingredientImg?: string;
  inputLabel?: string;
  inputImg?: string;
  result: string;
  resultImg?: string;
  resultColor?: string;
  hu?: string;
  en?: string;
  ru?: string;
}

const {
  ingredient, ingredientImg,
  inputLabel, inputImg,
  result, resultImg,
  resultColor = '#4ecca3',
  hu, en, ru,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="craft-section" style="margin:12px 0">
  <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">

    <!-- Brewing Stand body -->
    <div style="
      background:linear-gradient(160deg,#2a1e0e,#1e160a);
      border:2px solid #6b4a10;
      border-radius:8px;
      padding:12px 14px;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:4px;
      min-width:130px;
      box-shadow:inset 0 2px 8px rgba(0,0,0,.5);
    ">
      <!-- Ingredient slot (top) -->
      <div style="font-size:.6em;color:#aaa;letter-spacing:.06em;text-transform:uppercase;line-height:1;margin-bottom:2px">
        <span data-lang="hu">Alapanyag</span><span data-lang="en">Ingredient</span><span data-lang="ru">Ингредиент</span>
      </div>
      <div style="
        width:42px;height:42px;
        background:#8b8b8b;border:2px solid #555;border-radius:3px;
        display:flex;align-items:center;justify-content:center;
        box-shadow:inset 1px 1px 0 rgba(255,255,255,.08),inset -1px -1px 0 rgba(0,0,0,.25);
        position:relative;
      " title={ingredient}>
        {ingredientImg
          ? <img src={`${base}/${ingredientImg}`} alt={ingredient} width="30" height="30"
              style="image-rendering:pixelated;object-fit:contain"
              onerror="this.style.opacity=.25" />
          : <span style="font-size:.58em;color:#bbb;text-align:center;padding:2px;line-height:1.1">{ingredient}</span>
        }
      </div>

      <!-- Bubble pipe -->
      <div style="display:flex;flex-direction:column;align-items:center;gap:1px;margin:2px 0">
        <div style="width:3px;height:6px;background:#7ec8e3;border-radius:2px;opacity:.8"></div>
        <div style="width:5px;height:5px;background:#7ec8e3;border-radius:50%;opacity:.6"></div>
        <div style="width:3px;height:6px;background:#7ec8e3;border-radius:2px;opacity:.8"></div>
        <div style="width:5px;height:5px;background:#7ec8e3;border-radius:50%;opacity:.4"></div>
        <div style="width:3px;height:8px;background:#7ec8e3;border-radius:2px;opacity:.8"></div>
      </div>

      <!-- 3 bottle slots -->
      <div style="font-size:.6em;color:#aaa;letter-spacing:.06em;text-transform:uppercase;line-height:1;margin-bottom:2px">
        <span data-lang="hu">Palackok</span><span data-lang="en">Bottles</span><span data-lang="ru">Бутылки</span>
      </div>
      <div style="display:flex;gap:5px">
        {[0,1,2].map(() => (
          <div style="
            width:34px;height:42px;
            background:#5a5a8b;border:2px solid #4a4a7a;border-radius:3px 3px 5px 5px;
            display:flex;align-items:center;justify-content:center;
            box-shadow:inset 1px 1px 0 rgba(255,255,255,.1),inset -1px -1px 0 rgba(0,0,0,.3);
          " title={inputLabel ?? ''}>
            {inputImg
              ? <img src={`${base}/${inputImg}`} alt={inputLabel ?? ''} width="24" height="32"
                  style="image-rendering:pixelated;object-fit:contain"
                  onerror="this.style.opacity=.25" />
              : <span style="font-size:1.2em;opacity:.7">🧪</span>
            }
          </div>
        ))}
      </div>
      {inputLabel && (
        <div style="font-size:.62em;color:#aaa;text-align:center;margin-top:2px;max-width:110px;line-height:1.2">{inputLabel}</div>
      )}
    </div>

    <!-- Arrow -->
    <div style="font-size:1.6em;color:#f0c040;font-weight:700;flex-shrink:0">&#x27A4;</div>

    <!-- Result -->
    <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
      <div style="
        width:56px;height:56px;
        background:#3a3a6b;
        border:2px solid #7ec8e3;
        border-radius:4px;
        display:flex;align-items:center;justify-content:center;
        box-shadow:0 0 10px rgba(126,200,227,.25);
      " title={result}>
        {resultImg
          ? <img src={`${base}/${resultImg}`} alt={result} width="44" height="44"
              style="image-rendering:pixelated;object-fit:contain"
              onerror="this.style.opacity=.25" />
          : <span style="font-size:2em">🧪</span>
        }
      </div>
      <div style={`font-size:.82em;font-weight:600;color:${resultColor};text-align:center;max-width:100px;line-height:1.25`}>{result}</div>
    </div>

  </div>

  <!-- Labels -->
  {hu && <div class="craft-label" data-lang="hu">{hu}</div>}
  {en && <div class="craft-label" data-lang="en">{en}</div>}
  {ru && <div class="craft-label" data-lang="ru">{ru}</div>}
</div>
