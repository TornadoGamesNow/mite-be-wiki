---
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isDev = import.meta.env.DEV;

function isActive(ids: string[]): boolean {
  return ids.includes(currentPage);
}
---
<nav class="top-nav" data-dev={isDev ? 'true' : 'false'}>
  <button class="hamburger-btn" aria-label="Menu" aria-expanded="false">&#9776;</button>
  <div class="top-nav-links">

    <!-- Home -->
    <a href={`${base}/`} aria-current={currentPage === 'home' ? 'page' : undefined}>
      <span data-lang="hu">Kezdőlap</span>
      <span data-lang="en">Home</span>
      <span data-lang="ru">Главная</span>
    </a>

    <!-- Guide dropdown -->
    <div class="nav-dropdown">
      <button class="nav-dropdown-toggle" class:list={[{ active: isActive(['introduction','quick-start','game-modes','progression','systems']) }]}>
        <span data-lang="hu">Guide ▾</span>
        <span data-lang="en">Guide ▾</span>
        <span data-lang="ru">Гайд ▾</span>
      </button>
      <div class="nav-dropdown-menu">
        <a href={`${base}/introduction/`}>
          <span data-lang="hu">Bevezetés</span>
          <span data-lang="en">Introduction</span>
          <span data-lang="ru">Введение</span>
        </a>
        <a href={`${base}/quick-start/`}>
          <span data-lang="hu">Gyors kezdés</span>
          <span data-lang="en">Quick Start</span>
          <span data-lang="ru">Быстрый старт</span>
        </a>
        <a href={`${base}/progression/`}>
          <span data-lang="hu">Haladás</span>
          <span data-lang="en">Progression</span>
          <span data-lang="ru">Прогресс</span>
        </a>
        <a href={`${base}/systems/`}>
          <span data-lang="hu">Rendszerek</span>
          <span data-lang="en">Systems</span>
          <span data-lang="ru">Системы</span>
        </a>
      </div>
    </div>

    <!-- Reference dropdown -->
    <div class="nav-dropdown">
      <button class="nav-dropdown-toggle" class:list={[{ active: isActive(['recipes','items','mobs','biomes','brewing','reference']) }]}>
        <span data-lang="hu">Referencia ▾</span>
        <span data-lang="en">Reference ▾</span>
        <span data-lang="ru">Справочник ▾</span>
      </button>
      <div class="nav-dropdown-menu">
        <a href={`${base}/items/`}>
          <span data-lang="hu">Itemek</span>
          <span data-lang="en">Items</span>
          <span data-lang="ru">Предметы</span>
        </a>
        <a href={`${base}/recipes/`}>
          <span data-lang="hu">Receptek</span>
          <span data-lang="en">Recipes</span>
          <span data-lang="ru">Рецепты</span>
        </a>
        <a href={`${base}/mobs/`}>
          <span data-lang="hu">Bestiary</span>
          <span data-lang="en">Bestiary</span>
          <span data-lang="ru">Бестиарий</span>
        </a>
        <a href={`${base}/biomes/`}>
          <span data-lang="hu">Biome-ok</span>
          <span data-lang="en">Biomes</span>
          <span data-lang="ru">Биомы</span>
        </a>
        <a href={`${base}/brewing/`}>
          <span data-lang="hu">Brewing</span>
          <span data-lang="en">Brewing</span>
          <span data-lang="ru">Зельеварение</span>
        </a>
        <a href={`${base}/reference/`}>
          <span data-lang="hu">Referencia</span>
          <span data-lang="en">Reference</span>
          <span data-lang="ru">Справочник</span>
        </a>
      </div>
    </div>

    <!-- Standalone links -->
    <a href={`${base}/install/`} aria-current={currentPage === 'install' ? 'page' : undefined}>
      <span data-lang="hu">Telepítés</span>
      <span data-lang="en">Install</span>
      <span data-lang="ru">Установка</span>
    </a>
    <a href={`${base}/faq/`} aria-current={currentPage === 'faq' ? 'page' : undefined}>
      <span data-lang="hu">GYIK</span>
      <span data-lang="en">FAQ</span>
      <span data-lang="ru">FAQ</span>
    </a>
    <a href={`${base}/changelog/`} aria-current={currentPage === 'changelog' ? 'page' : undefined}>
      <span data-lang="hu">Changelog</span>
      <span data-lang="en">Changelog</span>
      <span data-lang="ru">Changelog</span>
    </a>

  </div>
  <div class="wiki-search" id="wiki-search">
    <input type="text" class="wiki-search-input" id="wiki-search-input" autocomplete="off" />
    <div class="wiki-search-results" id="wiki-search-results"></div>
  </div>
</nav>

<script>
  const btn = document.querySelector('.hamburger-btn');
  const links = document.querySelector('.top-nav-links');
  if (btn && links) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      links.classList.toggle('open');
    });
  }

  // Mobile: click toggle for dropdowns
  document.querySelectorAll('.nav-dropdown-toggle').forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      const dropdown = (toggle as HTMLElement).closest('.nav-dropdown');
      const menu = dropdown?.querySelector('.nav-dropdown-menu') as HTMLElement | null;
      if (!menu) return;
      const isOpen = menu.style.display === 'block';
      // Close all
      document.querySelectorAll('.nav-dropdown-menu').forEach((m: Element) => {
        (m as HTMLElement).style.display = '';
      });
      if (!isOpen) menu.style.display = 'block';
    });
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.nav-dropdown')) {
      document.querySelectorAll('.nav-dropdown-menu').forEach((m: Element) => {
        (m as HTMLElement).style.display = '';
      });
    }
  });
</script>

<script is:inline>
  (function() {
    var searchInput = document.getElementById('wiki-search-input');
    var searchResults = document.getElementById('wiki-search-results');
    if (!searchInput || !searchResults) return;

    var pagefind = null;
    var debounceTimer = null;

    var placeholders = { hu: 'Keresés...', en: 'Search...', ru: 'Поиск...' };

    function getLang() {
      return document.documentElement.getAttribute('data-lang-init') || 'hu';
    }

    function updatePlaceholder() {
      searchInput.placeholder = placeholders[getLang()] || placeholders.hu;
    }
    updatePlaceholder();
    window.addEventListener('mite-lang-change', function() { updatePlaceholder(); });

    function initPagefind() {
      if (pagefind) return Promise.resolve(pagefind);
      var prefix = '/mite-be-wiki';
      return import(prefix + '/pagefind/pagefind.js').then(function(pf) {
        pagefind = pf;
        return pf.init();
      }).then(function() { return pagefind; });
    }

    searchInput.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      var q = searchInput.value.trim();
      if (q.length < 2) {
        searchResults.innerHTML = '';
        searchResults.classList.remove('open');
        return;
      }
      debounceTimer = setTimeout(function() { doSearch(q); }, 150);
    });

    searchInput.addEventListener('keydown', function(e) {
      var items = searchResults.querySelectorAll('.ws-item');
      var active = searchResults.querySelector('.ws-item.active');
      var idx = -1;
      items.forEach(function(el, i) { if (el === active) idx = i; });

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        idx = Math.min(idx + 1, items.length - 1);
        items.forEach(function(el, i) { el.classList.toggle('active', i === idx); });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        idx = Math.max(idx - 1, 0);
        items.forEach(function(el, i) { el.classList.toggle('active', i === idx); });
      } else if (e.key === 'Enter' && active) {
        e.preventDefault();
        var href = active.getAttribute('data-href');
        if (href) window.location.href = href;
      } else if (e.key === 'Escape') {
        searchResults.innerHTML = '';
        searchResults.classList.remove('open');
        searchInput.blur();
      }
    });

    searchInput.addEventListener('blur', function() {
      setTimeout(function() { searchResults.classList.remove('open'); }, 200);
    });

    searchInput.addEventListener('focus', function() {
      if (searchResults.innerHTML) searchResults.classList.add('open');
    });

    function doSearch(query) {
      initPagefind().then(function(pf) {
        return pf.search(query);
      }).then(function(search) {
        return Promise.all(search.results.slice(0, 8).map(function(r) { return r.data(); }));
      }).then(function(results) {
        if (results.length === 0) {
          var lang = getLang();
          var noRes = lang === 'en' ? 'No results' : lang === 'ru' ? 'Нет результатов' : 'Nincs találat';
          searchResults.innerHTML = '<div class="ws-empty">' + noRes + '</div>';
          searchResults.classList.add('open');
          return;
        }

        searchResults.innerHTML = results.map(function(r) {
          var title = (r.meta && r.meta.title) || r.url;
          var excerpt = r.excerpt || '';
          return '<div class="ws-item" data-href="' + r.url + '">' +
            '<div class="ws-title">' + title + '</div>' +
            '<div class="ws-excerpt">' + excerpt + '</div>' +
            '</div>';
        }).join('');

        searchResults.querySelectorAll('.ws-item').forEach(function(el) {
          el.addEventListener('mousedown', function() {
            var href = el.getAttribute('data-href');
            if (href) window.location.href = href;
          });
        });

        searchResults.classList.add('open');
      }).catch(function(e) {
        var nav = document.querySelector('.top-nav');
        var devMode = nav && nav.getAttribute('data-dev') === 'true';
        if (devMode) {
          var lang = getLang();
          var msg = lang === 'en' ? 'Search only available after build'
                  : lang === 'ru' ? 'Поиск доступен только после сборки'
                  : 'Keresés csak build után érhető el';
          searchResults.innerHTML = '<div class="ws-empty ws-dev-notice">' + msg + '</div>';
          searchResults.classList.add('open');
        } else {
          console.error('Pagefind search error:', e);
        }
      });
    }
  })();
</script>
