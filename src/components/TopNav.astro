---
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pages = [
  { href: `${base}/`, id: 'home', hu: 'Kezdőlap', en: 'Home' },
  { href: `${base}/reference/`, id: 'reference', hu: 'Referencia', en: 'Reference' },
  { href: `${base}/install/`, id: 'install', hu: 'Telepítés', en: 'Install' },
  { href: `${base}/faq/`, id: 'faq', hu: 'GYIK', en: 'FAQ' },
  { href: `${base}/recipes/`, id: 'recipes', hu: 'Receptek', en: 'Recipes' },
  { href: `${base}/items/`, id: 'items', hu: 'Itemek', en: 'Items' },
  { href: `${base}/mobs/`, id: 'mobs', hu: 'Bestiary', en: 'Bestiary' },
  { href: `${base}/brewing/`, id: 'brewing', hu: '🧪 Brewing', en: '🧪 Brewing' },
  { href: `${base}/changelog/`, id: 'changelog', hu: 'Changelog', en: 'Changelog' },
];
---
<nav class="top-nav">
  {pages.map(p => (
    <a href={p.href} aria-current={p.id === currentPage ? 'page' : undefined}>
      <span data-lang="hu">{p.hu}</span>
      <span data-lang="en">{p.en}</span>
    </a>
  ))}
</nav>
