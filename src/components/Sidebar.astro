---
interface SidebarLink {
  href: string;
  label: string;
}

interface SidebarSection {
  title: string;
  links: SidebarLink[];
}

interface Props {
  groups: {
    hu: SidebarSection[];
    en: SidebarSection[];
    ru?: SidebarSection[];
  };
}

const { groups } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
function resolveHref(href: string): string {
  if (href.startsWith('#') || href.startsWith('http') || href.startsWith('/')) return href;
  if (href === '.' || href === './') return `${base}/`;
  // relative page link → prefix with base
  return `${base}/${href}`;
}
---
<!-- HU Sidebar -->
<div data-lang="hu">
  <nav class="sidebar">
    <div class="search-wrap">
      <button class="sidebar-toggle" aria-expanded="false" aria-label="Toggle sidebar">
        <span data-lang="hu">Navigáció</span>
        <span data-lang="en">Navigation</span>
        <span data-lang="ru">Навигация</span>
        <span class="sidebar-toggle-icon">&#9660;</span>
      </button>
    </div>
    <div class="sidebar-nav">
      {groups.hu.map(section => (
        <details class="sidebar-section" open>
          <summary class="sidebar-section-title">{section.title}</summary>
          <ul>
            {section.links.map(link => (
              <li><a href={resolveHref(link.href)}>{link.label}</a></li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </nav>
</div>

<!-- EN Sidebar -->
<div data-lang="en">
  <nav class="sidebar">
    <div class="search-wrap">
      <button class="sidebar-toggle" aria-expanded="false" aria-label="Toggle sidebar">
        <span data-lang="hu">Navigáció</span>
        <span data-lang="en">Navigation</span>
        <span data-lang="ru">Навигация</span>
        <span class="sidebar-toggle-icon">&#9660;</span>
      </button>
    </div>
    <div class="sidebar-nav">
      {groups.en.map(section => (
        <details class="sidebar-section" open>
          <summary class="sidebar-section-title">{section.title}</summary>
          <ul>
            {section.links.map(link => (
              <li><a href={resolveHref(link.href)}>{link.label}</a></li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </nav>
</div>

<!-- RU Sidebar -->
{groups.ru && (
<div data-lang="ru">
  <nav class="sidebar">
    <div class="search-wrap">
      <button class="sidebar-toggle" aria-expanded="false" aria-label="Toggle sidebar">
        <span data-lang="hu">Navigáció</span>
        <span data-lang="en">Navigation</span>
        <span data-lang="ru">Навигация</span>
        <span class="sidebar-toggle-icon">&#9660;</span>
      </button>
    </div>
    <div class="sidebar-nav">
      {groups.ru.map(section => (
        <details class="sidebar-section" open>
          <summary class="sidebar-section-title">{section.title}</summary>
          <ul>
            {section.links.map(link => (
              <li><a href={resolveHref(link.href)}>{link.label}</a></li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </nav>
</div>
)}

<script>
  document.querySelectorAll('.sidebar-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const nav = btn.closest('.sidebar')?.querySelector('.sidebar-nav');
      if (nav) nav.classList.toggle('sidebar-nav-open');
    });
  });
</script>
