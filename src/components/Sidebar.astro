---
interface SidebarLink {
  href: string;
  label: string;
}

interface SidebarSection {
  title: string;
  links: SidebarLink[];
}

interface Props {
  groups: {
    hu: SidebarSection[];
    en: SidebarSection[];
  };
}

const { groups } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
function resolveHref(href: string): string {
  if (href.startsWith('#') || href.startsWith('http') || href.startsWith('/')) return href;
  if (href === '.' || href === './') return `${base}/`;
  // relative page link → prefix with base
  return `${base}/${href}`;
}
---
<!-- HU Sidebar -->
<div data-lang="hu">
  <nav class="sidebar">
    <div class="search-wrap">
      <input type="text" class="search-input" id="search-input-hu" placeholder="Oldalak, tárgyak, receptek..." aria-label="Search" />
    </div>
    <div class="sidebar-nav">
      {groups.hu.map(section => (
        <>
          <h3>{section.title}</h3>
          <ul>
            {section.links.map(link => (
              <li><a href={resolveHref(link.href)}>{link.label}</a></li>
            ))}
          </ul>
        </>
      ))}
    </div>
  </nav>
</div>

<!-- EN Sidebar -->
<div data-lang="en">
  <nav class="sidebar">
    <div class="search-wrap">
      <input type="text" class="search-input" id="search-input-en" placeholder="Pages, items, recipes..." aria-label="Search" />
    </div>
    <div class="sidebar-nav">
      {groups.en.map(section => (
        <>
          <h3>{section.title}</h3>
          <ul>
            {section.links.map(link => (
              <li><a href={resolveHref(link.href)}>{link.label}</a></li>
            ))}
          </ul>
        </>
      ))}
    </div>
  </nav>
</div>

