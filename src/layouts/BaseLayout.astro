---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'MITE: Break Everything Wiki', description = 'The first public trilingual wiki for MITE: Break Everything — a hardcore total-conversion Minecraft mod.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ogImageURL = new URL(`${base}/img/og-banner.png`, Astro.site).href;
---
<!DOCTYPE html>
<html lang="hu" data-lang-init="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1024" />
  <meta property="og:image:height" content="1024" />
  <meta name="keywords" content="MITE, MiTE, Minecraft Is Too Easy, Break Everything, wiki, guide, progression, hardcore minecraft mod" />
  <link rel="canonical" href={canonicalURL.href} />
  <link rel="icon" href={`${base}/img/items/adamantium_pickaxe.png`} type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- GoatCounter analytics (no cookies, no GDPR banner required) -->
  <script data-goatcounter="https://mite-be-wiki.goatcounter.com/count"
          async src="//gc.zgo.at/count.js" is:inline></script>
  <!-- FOUC prevention: apply saved language before first paint -->
  <script is:inline>
    (function(){
      var l = localStorage.getItem('mite-wiki-lang');
      if (l === 'hu' || l === 'en' || l === 'ru') document.documentElement.setAttribute('data-lang-init', l);
    })();
  </script>
</head>
<body data-pagefind-meta={`title:${title}`} data-base={import.meta.env.BASE_URL.replace(/\/$/, '')}>
  <div class="progress-bar" id="progress-bar"></div>
  <slot />
  <footer class="site-footer" data-pagefind-ignore>
    <div data-lang="hu">
      <p class="site-footer-title">⚔️ MITE:BE v0.9.0 — Teljes Magyar Wiki ⚔️</p>
      <p>Az információk forrása: mod fájlok, az eredeti kínai wiki (<a href="https://www.mcmod.cn/class/596.html" target="_blank" rel="noopener">mcmod.cn</a>) és a közösség tapasztalatai.</p>
      <p class="site-footer-legal">Ez egy nem hivatalos, közösségi wiki. A MITE:BE és minden kapcsolódó játékeszköz, textúra és védjegy az eredeti alkotóik tulajdona.</p>
    </div>
    <div data-lang="en">
      <p class="site-footer-title">⚔️ MITE:BE v0.9.0 — Complete Wiki ⚔️</p>
      <p>Information sourced from mod files, the original Chinese wiki (<a href="https://www.mcmod.cn/class/596.html" target="_blank" rel="noopener">mcmod.cn</a>), and community knowledge.</p>
      <p class="site-footer-legal">This is an unofficial, community-driven wiki. MITE:BE and all related game assets, textures, and trademarks belong to their respective original creators.</p>
    </div>
    <div data-lang="ru">
      <p class="site-footer-title">⚔️ MITE:BE v0.9.0 — Полное руководство ⚔️</p>
      <p>Информация собрана из файлов мода, оригинальной китайской вики (<a href="https://www.mcmod.cn/class/596.html" target="_blank" rel="noopener">mcmod.cn</a>) и опыта сообщества.</p>
      <p class="site-footer-legal">Это неофициальная вики, созданная сообществом. MITE:BE и все связанные игровые ресурсы, текстуры и торговые марки принадлежат их соответствующим авторам.</p>
    </div>
  </footer>
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">&uarr;</button>
  <script is:inline src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/data/items_slim.js`}></script>
  <script is:inline>
    // Collapsible sections
    document.querySelectorAll('.collapsible-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        var body = btn.nextElementSibling;
        if (body) body.classList.toggle('open', !expanded);
      });
      btn.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); btn.click(); }
      });
    });
    // Progress bar
    window.addEventListener('scroll', function() {
      var h = document.documentElement.scrollHeight - window.innerHeight;
      var p = h > 0 ? (window.scrollY / h) * 100 : 0;
      document.getElementById('progress-bar').style.width = p + '%';
      var btn = document.getElementById('back-to-top');
      if (window.scrollY > 400) btn.classList.add('visible');
      else btn.classList.remove('visible');
    });
    document.getElementById('back-to-top').addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
</body>
</html>
