---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import ItemExplorer from '../islands/ItemExplorer.tsx';
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Items — MITE:BE Wiki" description="MITE:BE item katalógus: 1100+ tárgy kategória és tier szerint szűrve — fegyverek, páncélok, blokkok, ételek, anyagok.">
  <Header />
  <TopNav currentPage="items" />
  <main style="max-width:1440px; margin:0 auto; padding:24px 32px;">
    <div data-lang="hu">
      <h2>Item Böngésző</h2>
      <p style="color:var(--text2)">1126 item · szűrés kategória és tier szerint · leírás keresés · recept jelző</p>
    </div>
    <div data-lang="en">
      <h2>Item Browser</h2>
      <p style="color:var(--text2)">1126 items · filter by category and tier · description search · recipe indicator</p>
    </div>
    <div data-lang="ru">
      <h2>Браузер предметов</h2>
      <p style="color:var(--text2)">1126 предметов · фильтр по категории и тиру · поиск по описанию · индикатор рецепта</p>
    </div>
    <ItemExplorer client:load />
  </main>
</BaseLayout>
<script is:inline src={`${base}/js/app.js`}></script>
