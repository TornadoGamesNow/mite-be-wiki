---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import ItemExplorer from '../islands/ItemExplorer.tsx';
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Items — MITE:BE Wiki" description="MITE:BE item katalógus: 1127 tárgy kategória és tier szerint szűrve — fegyverek, páncélok, blokkok, ételek, anyagok.">
  <Header />
  <TopNav currentPage="items" />
  <main id="items-page" style="max-width:1800px; margin:0 auto; padding:8px 32px 24px;">
    <div data-lang="hu"><h2 style="padding-top:8px; margin-bottom:6px">Item Böngésző</h2></div>
    <div data-lang="en"><h2 style="padding-top:8px; margin-bottom:6px">Item Browser</h2></div>
    <div data-lang="ru"><h2 style="padding-top:8px; margin-bottom:6px">Браузер предметов</h2></div>
    <ItemExplorer client:load />
  </main>
</BaseLayout>
<style is:global>
  @media (min-width: 640px) {
    body:has(#items-page) .wiki-search { display: none; }
  }
</style>
<script is:inline src={`${base}/js/app.js`}></script>
