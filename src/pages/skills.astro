---
// Legacy redirect: /skills/ → /systems/skills/
const target = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/systems/skills/`;
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Képességek — átirányítás / Redirecting...</title>
  </head>
  <body>
    <p>Átirányítás... / Redirecting to <a href={target}>{target}</a></p>
  </body>
</html>
