---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

import { getSidebarGroups } from '../data/sidebar-config.ts';
const sidebarGroups = getSidebarGroups('changelog');
---
<BaseLayout title="Changelog — MITE: Break Everything Wiki" description="MITE:BE changelog: verzióhistória, új funkciók, hibajavítások és változtatások összefoglalója.">
  <Header />
  <TopNav currentPage="changelog" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<style>
/* ── Version blocks ── */
.ver-block {
  margin: 0 0 28px 0;
  border-radius: var(--radius);
  border: 1px solid var(--surface2);
  overflow: hidden;
  background: var(--surface);
}
.ver-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  background: var(--surface2);
  border-bottom: 1px solid var(--surface2);
  flex-wrap: wrap;
}
.ver-badge {
  display: inline-block;
  padding: 3px 12px;
  border-radius: 20px;
  font-weight: 700;
  font-size: .85em;
  letter-spacing: .5px;
  background: var(--surface2);
  color: var(--text2);
  border: 1px solid #444;
}
.ver-badge.current {
  background: linear-gradient(135deg, #1a6b3c, #2a9d5c);
  color: #fff;
  border-color: #2a9d5c;
}
.ver-badge.hotfix {
  background: linear-gradient(135deg, #1a4a6b, #2a7dc5);
  color: #fff;
  border-color: #2a7dc5;
}
.ver-badge.major {
  background: linear-gradient(135deg, #5b2a8a, #8a2be2);
  color: #fff;
  border-color: #8a2be2;
}
.ver-date {
  font-size: .82em;
  color: var(--text2);
  margin-left: auto;
}
.ver-body {
  padding: 14px 18px 6px;
}
/* ── Change type labels ── */
.ct {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: .72em;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  margin-right: 6px;
  vertical-align: middle;
}
.ct-new  { background: rgba(78,204,163,.20); color: #4ecca3; }
.ct-fix  { background: rgba(255,120,80,.18); color: #ff9070; }
.ct-chg  { background: rgba(255,200,50,.15); color: #ffd050; }
/* ── Changelog list ── */
.cl-section {
  margin: 10px 0 14px;
}
.cl-section h4 {
  margin: 0 0 6px;
  font-size: .88em;
  color: var(--text2);
  text-transform: uppercase;
  letter-spacing: .8px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.cl-section ul {
  margin: 0;
  padding: 0 0 0 18px;
  list-style: disc;
}
.cl-section li {
  font-size: .9em;
  color: var(--text);
  margin: 4px 0;
  line-height: 1.5;
}
/* ── Old versions collapsible ── */
details.old-ver {
  margin-bottom: 10px;
  background: var(--surface);
  border: 1px solid var(--surface2);
  border-radius: var(--radius);
}
details.old-ver summary {
  padding: 10px 16px;
  cursor: pointer;
  font-weight: 600;
  color: var(--text2);
  list-style: none;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: color .2s;
}
details.old-ver summary:hover { color: var(--text); }
details.old-ver summary::after { content: " ▶"; font-size: .75em; margin-left: auto; opacity: .5; }
details.old-ver[open] summary::after { content: " ▼"; }
details.old-ver .old-body { padding: 4px 16px 14px; }
/* ── Src link ── */
.src-link { font-size: .78em; color: var(--text2); margin-top: 4px; }
.src-link a { color: var(--accent); }
</style>

<div data-lang="hu">
