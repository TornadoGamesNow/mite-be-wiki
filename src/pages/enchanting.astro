  <tr><th>Bűvölés</th><th>EN neve</th><th>Tárgy</th><th>Hatás (szintenként)</th><th>Max</th></tr>
  <tr><td><strong>Lefegyverzés</strong></td><td>Disarming</td><td>Kard</td><td>20% esély, hogy az ellenfél elejtse a tartott tárgyát</td><td>V</td></tr>
  <tr><td><strong>Vérszívás</strong></td><td>Vampiric</td><td>Fém kard / rövid kard / kasza</td><td>10% esély életerő-szívásra támadáskor</td><td>V</td></tr>
  <tr><td><strong>Elkábítás</strong></td><td>Stun</td><td>Bot / rövid bot / háborús kalapács</td><td>10% esély az ellenfél elkábítására (hatás részecskék nélkül)</td><td>V</td></tr>
  <tr><td><strong>Húsvágás</strong></td><td>Butchering</td><td>Rövid kard</td><td>Megölt állatokból több hús esik ki</td><td>III</td></tr>
</table>

