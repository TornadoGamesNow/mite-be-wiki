<script is:inline>
(function () {
  function init() {
    document.querySelectorAll('.enchant-search').forEach(function (inp) {
      inp.addEventListener('input', function () {
        var q = this.value.trim().toLowerCase();
        // Sync value to all other language search boxes
        document.querySelectorAll('.enchant-search').forEach(function (o) {
          if (o !== inp) o.value = inp.value;
        });
        filterAll(q);
      });
    });
  }

  function getSiblings(from, until) {
    var els = [];
    var el = from ? from.nextElementSibling : null;
    while (el && el !== until) { els.push(el); el = el.nextElementSibling; }
    return els;
  }

  function filterAll(q) {
    document.querySelectorAll('[data-lang]').forEach(function (div) {
      var miteH2 = div.querySelector('#mite-enchants');
      var xpH2   = div.querySelector('#xp-table');
      var enchH2 = div.querySelector('#enchantability');
      if (!miteH2 || !xpH2 || !enchH2) return;

      // ── MITE enchants section: h4 + individual tables ──
      var currentH4 = null;
      getSiblings(miteH2, xpH2).forEach(function (el) {
        if (el.tagName === 'H4') {
          currentH4 = el;
          el.style.display = '';
        } else if (el.tagName === 'TABLE') {
          var anyVisible = false;
          el.querySelectorAll('tr').forEach(function (row) {
            if (row.querySelector('th')) { row.style.display = ''; return; }
            if (!q) { row.style.display = ''; anyVisible = true; return; }
            var match = row.textContent.toLowerCase().includes(q);
            row.style.display = match ? '' : 'none';
            if (match) anyVisible = true;
          });
          var show = !q || anyVisible;
          el.style.display = show ? '' : 'none';
          if (currentH4) currentH4.style.display = show ? '' : 'none';
        }
      });

      // ── XP table: category header rows (td[colspan]) ──
      getSiblings(xpH2, enchH2).forEach(function (el) {
        if (el.tagName !== 'TABLE') return;
        var rows = Array.from(el.querySelectorAll('tr'));
        var groups = [];
        var group = null;
        rows.forEach(function (row) {
          if (row.querySelector('th')) { row.style.display = ''; return; }
          if (row.querySelector('td[colspan]')) {
            group = { header: row, rows: [] };
            groups.push(group);
          } else if (group) {
            group.rows.push(row);
          }
        });
        groups.forEach(function (g) {
          if (!q) {
            g.header.style.display = '';
            g.rows.forEach(function (r) { r.style.display = ''; });
            return;
          }
          var matched = 0;
          g.rows.forEach(function (r) {
            var m = r.textContent.toLowerCase().includes(q);
            r.style.display = m ? '' : 'none';
            if (m) matched++;
          });
          g.header.style.display = matched ? '' : 'none';
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
