    <td><img src={`${base}/img/items/enchantment_table.png`} alt="" style="width:20px;vertical-align:middle;image-rendering:pixelated"> <strong>Diamond Enchantment Table</strong></td>
    <td>Yes (max 15)</td><td>Random (3 options)</td><td>Iron Workbench</td>
  </tr>
  <tr>
    <td><img src={`${base}/img/items/enchantment_table_emerald.png`} alt="" style="width:20px;vertical-align:middle;image-rendering:pixelated"> <strong>Emerald Enchantment Table</strong></td>
    <td>Yes (max 15)</td><td>Random (stronger)</td><td>—</td>
  </tr>
