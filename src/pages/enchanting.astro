---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import CraftingGrid from '../components/CraftingGrid.astro';
import PageSummary from '../components/PageSummary.astro';
import '../styles/global.css';

import { getSidebarGroups } from '../data/sidebar-config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = getSidebarGroups('enchanting');
---
<BaseLayout title="Enchanting — MITE: Break Everything Wiki" description="MITE:BE enchanting: enchanting tables, MITE-specific enchantments with descriptions, XP table, disenchanting bottle.">
  <Header />
  <TopNav currentPage="enchanting" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">
<PageSummary keyPoints={{
  hu: [
    '3 bűvölőasztal-szint: Gyémánt → Smaragd → Egyéni (Haladó)',
    'Az Egyéni asztal: nincs könyvespolc szükséges, meghatározott bűvölések XP-ért',
    '20 MITE-specifikus bűvölés — leírásokkal és XP-táblázattal',
  ],
  en: [
    '3 enchanting table tiers: Diamond → Emerald → Custom (Advanced)',
    'Custom table: no bookshelves needed, choose specific enchantments for XP',
    '20 MITE-specific enchantments — with descriptions and XP table',
  ],
  ru: [
    '3 уровня столов зачарования: Алмаз → Изумруд → Особый',
    'Особый стол: не нужны полки, выбирай конкретные чары за опыт',
    '20 MITE-специфичных чар — с описаниями и таблицей опыта',
  ],
}} />

<!-- ═══════════════════════════════════════════════ HUNGARIAN ═══ -->
<div data-lang="hu">
<h2 id="enchanting-overview">✨ Bűvölés (Enchanting)</h2>
<p>A MITE: Break Everything három bűvölőasztalt tartalmaz. Az alap véletlenszerű bűvöléseket ad, a legfejlettebb (Egyéni) lehetővé teszi a <strong>meghatározott bűvölések</strong> kiválasztását XP-ért — könyvespolcok nélkül.</p>

<h2 id="enchanting-tables">Bűvölőasztalok összehasonlítása</h2>
<table class="compare-table">
  <tr><th>Asztal</th><th>Könyvespolc?</th><th>Bűvölés módja</th><th>Munkaasztal</th></tr>
  <tr>
    <td><img src={`${base}/img/items/enchantment_table.png`} alt="" style="width:20px;vertical-align:middle;image-rendering:pixelated"> <strong>Gyémánt Bűvölőasztal</strong></td>
    <td>Igen (max 15)</td><td>Véletlenszerű (3 opció)</td><td>Vas Munkaasztal</td>
  </tr>
  <tr>
    <td><img src={`${base}/img/items/enchantment_table_emerald.png`} alt="" style="width:20px;vertical-align:middle;image-rendering:pixelated"> <strong>Smaragd Bűvölőasztal</strong></td>
    <td>Igen (max 15)</td><td>Véletlenszerű (erősebb)</td><td>—</td>
  </tr>
  <tr style="background:rgba(200,150,255,0.08)">
    <td><img src={`${base}/img/items/enchantment_table_custom.png`} alt="" style="width:20px;vertical-align:middle;image-rendering:pixelated"> <strong>Egyéni Bűvölőasztal</strong></td>
    <td><strong>Nem!</strong></td><td>Meghatározott bűvölés XP-ért</td><td>Mithril / Adamantium</td>
  </tr>
</table>

<h3 id="base-table">Gyémánt Bűvölőasztal</h3>
<p>Az alap gyémánt bűvölőasztal. Minden bűvöléshez <strong>3 Lapis Lazuli</strong> szükséges, és a lapis megmarad az asztalban bezárás után is.</p>
<div class="craft-section">
  <CraftingGrid recipeFullId="enchantment_table_841396" label={{ hu: "Gyémánt Bűvölőasztal", en: "Diamond Enchantment Table" }} />
</div>

<h3 id="emerald-table">Smaragd Bűvölőasztal</h3>
<p>Az alap asztal fejlettebb változata — erősebb bűvölési opciókat kínál ugyanolyan mechanikaval. A lapis itt is megmarad az asztalban.</p>
<div class="craft-section">
  <CraftingGrid recipe={{ gridSize: '3x3', pattern: [['_','book','_'],['emerald','obsidian','emerald'],['obsidian','obsidian','obsidian']], output: 'enchantment_table_emerald', label: { hu: 'Smaragd Bűvölőasztal', en: 'Emerald Enchantment Table' } }} />
</div>

<h3 id="custom-table">Egyéni Bűvölőasztal</h3>
<p>A legfejlettebb bűvölőasztal (v0.6.0+). <strong>Nem kell könyvespolc</strong> — te választod ki pontosan melyik bűvölést akarod, és fizetsz érte XP-ben + <strong>3 Lapis Lazuli + 1 Könyv</strong>.</p>
<div class="warning-box">⚠️ <strong>v0.9.0:</strong> Az elkészítéséhez az <strong>Egyéni Bűvölőasztal Tudáskönyve</strong> szükséges. Csak <strong>Mithril vagy Adamantium Munkaasztalon</strong> készíthető, és csak Mithril/Adamantium csákány vagy háborús kalapács töri szét.</div>
<div class="craft-section">
  <CraftingGrid recipeFullId="enchantment_table_custom_32141" label={{ hu: "Egyéni Bűvölőasztal", en: "Custom Enchantment Table" }} />
</div>
<div class="tip">Arany almát az Egyéni Asztalnál bűvölni <strong>csak 100 XP-be kerül</strong>, extra anyag nem szükséges. Bűvölések csak erősebbé tehetők — eltávolítani vagy gyengíteni NEM lehet.</div>

<!-- ─── MITE-specifikus bűvölések ─── -->
<div class="enchant-search-bar" style="margin:1.5rem 0 0.5rem">
  <input class="enchant-search" type="search" autocomplete="off" placeholder="🔍 Bűvölés keresése..."
    style="width:100%;padding:8px 14px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.07);color:inherit;font-size:0.9em;box-sizing:border-box">
</div>
<h2 id="mite-enchants">MITE-specifikus bűvölések</h2>
<p>Az alábbi 20 bűvölés a MITE:BE mod saját bűvölése — ezek a vanilla Minecraftban nem léteznek.</p>

<h4>⚔ Fegyver</h4>
