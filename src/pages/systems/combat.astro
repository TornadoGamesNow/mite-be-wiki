---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TopNav from '../../components/TopNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import CraftingGrid from '../../components/CraftingGrid.astro';
import PageSummary from '../../components/PageSummary.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ProgressComplete from '../../components/ProgressComplete.astro';
import { getSidebarGroups } from '../../data/sidebar-config.ts';
import '../../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups('systems/combat');
---
<BaseLayout title="Combat — MITE:BE Wiki" description="MITE:BE combat: armor types and set bonuses, weapons, enchantments, bow and arrows, combat strategies.">
  <Header />
  <TopNav currentPage="systems" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<PageSummary keyPoints={{
  hu: [
    'Páncél 50% alatt elveszíti a védelmet — tartsd karban!',
    'Kasza: leghosszabb hatótáv, de harcban 4× gyorsabban kopik',
    'Adamantium nyíl az egyetlen, ami az End Kristályokat elpusztítja',
  ],
  en: [
    'Armor loses protection below 50% durability — keep it maintained!',
    'Scythe: longest reach, but wears 4x faster in combat',
    'Adamantium arrows are the only ones that destroy End Crystals',
  ],
  ru: [
    'Броня теряет защиту ниже 50% прочности — следи за состоянием!',
    'Коса: самый длинный радиус, но в 4× быстрее изнашивается в бою',
    'Стрелы из адаманта — единственные, уничтожающие Кристаллы Края',
  ],
}} />

<div data-lang="hu">
<h2 id="armor-weapons">Páncél &amp; Fegyverek</h2>

<h3>Páncél típusok</h3>
<p>Minden fémszintnek van teljes páncélkészlete (sisak, mellvért, Nadrág, csizmák) <strong>lemez</strong> és <strong>lánc</strong> változatban.</p>

<h3>Szett hatások</h3>
<table>
  <tr><th>Szett</th><th>Hatás</th></tr>
  <tr><td><span class="tier t-copper">Bronz</span></td><td>+20% Futás Sebesség</td></tr>
  <tr><td><span class="tier t-silver">Ezüst-Réz</span></td><td>-10% Elszenvedett Sérülés</td></tr>
  <tr><td><span class="tier t-iron">Szénacél</span></td><td>5% Sérülés Csökkentés darabonként</td></tr>
  <tr><td><span class="tier t-mithril">Mithril (4/4)</span></td><td>+40% Futás Sebesség, -30% Sérülés Csökkentés</td></tr>
  <tr><td><span class="tier t-ancient">Ősi Fém (4/4)</span></td><td>-30% Sérülés az Alvilágból, Alvilágbeli Denevérek nem támadnak, Korróziógátló</td></tr>
  <tr><td><span class="tier t-adamantium">Adamantium (4/4)</span></td><td>Szürke/fekete nyálkák korróziója nem hat rá; tűzkár nem csökkenti a tartósságot</td></tr>
  <tr><td>Higany Elem (4/4)</td><td>Testhőmérséklet marad 36,5°C örökké</td></tr>
</table>

<h3>Páncél Védelmi Értékek</h3>
<p>A teljes védelemhez 20 pont kell. A páncél 50% tartósság alatt elveszíti védelmi értékét! <em>(Lemezpáncél adatok)</em></p>
<table class="compare-table">
  <tr><th>Anyag</th><th>Sisak</th><th>Mellvért</th><th>Nadrág</th><th>Csizmák</th><th>Összesen</th></tr>
  <tr><td><span class="tier t-flint">Bőr</span></td><td>0.42</td><td>0.67</td><td>0.58</td><td>0.33</td><td>2.00</td></tr>
  <tr><td><span style="color:#f0c040">Arany</span></td><td>1.25</td><td>2.00</td><td>1.75</td><td>1.00</td><td>6.00</td></tr>
  <tr><td><span class="tier t-copper">Réz / Ezüst</span></td><td>1.46</td><td>2.33</td><td>2.04</td><td>1.17</td><td>7.00</td></tr>
  <tr><td><span class="tier t-copper">Bronz</span></td><td>1.60</td><td>2.40</td><td>2.10</td><td>1.30</td><td>7.40</td></tr>
  <tr><td><span class="tier t-silver">Ezüst-Réz ötvözet</span></td><td>1.70</td><td>2.50</td><td>2.20</td><td>1.30</td><td>7.70</td></tr>
  <tr><td><span class="tier t-iron">Vas (Vasalt)</span></td><td>1.67</td><td>2.67</td><td>2.33</td><td>1.33</td><td>8.00</td></tr>
  <tr><td><span class="tier t-iron">Szénacél</span></td><td>1.70</td><td>2.70</td><td>2.30</td><td>1.30</td><td>8.00</td></tr>
  <tr><td><span class="tier t-hard">Keménykő</span></td><td>1.80</td><td>2.80</td><td>2.40</td><td>1.40</td><td>8.40</td></tr>
  <tr><td><span class="tier t-ancient">Ősi Fém</span></td><td>1.90</td><td>2.90</td><td>2.50</td><td>1.50</td><td>8.80</td></tr>
  <tr><td><span class="tier t-mithril">Mithril</span></td><td>2.00</td><td>3.00</td><td>2.70</td><td>1.60</td><td>9.30</td></tr>
  <tr><td><span class="tier t-adamantium">Adamantium</span></td><td>2.08</td><td>3.33</td><td>2.92</td><td>1.67</td><td>10.00</td></tr>
</table>
<div class="info-box">A maximális 20 pont eléréséhez 2× Adamantium szett kellene — ez a játékban elérhetetlen. A cél a minél magasabb védelmi szint elérése bűvölésekkel kiegészítve!</div>

<div class="craft-section">
  <CraftingGrid recipeOutput="copper_helmet" label={{hu: "Sisak", en: "Helmet"}}/>
  <CraftingGrid recipeOutput="copper_chestplate" label={{hu: "Mellvért", en: "Chestplate"}}/>
  <CraftingGrid recipeOutput="copper_leggings" label={{hu: "Nadrág", en: "Leggings"}}/>
  <CraftingGrid recipeOutput="copper_boots" label={{hu: "Csizma", en: "Boots"}}/>
</div>

<h3>Fegyver típusok</h3>
<table>
  <tr><th>Fegyver</th><th>Jellemző</th></tr>
  <tr><td>Kard</td><td>Magas sebzés, blokkolás</td></tr>
  <tr><td>Tőr</td><td>Nem blokkolhat, de Henteskedés bűvöléssel több hús az állatokból</td></tr>
  <tr><td>Háborús kalapács</td><td>33% tartósság-csökkentés, extra sebzés csontvázak ellen — érc zúzásra is használható!</td></tr>
  <tr><td>Csatafejsze</td><td>Erős, lassú</td></tr>
  <tr><td>Lándzsa</td><td>Hatótáv, korai fegyver</td></tr>
  <tr><td>Kasza</td><td>Mezőgazdasági + harci hibrid — Betakarítás és Vámpír bűvölés, de 4× kopás combat közben!</td></tr>
  <tr><td>Íj / Számszeríj</td><td>Távharc</td></tr>
  <tr><td>Pajzs</td><td>Fém pajzsok (réz → adamantium) — blokkolás jobb klikkel</td></tr>
</table>

<h3>Kard Sebzés Összehasonlítás</h3>
<table class="compare-table">
  <tr><th>Anyag</th><th>Kard Sebzés</th><th>Csatafejsze</th><th>Háb. Kalapács</th></tr>
  <tr><td><span class="tier t-copper">Réz</span></td><td>+7</td><td>+7</td><td>+5</td></tr>
  <tr><td><span class="tier t-silver">Ezüst</span></td><td>+7</td><td>+7</td><td>+5</td></tr>
  <tr><td><span class="tier t-iron">Vas (Vasalt)</span></td><td>+8</td><td>+8</td><td>+6</td></tr>
  <tr><td><span class="tier t-hard">Keménykő</span></td><td>+8</td><td>+8</td><td>+6</td></tr>
  <tr><td><span class="tier t-ancient">Ősi Fém</span></td><td>+9</td><td>+9</td><td>+7</td></tr>
  <tr><td><span class="tier t-mithril">Mithril</span></td><td>+11</td><td>+11</td><td>+9</td></tr>
  <tr><td><span class="tier t-adamantium">Adamantium</span></td><td>+10</td><td>+10</td><td>+8</td></tr>
</table>
<div class="info-box">⚔️ <strong>Különleges kard bónuszok:</strong>
<ul style="margin:4px 0 0 0">
  <li><strong>Ezüstkard:</strong> Élőholtak meggyullasztása — 100 tickig ég (5 másodperc)</li>
  <li><strong>Szénacél Kard:</strong> AoE hatás — az 5 blokkon belüli mobokra +4 sebzés ütésenként</li>
  <li><strong>Ősi Fém Kard:</strong> Átfázik a Fázis Pókokra; korróziótól védett</li>
</ul></div>

<h3>Fegyver Kopási Sebesség (Decay Rate)</h3>
<table class="compare-table">
  <tr><th>Fegyver</th><th>Kopás vs. Ellenség</th><th>Kopás vs. Blokk</th><th>Megjegyzés</th></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td><strong>Kard</strong></td><td><strong>0.5× ✅</strong></td><td>2× ❌</td><td>Harcban sokáig bírja, de NE bányássz vele!</td></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td><strong>Tőr</strong></td><td><strong>0.5× ✅</strong></td><td>2× ❌</td><td>Ugyanolyan mint a kard vs. entitások</td></tr>
  <tr><td><strong>Csatafejsze</strong></td><td>0.75×</td><td>1.25×</td><td>Kiegyensúlyozott harci és favágó eszköz</td></tr>
  <tr><td><strong>Háborús kalapács</strong></td><td>0.67×</td><td>0.67×</td><td>Mindkét esetben gazdaságos</td></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td><strong>Ácskapa (Mattock)</strong></td><td>1×</td><td><strong>0.4× ✅</strong></td><td>Leggazdaságosabb blokk-bontó eszköz!</td></tr>
  <tr style="background:rgba(255,100,100,0.15)"><td><strong>Kasza</strong></td><td><strong>4× ‼️</strong></td><td>2×</td><td>⚠️ Harcban nagyon gyorsan kopik!</td></tr>
</table>

<h3 id="reach">⚔️ Elérési Távolság (Reach)</h3>
<p>A MITE:BE-ben az elérési távolság <strong>jóval kisebb</strong> mint a vanilla Minecraftban!</p>
<table class="compare-table">
  <tr><th>Bónusz</th><th>Teljes elérés (blokkok ellen)</th><th>Eszköz / Tárgy</th></tr>
  <tr style="background:rgba(255,80,80,0.10)"><td>Alap (üres kéz)</td><td><strong>2.75 blokk</strong></td><td>— (vanilla-ban 4.5!)</td></tr>
  <tr><td>+0.50</td><td>3.25 blokk</td><td>Fabot, Csont, Fa Buzogány, Kézbalta</td></tr>
  <tr style="background:rgba(200,160,80,0.12)"><td>+0.75</td><td>3.50 blokk</td><td>Vaskard, Vascsákány, Vas Ásó, Vas Fejsze, Vas Kapa, Háborús Kalapács, Csatafejsze</td></tr>
  <tr style="background:rgba(100,200,100,0.12)"><td><strong>+1.00</strong></td><td><strong>3.75 blokk</strong></td><td>⭐ <strong><span class="wiki-item" data-id="iron_scythe">Vas Kasza</span></strong> — legjobb közelharci elérés!</td></tr>
</table>
<div class="info-box">⚠️ <strong>Fontos:</strong> Réz, Ezüst, Bronz, Keménykő (és magasabb szintű) változatai csak Vas szintű eszközök kapnak +0.75 bónuszt az elérés adataiban. Ellenfelekhez való közelharci elérés alap értéke: <strong>1.5 blokk</strong>.</div>

<h2 id="enchanting">Bűvölőasztal</h2>

<h3>Smaragd Bűvölőasztal</h3>
<div class="recipe">Smaragd + Obszidián + Könyv → Smaragd Bűvölőasztal</div>

<h3>Gyémánt Bűvölőasztal</h3>
<p>Erős bűvölésekhez <strong>24 könyvespolc</strong> szükséges! A Gyémánt Bűvölőasztal <strong>Lapis lazulit</strong> igényel bűvöléshez. A magasabb szintű asztal lehetővé teszi a kívánt bűvölés közvetlen kiválasztását.</p>
<div class="warning-box">💎 <strong>Gyémánt gazdálkodás:</strong> Az összes hasznos recepthez összesen kb. <strong>11 gyémánt</strong> szükséges — takarékoskodj velük!<ul style="margin:4px 0 0 0"><li>2 gyémánt → Gyémánt Bűvölőasztal</li><li>Maradék → egyéb kulcs receptek</li></ul></div>

<h3>Elérhető bűvölések</h3>
<p>Ritkaság: <span style="color:#aaa">■ Közönséges</span> · <span style="color:#5f5">■ Ritka</span> · <span style="color:#55f">■ SzoÜst</span> · <span style="color:#a0f">■ Epikus</span> &nbsp;|&nbsp; <span style="background:rgba(255,200,0,0.12);padding:0 4px">Sárga = MITE-specifikus bűvölés</span></p>
<table class="compare-table">
  <tr><th>Bűvölés</th><th>Ritkaság</th><th>Max szint</th><th>Mire</th></tr>
  <tr><td>Védelem</td><td style="color:#aaa">Közönséges</td><td>IV</td><td>Páncél</td></tr>
  <tr><td>Tűzvédelem</td><td style="color:#55f">SzoÜst</td><td>IV</td><td>Páncél</td></tr>
  <tr><td>Pehelykönnyű hullás</td><td style="color:#55f">SzoÜst</td><td>IV</td><td>Csizma</td></tr>
  <tr><td>Élesség</td><td style="color:#aaa">Közönséges</td><td>V</td><td>Kard</td></tr>
  <tr><td>Visszalökés</td><td style="color:#55f">SzoÜst</td><td>II</td><td>Kard</td></tr>
  <tr><td>Tűzaspektus</td><td style="color:#5f5">Ritka</td><td>II</td><td>Kard</td></tr>
  <tr><td>Fosztogatás</td><td style="color:#55f">SzoÜst</td><td>III</td><td>Kard</td></tr>
  <tr><td>Hatékonyság</td><td style="color:#aaa">Közönséges</td><td>V</td><td>Szerszám</td></tr>
  <tr><td>Töretlenség</td><td style="color:#55f">SzoÜst</td><td>V</td><td>Bármely</td></tr>
  <tr><td>Erő</td><td style="color:#aaa">Közönséges</td><td>V</td><td>Íj</td></tr>
  <tr><td>Láng</td><td style="color:#5f5">Ritka</td><td>I</td><td>Íj</td></tr>
  <tr style="background:rgba(255,200,0,0.08)"><td><strong>Vámpír 🩸</strong></td><td style="color:#a0f">Epikus</td><td>V</td><td>Fegyver</td></tr>
