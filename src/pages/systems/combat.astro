  <tr style="background:rgba(255,200,0,0.08)"><td><strong>Fa Döntés 🪓</strong></td><td style="color:#55f">SzoÜst</td><td>V</td><td>Fejsze</td></tr>
  <tr style="background:rgba(255,200,0,0.08)"><td><strong>Regenerálódás 💚</strong></td><td style="color:#5f5">Ritka</td><td>V</td><td>Páncél</td></tr>
