  <tr><td>Sült burgonya</td><td>6</td><td>2</td><td>—</td><td>—</td><td>—</td><td>Közepes</td></tr>
  <tr><td>Nyers sertéshús</td><td>4</td><td>4</td><td>4.0</td><td>—</td><td>—</td><td>Nyersen is megy</td></tr>
  <tr><td>Sült sertéshús</td><td>8</td><td>8</td><td>8.0</td><td>—</td><td>—</td><td>Jó fehérjeforrás</td></tr>
  <tr><td>Sült csirke</td><td>6</td><td>6</td><td>6.0</td><td>—</td><td>—</td><td>Közepesen jó</td></tr>
  <tr><td>Sült steak 🥩</td><td>10</td><td>10</td><td>10.0</td><td>—</td><td>—</td><td>Kiváló fehérje</td></tr>
