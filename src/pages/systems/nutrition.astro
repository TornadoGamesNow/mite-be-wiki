  <tr><td>Sült medve/cápa hús</td><td>12</td><td>12</td><td>12.0</td><td>—</td><td>—</td><td>Veszélyes zsákmány</td></tr>
  <tr><td>Burgonya püré 🥔</td><td>12</td><td>8</td><td>8.0</td><td>—</td><td>—</td><td>Szakács foglalkozás</td></tr>
  <tr><td>Tök pite 🎃</td><td>10</td><td>6</td><td>6.0</td><td>6.0</td><td>✓</td><td>Szakács foglalkozás</td></tr>
  <tr><td>Gombakrémleves</td><td>3</td><td>5</td><td>5.0</td><td>—</td><td>—</td><td>Szakács foglalkozás</td></tr>
  <tr><td>Zöldségkrémleves 🥦</td><td>7</td><td>7</td><td>7.0</td><td>7.0</td><td>—</td><td>Szakács foglalkozás</td></tr>
  <tr><td>Csirkeleves 🍲</td><td>10</td><td>10</td><td>10.0</td><td>10.0</td><td>—</td><td>Szakács — komplex</td></tr>
