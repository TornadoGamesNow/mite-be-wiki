---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TopNav from '../../components/TopNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import CraftingGrid from '../../components/CraftingGrid.astro';
import PageSummary from '../../components/PageSummary.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ProgressComplete from '../../components/ProgressComplete.astro';
import { getSidebarGroups } from '../../data/sidebar-config.ts';
import '../../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups('systems/nutrition');
---
<BaseLayout title="Nutrition & Water — MITE:BE Wiki" description="MITE:BE nutrition and water: balancing 4 nutrients, avoiding headaches, best foods, water sources.">
  <Header />
  <TopNav currentPage="systems" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<PageSummary keyPoints={{
  hu: [
    '4 tápanyag (Jóllakottság, Táplálék, Fehérje, Fitó) — arányosan fogyassz',
    'Fejfájás = egyoldalú étrend — salátával orvosolható (Tál + 3× Pitypang)',
    'Marha Pörkölt (16/16/16/16) a legjobb étel — Szakács képesség kell',
  ],
  en: [
    '4 nutrients (Satiation, Nutrition, Protein, Phyto) — must stay balanced',
    'Headache = unbalanced diet — fix with salad (Bowl + 3x Dandelion)',
    'Beef Stew (16/16/16/16) is the best food — requires Cook skill',
  ],
  ru: [
    '4 вещества (Насыщение, Питание, Белок, Фито) — держи баланс',
    'Головная боль = дисбаланс — лечи салатом (Миска + 3× Одуванчик)',
    'Говяжье рагу (16/16/16/16) — лучшая еда, нужна Кулинария',
  ],
}} />

<div data-lang="hu">
<h2 id="food">Élelmiszer &amp; Táplálkozás</h2>
<p>A MITE:BE-ben az étrend sokszínűsége kritikus! Egyoldalú táplálkozás Alultápláltságot okoz. Nyomj <strong>P</strong>-t a táplálkozási mutató megnyitásához!</p>

<div class="info-box">🤕 <strong>Fejfájás tünet?</strong> Ha a karaktered rendszeresen szenved fejfájástól (folyamatos sebzés), az szinte biztosan <strong>kiegyensúlyozatlan étrend</strong> jele. Egyél salátát: <strong>Tál + 3× Pitypang</strong> (vagy más zöldség). Nyomj P-t az étrend részleteiért!</div>

<h3>Korai ételek</h3>
<table>
  <tr><th>Étel</th><th>Forrás</th><th>Megjegyzés</th></tr>
  <tr><td>Búzamag</td><td>Magas fű</td><td>Azonnal ehető, kevés tápérték</td></tr>
  <tr><td>Alma</td><td>Tölgyfa levelek</td><td>Jó gyümölcs</td></tr>
  <tr><td>Tojás</td><td>Csirkék</td><td>Ehető nyersen</td></tr>
  <tr><td>Sült hús</td><td>Tábortűz/kemence</td><td>Fehérje — fontos!</td></tr>
  <tr><td>Kenyér</td><td>Liszt + Víz + Sütés</td><td>Alapvető szénhidrát</td></tr>
  <tr><td><span class="wiki-item" data-id="salad">Saláta</span></td><td>Tál + Zöldség (pl. 3× <span class="wiki-item" data-id="dandelion">Pitypang</span>)</td><td>Növényi tápanyag — fejfájás ellen!</td></tr>
</table>

<h3>Tápértékek</h3>
<p>A MITE:BE 4 tápanyagot követ. <strong>Telítettség</strong> (éhség csökkentés), <strong>Táplálkozás</strong> (tényleges tápérték), <strong>Fehérje</strong> és <strong>Növényi tápanyag</strong>. Az <strong>IR</strong> (Inzulinválasz) magas cukortartalmú ételeknél jelenik meg — az egyoldalúan cukros étrend rontja az energiaszintet!</p>
<table class="compare-table">
  <tr><th>Étel</th><th>Tel.</th><th>Tápl.</th><th>Fehérje</th><th>Fitotáp.</th><th>IR</th><th>Megjegyzés</th></tr>
  <tr><td>Búzamag</td><td>1</td><td>0</td><td>—</td><td>—</td><td>—</td><td>Korai vészkijárat</td></tr>
  <tr><td>Alma</td><td>2</td><td>1</td><td>—</td><td>1.0</td><td>✓</td><td>Tölgyfa levelekből</td></tr>
  <tr><td>Kenyér</td><td>8</td><td>2</td><td>—</td><td>—</td><td>—</td><td>Alap szénhidrát</td></tr>
  <tr><td>Tojás</td><td>1</td><td>3</td><td>3.0</td><td>—</td><td>—</td><td>Csirkétől, nyersen is ehető</td></tr>
