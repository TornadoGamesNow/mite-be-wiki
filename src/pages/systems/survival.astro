---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TopNav from '../../components/TopNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import CraftingGrid from '../../components/CraftingGrid.astro';
import PageSummary from '../../components/PageSummary.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ProgressComplete from '../../components/ProgressComplete.astro';
import { getSidebarGroups } from '../../data/sidebar-config.ts';
import '../../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups('systems/survival');
const wormCompostingRows = [
  { item: { hu: 'Lomb / levelek', en: 'Leaves', ru: 'Листва' }, value: '1.0', note: { hu: 'Minden levéltípus erős alapanyag.', en: 'All leaf variants are strong basic feedstock.', ru: 'Все виды листвы дают хороший базовый материал.' } },
  { item: { hu: 'Magas fű / páfrány', en: 'Tall grass / fern', ru: 'Высокая трава / папоротник' }, value: '0.5', note: { hu: 'Korai játékban könnyen farmolható.', en: 'Easy to mass-collect in early game.', ru: 'Легко собирать массово в начале игры.' } },
  { item: { hu: 'Virágok', en: 'Flowers', ru: 'Цветы' }, value: '0.3', note: { hu: 'Alacsony, de biztos komposztérték.', en: 'Low but reliable compost value.', ru: 'Невысокая, но стабильная ценность.' } },
  { item: { hu: 'Barna / piros gomba', en: 'Brown / red mushroom', ru: 'Коричневый / красный гриб' }, value: '0.5', note: { hu: 'Közepes értékű, könnyű kiegészítő alapanyag.', en: 'Mid-value filler material.', ru: 'Средняя ценность, удобный наполнитель.' } },
  { item: { hu: 'Tök', en: 'Pumpkin', ru: 'Тыква' }, value: '2.0', note: { hu: 'A referencia plusz tökmagot is jelez.', en: 'The reference also indicates pumpkin seeds as extra return.', ru: 'Справочник также указывает возврат тыквенных семечек.' } },
  { item: { hu: 'Dinnye blokk', en: 'Melon block', ru: 'Блок арбуза' }, value: '2.0', note: { hu: 'A referencia plusz dinnyemagot is jelez.', en: 'The reference also indicates melon seeds as extra return.', ru: 'Справочник также указывает возврат арбузных семечек.' } },
  { item: { hu: 'Szénabála', en: 'Hay Bale', ru: 'Тюк сена' }, value: '4.5', note: { hu: 'A legerősebb egytételes komposztforrás a nyers listában.', en: 'The strongest single-item compost source in the raw list.', ru: 'Самый сильный одиночный источник компоста в сыром списке.' } },
  { item: { hu: 'Alma', en: 'Apple', ru: 'Яблоко' }, value: '0.3', note: { hu: 'Étellel is lehet komposztálni, de nem túl hatékony.', en: 'Food can be composted too, but this is not very efficient.', ru: 'Еду тоже можно компостировать, но это не слишком эффективно.' } },
  { item: { hu: 'Búza', en: 'Wheat', ru: 'Пшеница' }, value: '0.5', note: { hu: 'Jobb, mint a legtöbb virág vagy alma.', en: 'Better than most flowers or apples.', ru: 'Лучше, чем большинство цветов или яблок.' } },
  { item: { hu: 'Kenyér', en: 'Bread', ru: 'Хлеб' }, value: '1.0', note: { hu: 'Meglepően jó komposztérték kész ételhez képest.', en: 'Surprisingly solid value for processed food.', ru: 'Неожиданно неплохая ценность для готовой еды.' } },
  { item: { hu: 'Gombaleves', en: 'Mushroom Stew', ru: 'Грибной суп' }, value: '0.6', note: { hu: 'A referencia a tál visszajárását is jelzi.', en: 'The reference also notes the bowl as an extra return.', ru: 'В справочнике также указан возврат миски.' } },
  { item: { hu: 'Papír / cukor / Nether Wart', en: 'Paper / sugar / Nether Wart', ru: 'Бумага / сахар / адский нарост' }, value: '0.1', note: { hu: 'Leggyengébb még elfogadott kategória.', en: 'The weakest still-valid compost tier.', ru: 'Самая слабая, но всё ещё допустимая категория.' } },
  { item: { hu: 'Hal / nyers vagy sült csirke', en: 'Fish / raw or cooked chicken', ru: 'Рыба / сырая или жареная курица' }, value: '0.6', note: { hu: 'Közepes húsalapú érték.', en: 'Mid-tier meat-based value.', ru: 'Средняя мясная ценность.' } },
  { item: { hu: 'Sertéshús', en: 'Pork', ru: 'Свинина' }, value: '0.8', note: { hu: 'Kicsit jobb, mint a hal vagy csirke.', en: 'Slightly better than fish or chicken.', ru: 'Немного лучше, чем рыба или курица.' } },
  { item: { hu: 'Marhahús', en: 'Beef', ru: 'Говядина' }, value: '1.0', note: { hu: 'Az egyik legerősebb hús-alapú tétel.', en: 'One of the strongest meat entries in the list.', ru: 'Один из самых сильных мясных вариантов в списке.' } },
  { item: { hu: 'Répa', en: 'Carrot', ru: 'Морковь' }, value: '0.3', note: { hu: 'Alap zöldségszint.', en: 'Basic vegetable-tier value.', ru: 'Базовая овощная ценность.' } },
  { item: { hu: 'Burgonya / sült burgonya / mérgező burgonya', en: 'Potato / baked potato / poisonous potato', ru: 'Картофель / печёный картофель / ядовитый картофель' }, value: '0.4 / 0.8 / 0.2', note: { hu: 'A sütés javít rajta, a mérgező változat gyenge.', en: 'Cooking improves it; the poisonous version is weak.', ru: 'После готовки ценность выше; ядовитая версия слабая.' } },
  { item: { hu: 'Tökpite', en: 'Pumpkin Pie', ru: 'Тыквенный пирог' }, value: '1.6', note: { hu: 'Kiemelkedően jó feldolgozott étel-komposzt.', en: 'An unusually strong processed-food compost option.', ru: 'Необычно сильный вариант компоста из готовой еды.' } },
];
---
<BaseLayout title="Survival — MITE:BE Wiki" description="MITE:BE survival: backpack (B key), body temperature 36-37°C, reduced stack sizes, storage planning.">
  <Header />
  <TopNav currentPage="systems" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<PageSummary keyPoints={{
  hu: [
    'Hátizsák (B gomb) — v0.9.0-ban a biztosan megszerezhető végpont az Ősi Fém Hátizsák: 78 slot',
    'Testhőmérséklet: 36–37°C optimális — kemence 2-3 blokkon belül túlmelegíthet',
    'Csökkentett stack méretek (kő: 8, rönk: 4, érc: 5) — több tároló kell',
  ],
  en: [
    'Backpack (B key) — in v0.9.0 the reliably obtainable end point is the Ancient Metal Backpack: 78 slots',
    'Body temp: 36–37°C optimal — 2-3 blocks from furnace overheats you',
    'Reduced stack sizes (stone: 8, logs: 4, ores: 5) — you need more storage',
  ],
  ru: [
    'Рюкзак (клавиша B) — в v0.9.0 надёжно достижимый максимум: рюкзак из Древнего металла на 78 ячеек',
    'Температура тела: 36–37°C — в 2-3 блоках от печи можно перегреться',
    'Уменьшенные стаки (камень: 8, брёвна: 4, руда: 5) — нужно больше хранилищ',
  ],
}} />

<div data-lang="hu">
<h2 id="backpacks">Hátizsákok</h2>
<p>Extra tárhelyért hátizsákokat készíthetsz, egyre nagyobb kapacitással. <strong>B gomb</strong> = hátizsák megnyitása!</p>
<table class="compare-table">
  <tr><th>Hátizsák</th><th>Slotok</th><th>v0.9.0 státusz</th></tr>
  <tr><td>Bőr Hátizsák</td><td>10</td><td>Normál recepttel elkészíthető alap hátizsák</td></tr>
  <tr><td>Nagy Hátizsák</td><td>21</td><td><span class="wiki-item" data-id="big_backpack_upgrade">Nagy Hátizsák Fejlesztés</span> tárggyal fejleszthető</td></tr>
  <tr style="background:rgba(180,120,255,0.12)"><td><strong>Ősi Fém Hátizsák</strong></td><td><strong>78</strong></td><td><span class="wiki-item" data-id="ancient_metal_backpack_upgrade">Ősi Fém Hátizsák Fejlesztés</span> + higanyüst + Tudáskönyv</td></tr>
  <tr><td>Réz / Ezüst / Vas / Arany / Keménykő</td><td>21 / 21 / 36 / 44 / 55</td><td>Régi hátizsák-típusok a játékfájlokban; a jelenlegi v0.9.0-ban nincs helyi receptlista hozzájuk</td></tr>
  <tr><td>Mithril / Adamantium</td><td>90 / 102</td><td>A játékfájlok név szerint tartalmazzák, de a v0.9.0-hoz nem találtam hozzájuk receptet vagy fejlesztő tárgyat</td></tr>
</table>
<div class="tip-card">🎒 <strong>Biztos v0.9.0 útvonal:</strong> Bőr Hátizsák → Nagy Hátizsák Fejlesztő → Ősi Fém Hátizsák Fejlesztő. Az utolsó lépéshez a nagy hátizsák-fejlesztőt és 4× ősi fémrudat kell teljes higanyüstbe tenni, alul magma/láva hőforrással, majd kb. 30 másodpercet várni.</div>
<div class="tip-card">🖱️ <strong>Hogyan kell felhasználni a fejlesztő itemeket:</strong> a helyi item-docok szerint mindkét hátizsák-fejlesztő <strong>ráhúzás + kattintás</strong> módon működik a <strong>kiegészítő slotban viselt</strong> hátizsákon. Előbb a Big Backpack Upgrade megy a Leather Backpackre, utána ugyanígy az Ancient Metal Backpack Upgrade. Ugyanez a helyi leírás azt is sugallja, hogy a jelenlegi útvonalon a bőr és ősi fém hátizsák <strong>nem levételre tervezett</strong> accessory-állapot.</div>

<h3>Fejlett tárolók</h3>
<p>A helyi item-info alapján a v0.9.0-ban a láda- és hordófejlesztések a <strong>dedikált upgrade item</strong> útvonalra egyszerűsödtek. Ezekhez <strong>Ősi Fém Tároló Tudáskönyv</strong> kell, használatuk pedig lerakott tárolón történik.</p>
<table class="compare-table">
  <tr><th>Tároló</th><th>Kapacitás</th><th>Biztosan igazolt működés</th></tr>
  <tr><td><strong>Ősi Fém Láda / Hordó</strong></td><td><strong>15×7 = 105</strong></td><td>Dedikált upgrade item kell; <strong>Shift + jobb klikk</strong> a lerakott ládán / rekeszen / hordón</td></tr>
  <tr><td>Mithril Láda / Hordó</td><td>17×7 = 119</td><td>Csak az elvárt alsó tierre megy rá, szintet nem ugrik át</td></tr>
  <tr><td>Adamantium Láda / Hordó</td><td>19×7 = 133</td><td>Szintén csak a közvetlen előző tárolót fejleszti tovább</td></tr>
</table>
<div class="info-box">📦 <strong>Röviden:</strong> a biztos v0.9.0 logika itt az, hogy a storage-upgrade itemek <strong>nem ugranak át szinteket</strong>, és az Ősi Fém Tároló Tudáskönyv az ősi fémes upgrade-item vonalat oldja fel: hátizsák, láda és hordó.</div>
<div class="tip-card">📦 <strong><span class="wiki-item" data-id="crate">Rekesz / Crate</span>:</strong> v0.9.0-ban bekerült a <strong>mozgatható</strong> faláda-család. A tölgy, nyír, dzsungel és luc változatok mind <strong>9×6-os</strong>, nagy láda méretű tárolót adnak, és a chest upgrade route is tud rájuk épülni.</div>

<h2 id="temperature">Testhőmérséklet</h2>
<p>A testhőmérséklet 36–37°C-ban optimális. Tűz, láva, Alvilág emeli — víz, eső, jég csökkenti.</p>
<table class="compare-table">
  <tr><th>Hőmérséklet</th><th>Hatás</th></tr>
  <tr style="background:rgba(100,180,255,0.12)"><td><strong>&lt;35.8°C</strong></td><td>Hideg státusz — enyhe lassítás</td></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td><strong>36–37°C</strong></td><td>✅ Optimális — nincs debuff</td></tr>
  <tr style="background:rgba(255,200,0,0.10)"><td><strong>37.2–38.1°C</strong></td><td>Gyengeség I</td></tr>
  <tr style="background:rgba(255,150,50,0.12)"><td><strong>38.2–39°C</strong></td><td>Gyengeség I + Láng + Lassítás I + 1 HP/perc</td></tr>
  <tr style="background:rgba(255,80,30,0.14)"><td><strong>39–45°C+</strong></td><td>Gyengeség I + Láng + Lassítás I + 1 HP/20mp</td></tr>
</table>
<div class="warning-box">🔥 <strong>Kemence közelség = túlmelegedés!</strong> Ha 2–3 blokkon belül állsz egy égő kemencéhez, a testhőmérsékleted átléphet 37.2°C-ot → <strong>Gyengeség I</strong>. Megoldás: állj távolabb, vagy kezeld hűtéssel.</div>
<div class="tip-card">🌡️ <strong>Melegítő módosítók:</strong> Láva (2 blokk közel): +0.1°C/35mp · Tűz (3 blokk): +0.1°C/50mp · Fáklya tartása: +0.1°C/60mp · Alvilág: állandó +0.4°C<br>🌡️ <strong>Hűtő módosítók:</strong> Vízbe merülés: −0.1°C/5mp · Jég tartása: −0.1°C/25mp · Fagylalt evése: −0.1°C</div>
<div class="tip-card">🎋 <strong><span class="wiki-item" data-id="bamboo_helmet">Bambuszkalap</span>:</strong> a <strong>kiegészítő slotban</strong> viselve kivédi az esős idő negatív hatását. Esőben <strong>30 másodpercenként 1 tartósságot</strong> veszít, <strong>0 tartósságnál nem tűnik el</strong>, csak hatástalan lesz. A helyi item-doc ezt a javítóblokkot belsőleg <strong>Armor Stand</strong>-ként írja le, de funkció szerint <strong>szárító / kalaptartó</strong>: itt kb. <strong>1 tartósság / 3 másodperc</strong> tempóval javul.</div>

<h3>Korlátozott Kötegméret (Stack Limit)</h3>
<p>A MITE:BE drastikusan csökkenti a legtöbb blokk kötegméretét — komoly <strong>leltár- és tárolástervezést</strong> igényel!</p>
<table class="compare-table">
  <tr><th>Kategória</th><th>Példák</th><th>MITE köteg</th><th>Vanilla köteg</th></tr>
  <tr style="background:rgba(255,100,100,0.10)"><td><strong>Kő / Kőtömb</strong></td><td>Kő, Gránit, Diorit, Andezit</td><td><strong>8</strong></td><td>64</td></tr>
  <tr style="background:rgba(255,100,100,0.10)"><td><strong>Rönk</strong></td><td>Tölgy, Lucfenyő, Nyár, Jungle Rönk</td><td><strong>4</strong></td><td>64</td></tr>
  <tr style="background:rgba(255,100,100,0.10)"><td><strong>Deszka</strong></td><td>Minden deszka típus</td><td><strong>8</strong></td><td>64</td></tr>
  <tr style="background:rgba(255,100,100,0.10)"><td><strong>Ércek</strong></td><td>Vas, Réz, Arany, Gyémánt, Mithril, Adamantium</td><td><strong>5</strong></td><td>64</td></tr>
  <tr><td>Homok / Kavics / Föld</td><td>Homok, Kavics, Föld, Alapkő (4)</td><td>8 / 4</td><td>64</td></tr>
  <tr><td>Üveg / Gyapjú</td><td>Üveg blokk, Panel (16), Gyapjú</td><td>4</td><td>64</td></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td>Fáklya</td><td>Fáklya, Vöröskő Fáklya</td><td><strong>32</strong></td><td>64</td></tr>
  <tr style="background:rgba(255,150,0,0.10)"><td><strong>Élelem</strong></td><td>Sült húsok, Kenyér, Alma</td><td><strong>16</strong></td><td>64</td></tr>
  <tr style="background:rgba(255,150,0,0.10)"><td>Tojás / Csali</td><td>Tojás, Giliszta</td><td>16</td><td>16</td></tr>
  <tr style="background:rgba(100,180,255,0.10)"><td><strong>Vödrök</strong></td><td>Üres, Vizes, Lávás, Higanyos</td><td><strong>1</strong></td><td>16</td></tr>
  <tr><td>Nyilak</td><td>Kova, Réz, Vas, Mithril, Adamantium</td><td>32</td><td>64</td></tr>
</table>
<div class="warning-box">📦 <strong>Fontos:</strong> A csökkentett kötegméretek miatt szükséged van <strong>több tároló ládára</strong>, és az anyaggyűjtés is hamarabb tölti meg a leltárat. Tervezz előre!</div>

<h2 id="fishing">Horgászat</h2>
<p>A MITE:BE-ben a horgászat komolyan átalakult: 10 különböző horgászbot létezik, mindegyik más horoganyaggal és tartóssággal. A horgászat eredményességét az <strong>időpont</strong>, az <strong>időjárás</strong> és a <strong>vízmélység</strong> is befolyásolja.</p>

<table class="compare-table">
  <tr><th>Horgászbot</th><th>Horog anyag</th><th>Tartósság</th></tr>
  <tr><td>Kovakő horgászbot</td><td>Kovakő szilánk</td><td>3</td></tr>
  <tr><td>Obszidián horgászbot</td><td>Obszidián szilánk</td><td>4</td></tr>
  <tr><td>Réz horgászbot</td><td>Réz rög</td><td>8</td></tr>
  <tr><td>Ezüst horgászbot</td><td>Ezüst rög</td><td>8</td></tr>
  <tr><td>Arany horgászbot</td><td>Arany rög</td><td>8</td></tr>
  <tr><td>Vas horgászbot</td><td>Vas rög</td><td>16</td></tr>
  <tr style="background:rgba(180,120,255,0.12)"><td><strong>Keménykő horgászbot</strong></td><td>Keménykő rög</td><td><strong>80</strong></td></tr>
  <tr style="background:rgba(180,120,255,0.12)"><td><strong>Ősi fém horgászbot</strong></td><td>Ősi fém rög</td><td><strong>156</strong></td></tr>
  <tr style="background:rgba(255,200,0,0.10)"><td><strong>Mithril horgászbot</strong></td><td>Mithril rög</td><td><strong>400</strong></td></tr>
  <tr style="background:rgba(255,200,0,0.10)"><td><strong>Adamantium horgászbot</strong></td><td>Adamantium rög</td><td><strong>512</strong></td></tr>
</table>

<h3>Mechanika</h3>
<table class="compare-table">
  <tr><th>Tényező</th><th>Hatás</th></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td>Hajnal / Alkony / Eső</td><td>Magasabb fogási esély</td></tr>
  <tr style="background:rgba(100,200,100,0.10)"><td>Mélyebb víz</td><td>Magasabb fogási esély</td></tr>
  <tr style="background:rgba(100,180,255,0.12)"><td>Giliszta csali</td><td>A hal <strong>50%-kal gyorsabban</strong> kapja be a horgot — minden fogásnál 1 giliszta fogy</td></tr>
  <tr style="background:rgba(255,100,100,0.10)"><td>Búvárkodás</td><td>NEM lehet horgászni víz alatt</td></tr>
</table>

<div class="tip-card">🎣 <strong>Harci trükk:</strong> A horgászbot eltalál egy mobot → 1 sebzés (a karaktered támadóereje nem számít). Ha ezután <strong>hotbart váltasz</strong>, a bot nem veszít tartósságot. Korai játékban hasznos gyenge mobokra!</div>
<div class="tip-card">🥕 <strong>Répa-horgászbot:</strong> Bármely horgászbotból craftolható répa-horgászbot. Miután a répa-horgászbot elhasználódik, <strong>teljes tartósságú horgászbotot</strong> kapsz vissza!</div>

<h3>Gilisztás komposztálás</h3>
<p>A ZIP <code>item_composting.txt</code> fájlja külön listázza, milyen itemet milyen értékkel tudnak a giliszták komposztálni. Az alábbiak a legfontosabb, biztosan azonosítható tételek.</p>
<table class="compare-table">
  <tr><th>Item</th><th>Komposztérték</th><th>Megjegyzés</th></tr>
  {wormCompostingRows.map((row) => (
    <tr>
      <td>{row.item.hu}</td>
      <td>{row.value}</td>
      <td>{row.note.hu}</td>
    </tr>
  ))}
</table>
<div class="info-box">🪱 <strong>Ökölszabály:</strong> a <strong>szénabála</strong> messze a legjobb tömegkomposzt, a <strong>tök</strong> és a <strong>dinnye</strong> jó középkategóriás forrás, a levelek pedig olcsó, korlátlan alapanyagot adnak.</div>

<h2 id="knowledge-books">Tudáskönyvek</h2>
<p>A Tudáskönyv egy speciális tárgy, amely haladó receptek feloldására szolgál. Amíg nem rendelkezel a megfelelő Tudáskönyvvel, az adott recept <strong>nem készíthető el</strong>!</p>
<div class="warning-box">🔒 <strong>Kemény zárolás!</strong> Ha egy recept Tudáskönyvhöz kötött, akkor <strong>még akkor sem tudod elkészíteni, ha minden alapanyagod megvan!</strong> A v0.9.0 tapasztalatok és itemleírások alapján a könyvek biztos forrásai közé tartoznak a <strong>földalatti dungeonök kincsesládái</strong> és a <strong>felszíni Pillager-erődök ládái</strong>.</div>

<div class="craft-section">
  <CraftingGrid recipeOutput="miner_helmet" label={{hu: "Bányászsisak (Vas Munkaasztal)", en: "Miner Helmet (Iron Workbench)"}}/>
  <CraftingGrid recipeOutput="battery" label={{hu: "Akkumulátor", en: "Battery"}}/>
