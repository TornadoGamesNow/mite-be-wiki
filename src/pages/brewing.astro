---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import BrewingGrid from '../components/BrewingGrid.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = {
  hu: [
    {
      title: '🧪 Bájitalfőzés',
      links: [
        { href: '#brewing-overview', label: 'Áttekintés' },
        { href: '#brewing-stand', label: 'Főzőállvány' },
        { href: '#brewer-profession', label: 'Bájitalkészítő szakma' },
        { href: '#cauldron', label: 'Üst-mechanikák' },
        { href: '#potions', label: 'Bájital-hatások' },
        { href: '#splash-potions', label: 'Fröccsenő bájitalok' },
        { href: '#disenchanting', label: 'Varázstalanító palack' },
        { href: '#cheese', label: 'Sajtkészítés' },
      ],
    },
    {
      title: '🔗 Kapcsolódó',
      links: [
        { href: `${base}/reference/#potions`, label: '↗ Referencia: Bájitalok' },
        { href: `${base}/reference/#mobs`, label: '↗ Referencia: Szörnyek' },
        { href: `${base}/`, label: '← Wiki főoldal' },
      ],
    },
  ],
  en: [
    {
      title: '🧪 Brewing',
      links: [
        { href: '#brewing-overview', label: 'Overview' },
        { href: '#brewing-stand', label: 'Brewing Stand' },
        { href: '#brewer-profession', label: 'Brewer Profession' },
        { href: '#cauldron', label: 'Cauldron Mechanics' },
        { href: '#potions', label: 'Potion Effects' },
        { href: '#splash-potions', label: 'Splash Potions' },
        { href: '#disenchanting', label: 'Disenchanting Bottle' },
        { href: '#cheese', label: 'Cheese Crafting' },
      ],
    },
    {
      title: '🔗 Related',
      links: [
        { href: `${base}/reference/#potions`, label: '↗ Reference: Potions' },
        { href: `${base}/reference/#mobs`, label: '↗ Reference: Mobs' },
        { href: `${base}/`, label: '← Main wiki' },
      ],
    },
  ],
  ru: [
    {
      title: '🧪 Зельеварение',
      links: [
        { href: '#brewing-overview', label: 'Обзор' },
        { href: '#brewing-stand', label: 'Стойка для зелий' },
        { href: '#brewer-profession', label: 'Профессия «Зельевар»' },
        { href: '#cauldron', label: 'Механики котла' },
        { href: '#potions', label: 'Эффекты зелий' },
        { href: '#splash-potions', label: 'Взрывные зелья' },
        { href: '#disenchanting', label: 'Бутылка расчарования' },
        { href: '#cheese', label: 'Крафт сыра' },
      ],
    },
    {
      title: '🔗 Связанное',
      links: [
        { href: `${base}/reference/#potions`, label: '↗ Справочник: Зелья' },
        { href: `${base}/reference/#mobs`, label: '↗ Справочник: Мобы' },
        { href: `${base}/`, label: '← Главная вики' },
      ],
    },
  ],
};
---
<BaseLayout title="Bájitalfőzés — MITE: Break Everything Wiki">
  <Header />
  <TopNav currentPage="brewing" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<!-- ═══════════════════════════════════════════════ HUNGARIAN ═══ -->
<div data-lang="hu">
<h2 id="brewing-overview">🧪 Bájitalfőzés (Brewing)</h2>
<p>A MITE: Break Everything bájitalrendszere a vanilla Minecraft alapjaira épül, de számos egyedi hatással és az üst-mechanikával egészül ki.</p>

<div class="warning-box">⚠️ <strong>A bájitalkészítő szakma jelenleg nincs aktiválva a v0.9.0-ban.</strong> A bájitalfőzés és a sajtkészítés <strong>szakma nélkül is elérhető</strong> az aktuális verzióban — a bájitalkészítő rendszer csak érdekességképpen van dokumentálva.</div>

<div class="info">⚗️ <strong>Gyors áttekintés:</strong> Főzőállvány → bájitalok (szakma nélkül is). Üst (Cauldron) → speciális receptek (Folyékony arany, Higany, Ősi fémhátizsák). Sajt = bármilyen fémtejesvödör.</div>

<!-- ─── Brewing Stand ─── -->
<h2 id="brewing-stand">Főzőállvány (Brewing Stand)</h2>
<p>A főzőállvány elkészítéséhez <strong>kovamunkaasztal</strong> (vagy magasabb) szükséges:</p>

<div class="craft-section">
  <div class="craft-table">
    <div class="craft-grid g3x3">
      <div class="craft-slot empty"></div>
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" data-lang="hu" style="color:#e94560">Blaze-rúd (Blaze Rod)</div><div class="tt-name" data-lang="en" style="color:#e94560">Blaze Rod</div><div class="tt-desc" data-lang="hu">Blaze dobja (Alvilág)</div><div class="tt-desc" data-lang="en">Dropped by Blaze (Nether)</div></div>
        <img src={`${base}/img/items/blaze_rod.png`} alt="" onerror="this.style.opacity=.3">
      </div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" style="color:#aaa">Zúzott kő (Cobblestone)</div><div class="tt-desc" data-lang="hu">Bányászott kő</div><div class="tt-desc" data-lang="en">Cobblestone</div></div>
        <img src={`${base}/img/blocks/stone.png`} alt="" onerror="this.style.opacity=.3">
      </div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" style="color:#aaa">Zúzott kő</div></div>
        <img src={`${base}/img/blocks/stone.png`} alt="" onerror="this.style.opacity=.3">
      </div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot empty"></div>
    </div>
    <div class="craft-arrow-box">➜</div>
    <div class="craft-output">
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" data-lang="hu" style="color:#4ecca3">Főzőállvány</div><div class="tt-name" data-lang="en" style="color:#4ecca3">Brewing Stand</div></div>
      </div>
    </div>
    <div class="craft-label" data-lang="hu">Főzőállvány</div>
    <div class="craft-label" data-lang="en">Brewing Stand</div>
  </div>
</div>

<p>A bájitalfőzés folyamata:</p>
<ol>
  <li><strong>Vizespalack</strong> → Akármelyik vízforrásból (üvegpalack + víz)</li>
  <li>Vizespalack a főzőállványba + <strong>alvilági szemölcs (Nether Wart)</strong> → Zavaros bájital (Awkward Potion)</li>
  <li>Zavaros bájital + hatóanyag → kész bájital</li>
  <li>Opcionális: + <strong>lőpor</strong> → Fröccsenő (Splash) változat</li>
</ol>

<h4 data-lang="hu">1. lépés — Zavaros bájital alapja</h4>
<BrewingGrid
  ingredient="Alvilági szemölcs"
  ingredientImg="img/items/nether_wart.png"
  inputLabel="Vizespalack × 3"
  inputImg="img/items/glass_bottle.png"
  result="Zavaros bájital (Awkward Potion)"
  resultColor="#c0a0ff"
  hu="Minden bájitalrecept kiindulópontja"
  en="Starting point for every potion recipe"
/>

<h4 data-lang="hu">2. lépés — Hatóanyag hozzáadása (példák)</h4>
<div style="display:flex;flex-wrap:wrap;gap:16px;margin:8px 0 16px">
  <div>
    <BrewingGrid
      ingredient="Cukor"
      ingredientImg="img/items/sugar.png"
      inputLabel="Zavaros bájital"
      result="Gyorsaság bájital"
      resultColor="#88ff88"
    />
  </div>
  <div>
    <BrewingGrid
      ingredient="Blaze-por"
      ingredientImg="img/items/blaze_powder.png"
      inputLabel="Zavaros bájital"
      result="Erő bájital"
      resultColor="#ff8844"
    />
  </div>
  <div>
    <BrewingGrid
      ingredient="Magmakrém"
      ingredientImg="img/items/magma_cream.png"
      inputLabel="Zavaros bájital"
      result="Tűzállóság bájital"
      resultColor="#ff4444"
    />
  </div>
  <div>
    <BrewingGrid
      ingredient="Ghast-könny"
      ingredientImg="img/items/ghast_tear.png"
      inputLabel="Zavaros bájital"
      result="Regeneráció bájital"
      resultColor="#ff88cc"
    />
  </div>
</div>

<h4 data-lang="hu">3. lépés — Fröccsenő változat (opcionális)</h4>
<BrewingGrid
  ingredient="Lőpor"
  inputLabel="Bármilyen kész bájital"
  result="Fröccsenő bájital"
  resultColor="#ffcc44"
  hu="Dobható — ellenfelekre vagy szövetségesekre"
  en="Throwable — at enemies or allies"
/>

<!-- ─── Brewer Profession ─── -->
<h2 id="brewer-profession">Bájitalkészítő szakma</h2>
<div class="warning-box">⚠️ <strong>A szakmák jelenleg nincsenek aktiválva a v0.9.0-ban.</strong> Ez az adat a játék fájljaiban megtalálható, de valószínűleg még nem készült el teljesen — érdekességképp szerepel a wikiben.</div>

<p>A bájitalkészítő szakma előnyei:</p>
<ul>
  <li>🧪 Bájitalfőzés (főzőállvány használata)</li>
  <li>🧀 Sajtkészítés (keménykő tejesvödörből)</li>
  <li>⚗️ Speciális üst-receptek elérése</li>
  <li>💊 Varázstalanító palack elkészítése</li>
</ul>

<table>
  <tr><th>Szint</th><th>XP-szükséglet</th><th>Hatás</th></tr>
  <tr><td>1</td><td>0</td><td>Alapszintű bájitalok (Erő I, Gyorsaság I, Regeneráció I...)</td></tr>
  <tr><td>2</td><td>~500 XP</td><td>Bájital II szintek elérhetők; a fröccsenő bájitalok hatékonyabbak</td></tr>
  <tr><td>3</td><td>~2000 XP</td><td>Bájital III szintek; hosszabb időtartam</td></tr>
  <tr><td>4</td><td>~8000 XP</td><td>Bájital IV szintek (max. erő/gyorsaság); 5× hatékonyabb sajt-recept</td></tr>
</table>

<div class="tip">💡 <strong>Tipp:</strong> A bájitalkészítő és a kovács/bűvölő szakmák kombinálása nem lehetséges — csak 1 szakma választható. Ha harcra fókuszálsz, fontold meg, hogy bájitalkészítő helyett bűvölővel indulsz-e.</div>

<!-- ─── Cauldron ─── -->
<h2 id="cauldron">Üst (Cauldron) mechanikák</h2>
<p>Az üst nem csak vizet tárol — egyedi MITE-receptek forrása, amelyek normál főzőállványon NEM készíthetők el.</p>

<div class="info">ℹ️ Az üst <strong>vasmunkaasztalon</strong> készíthető el (kovácsmesterség képesség szükséges): 7× vasrúd, U alakban (3×3 rács).</div>

<table>
  <tr><th>Recept neve</th><th>Folyamat</th><th>Eredmény</th><th>Felhasználás</th></tr>
  <tr>
    <td><strong style="color:var(--gold)">Folyékony arany</strong></td>
    <td>Üst lávaforrás alá helyezve + aranyérc beledobása → 10 mp várakozás</td>
    <td>Folyékony arany az üstben</td>
    <td>4× aranyalma (Golden Apple) készíthető belőle</td>
  </tr>
  <tr>
    <td><strong style="color:var(--silver)">Folyékony higany</strong></td>
    <td>Higanyérc + láva az üstben → olvasztás</td>
    <td>Folyékony higany (vödörrel szedhető)</td>
    <td>Ötvözési alapanyag; ősifém-hátizsák receptjéhez</td>
  </tr>
  <tr>
    <td><strong style="color:var(--ancient)">Ősifém-hátizsák</strong></td>
    <td>Bőrhátizsák + 4× ősifém-rúd a higanyba → 30 mp várakozás</td>
    <td>Ősifém-hátizsák</td>
    <td>Több tárgyhely, tartósabb hátizsák</td>
  </tr>
</table>

<div class="tip">💡 <strong>Higanyforrás:</strong> A mocsár biomban található higanyérc (Y 0–40). Olvasztásához @3 kemence (obszidiánkemence) szükséges!</div>

<!-- ─── Potion Effects ─── -->
<h2 id="potions">Bájital-hatások</h2>
<p>A MITE: Break Everything 20 különböző bájitalhatást tartalmaz, köztük vanilla és egyedi MITE-hatásokat:</p>

<table>
  <tr><th>Bájital / Hatás</th><th>Típus</th><th>Leírás</th><th>Szintek</th></tr>
  <tr><td><strong>Gyorsaság</strong></td><td>Pozitív</td><td>Gyorsabb mozgás</td><td>I–IV</td></tr>
  <tr><td><strong>Erő</strong></td><td>Pozitív</td><td>Több ütési sebzés</td><td>I–IV</td></tr>
  <tr><td><strong>Regeneráció</strong></td><td>Pozitív</td><td>Folyamatos gyógyulás</td><td>I–IV</td></tr>
  <tr><td><strong>Gyógyítás</strong></td><td>Pozitív (azonnali)</td><td>Azonnali életerő-visszatöltés</td><td>I–II</td></tr>
  <tr><td><strong>Tűzállóság</strong></td><td>Pozitív</td><td>A tűz és a láva nem sebez</td><td>I</td></tr>
  <tr><td><strong>Láva-ellenállás</strong> ⭐</td><td>Pozitív (MITE)</td><td>Speciális MITE-hatás — láva-sebzés csökkentése</td><td>I</td></tr>
  <tr><td><strong>Éjjellátás</strong></td><td>Pozitív</td><td>Teljes látás sötétben</td><td>I</td></tr>
  <tr><td><strong>Víz alatti légzés</strong></td><td>Pozitív</td><td>Korlátlan légzés a víz alatt</td><td>I</td></tr>
  <tr><td><strong>Láthatatlanság</strong></td><td>Pozitív</td><td>A szörnyek nem látnak (kivétel: HIM)</td><td>I</td></tr>
  <tr><td><strong>Sértés (Harming)</strong></td><td>Negatív/Fegyver</td><td>Azonnali sebzés — tűzelementál ellen kiváló!</td><td>I–II</td></tr>
  <tr><td><strong>Mérgezés</strong></td><td>Negatív</td><td>Folyamatos mérgezési sebzés</td><td>I–IV</td></tr>
  <tr><td><strong>Gyengeség</strong></td><td>Negatív</td><td>Csökkentett ütési sebzés</td><td>I–II</td></tr>
  <tr><td><strong>Lassítás</strong></td><td>Negatív</td><td>Lassabb mozgás</td><td>I–II</td></tr>
  <tr><td><strong>Sorvadás (Wither)</strong></td><td>Negatív</td><td>Sorvadásos betegség hatás</td><td>I–II</td></tr>
  <tr><td><strong>Korrózió</strong> ⭐</td><td>Negatív (MITE)</td><td>Felszerelés tartósságának csökkentése</td><td>I</td></tr>
  <tr><td><strong>Alvászavar</strong> ⭐</td><td>Negatív (MITE)</td><td>Az alvás nem lehetséges a hatás alatt</td><td>I</td></tr>
  <tr><td><strong>Fagyás</strong> ⭐</td><td>Negatív (MITE)</td><td>Fagyás — melegítsd magad tűzzel!</td><td>I</td></tr>
  <tr><td><strong>Napszúrás</strong> ⭐</td><td>Negatív (MITE)</td><td>Hőség-hatás</td><td>I</td></tr>
  <tr><td><strong>Paralízis</strong> ⭐</td><td>Negatív (MITE)</td><td>Teljes mozgásképtelenség</td><td>I</td></tr>
  <tr><td><strong>Sebezhetőség</strong> ⭐</td><td>Negatív (MITE)</td><td>Több bekapott sebzés minden forrásból</td><td>I</td></tr>
</table>
<p style="font-size:.82em;color:var(--text2)">⭐ = MITE-egyedi hatás, a vanilla Minecraftban nem szerepel</p>

<h3>Hatóanyagok → Hatások</h3>
<table>
  <tr><th>Hatóanyag</th><th>Bázishatás</th><th>Megjegyzés</th></tr>
  <tr><td>Alvilági szemölcs (Nether Wart)</td><td>Zavaros bájital (alap)</td><td>Minden recept kezdete</td></tr>
  <tr><td>Cukor</td><td>Gyorsaság</td><td>–</td></tr>
  <tr><td>Blaze-por</td><td>Erő</td><td>Blaze-rúdból</td></tr>
  <tr><td>Ghast-könny</td><td>Regeneráció</td><td>Ghast dobja</td></tr>
  <tr><td>Magmakrém</td><td>Tűzállóság</td><td>Magmakocka dobja</td></tr>
  <tr><td>Arany sárgarépa</td><td>Éjjellátás</td><td>–</td></tr>
  <tr><td>Pókszem</td><td>Mérgezés</td><td>–</td></tr>
  <tr><td>Gömbhal</td><td>Víz alatti légzés</td><td>–</td></tr>
  <tr><td>Csillogó dinnyeszelet</td><td>Gyógyítás</td><td>–</td></tr>
  <tr><td>Fermentált pókszem</td><td>Gyengeség / Sértés</td><td>Negatív hatásokhoz</td></tr>
  <tr><td>+ Lőpor</td><td>Fröccsenő változat</td><td>Minden bájitalra alkalmazható</td></tr>
  <tr><td>+ Vöröskő</td><td>Hosszabb időtartam</td><td>A hatás szintjét nem növeli</td></tr>
  <tr><td>+ Izzókő-por</td><td>Erősebb hatás (II)</td><td>Vöröskő VAGY izzókő — nem mindkettő!</td></tr>
</table>

<!-- ─── Splash ─── -->
<h2 id="splash-potions">Fröccsenő bájitalok (Splash Potions)</h2>
<p>A legtöbb bájital fröccsenő változatban is elkészíthető — a kész bájitalhoz <strong>lőport (Gunpowder)</strong> adj a főzőállványban.</p>

<div class="tip">💡 A fröccsenő bájitalok dobhatók ellenfelekre (Sértés, Lassítás, Gyengeség) VAGY szövetségesekre (Gyógyítás, Erő). A sértés-bájital különösen hatékony a tüzet nem félő tűzelementál ellen!</div>

<table>
  <tr><th>Stratégia</th><th>Bájital</th><th>Célpont</th></tr>
  <tr><td>Erős boss-harc</td><td>Erő IV Splash</td><td>Saját magad</td></tr>
  <tr><td>Menekülés</td><td>Gyorsaság IV Splash</td><td>Saját magad</td></tr>
  <tr><td>Tűzelementál</td><td>Sértés Splash</td><td>Ellenség (nem sebzi magát!)</td></tr>
  <tr><td>Szörnycsoportok</td><td>Mérgezés IV Splash</td><td>Szörnycsoportok</td></tr>
  <tr><td>Sérült szövetséges</td><td>Gyógyítás II Splash</td><td>Partner NPC</td></tr>
</table>

<!-- ─── Disenchanting ─── -->
<h2 id="disenchanting">Varázstalanító palack (Disenchanting Bottle)</h2>
<p>Egyedi MITE-bájital, amelyet <strong>főzőállványon</strong> kell elkészíteni (szakma szükséges). Recept: alvilági szemölcs + szén → vizespalackokon.</p>

<BrewingGrid
  ingredient="Alvilági szemölcs + szén"
  ingredientImg="img/items/nether_wart.png"
  inputLabel="Vizespalack × 3"
  inputImg="img/items/glass_bottle.png"
  result="Varázstalanító palack"
  resultColor="#7ec8e3"
  hu="Varázstalanító palack"
  en="Disenchanting Bottle"
/>

<p><strong>Hatásai:</strong></p>
<ul>
  <li>✅ Bűvölések eltávolítása tárgyakról (a tapasztalati pont visszakapható!)</li>
  <li>✅ Aktív bájitalhatások törlése saját magadról</li>
  <li>✅ Boszorkányátkok eltávolítása</li>
  <li>⚠️ A tárgy minőségét (Quality) NEM érinti</li>
</ul>

<div class="tip">💡 Rendkívül hasznos, ha rossz bűvölést kaptál a bűvölőasztalnál, vagy ha egy boszorkány megátkozta a felszerelésedet!</div>

<!-- ─── Cheese ─── -->
<h2 id="cheese">Sajtkészítés</h2>
<p><strong>Bájitalkészítő képesség</strong> szükséges. Bármilyen anyagú tejesvödör használható — keménykő, réz, ezüst, arany, vas, ősifém, mithril, adamantium. A vödör szintje határozza meg, melyik munkaasztalon készíthető el a sajt.</p>

<div class="info">ℹ️ A tehenek fejéséhez az adott anyagú vödör kell (pl. keménykő vödör a keménykő tehénhez). A receptek <strong>6400 nehézség/db</strong> értékkel dolgoznak, függetlenül a vödör anyagától.</div>

<table>
  <tr><th>Vödörszám</th><th>Eredmény</th><th>Nehézség/db</th><th>Hatékonyság</th></tr>
  <tr><td>1× vödör</td><td>1× sajt</td><td style="color:var(--accent)">6 400</td><td>Alap (1×)</td></tr>
  <tr><td>2× vödör</td><td>2× sajt</td><td style="color:var(--gold)">3 200/db</td><td>2× hatékonyabb</td></tr>
  <tr><td>3× vödör</td><td>3× sajt</td><td style="color:var(--gold)">2 133/db</td><td>3× hatékonyabb</td></tr>
