---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import BrewingGrid from '../components/BrewingGrid.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = {
  hu: [
    {
      title: '🧪 Brewing',
      links: [
        { href: '#brewing-overview', label: 'Áttekintés' },
        { href: '#brewing-stand', label: 'Főzőállvány' },
        { href: '#brewer-profession', label: 'Brewer Foglalkozás' },
        { href: '#cauldron', label: 'Üst Mechanikák' },
        { href: '#potions', label: 'Bájital Hatások' },
        { href: '#splash-potions', label: 'Fröccsenő Bájitalok' },
        { href: '#disenchanting', label: 'Varázstalanító Palack' },
        { href: '#cheese', label: 'Sajt Készítés' },
      ],
    },
    {
      title: '🔗 Kapcsolódó',
      links: [
        { href: `${base}/reference/#potions`, label: '↗ Referencia: Bájitalok' },
        { href: `${base}/reference/#mobs`, label: '↗ Referencia: Szörnyek' },
        { href: `${base}/`, label: '← Wiki főoldal' },
      ],
    },
  ],
  en: [
    {
      title: '🧪 Brewing',
      links: [
        { href: '#brewing-overview', label: 'Overview' },
        { href: '#brewing-stand', label: 'Brewing Stand' },
        { href: '#brewer-profession', label: 'Brewer Profession' },
        { href: '#cauldron', label: 'Cauldron Mechanics' },
        { href: '#potions', label: 'Potion Effects' },
        { href: '#splash-potions', label: 'Splash Potions' },
        { href: '#disenchanting', label: 'Disenchanting Bottle' },
        { href: '#cheese', label: 'Cheese Crafting' },
      ],
    },
    {
      title: '🔗 Related',
      links: [
        { href: `${base}/reference/#potions`, label: '↗ Reference: Potions' },
        { href: `${base}/reference/#mobs`, label: '↗ Reference: Mobs' },
        { href: `${base}/`, label: '← Main wiki' },
      ],
    },
  ],
};
---
<BaseLayout title="Brewing — MITE: Break Everything Wiki">
  <Header />
  <TopNav currentPage="brewing" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<!-- ═══════════════════════════════════════════════ HUNGARIAN ═══ -->
<div data-lang="hu">
<h2 id="brewing-overview">🧪 Brewing — Bájitalfőzés</h2>
<p>A MITE: Break Everything bájitalrendszere a vanilla Minecraft alapjaira épül, de számos egyedi effekttel és az Üst mechanikával egészül ki.</p>

<div class="warning-box">⚠️ <strong>A Brewer foglalkozás jelenleg nincs aktiválva a v0.9.0-ban.</strong> A bájitalfőzés és a sajtkészítés <strong>foglalkozás nélkül is elérhető</strong> az aktuális verzióban — a Brewer foglalkozás rendszer érdekességképp van dokumentálva.</div>

<div class="info">⚗️ <strong>Gyors áttekintés:</strong> Főzőállvány → bájitalok (foglalkozás nélkül is). Üst (Cauldron) → speciális receptek (Folyékony Arany, Higany, Ősi Fém Hátizsák). Sajt = bármilyen fém tejesvödör.</div>

<!-- ─── Brewing Stand ─── -->
<h2 id="brewing-stand">Főzőállvány</h2>
<p>A Főzőállvány elkészítéséhez <strong>Kova Munkaasztal</strong> (vagy magasabb) szükséges:</p>

<div class="craft-section">
  <div class="craft-table">
    <div class="craft-grid g3x3">
      <div class="craft-slot empty"></div>
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" data-lang="hu" style="color:#e94560">Pokoli Bot (Blaze Rod)</div><div class="tt-name" data-lang="en" style="color:#e94560">Blaze Rod</div><div class="tt-desc" data-lang="hu">Blaze dobja (Nether)</div><div class="tt-desc" data-lang="en">Dropped by Blaze (Nether)</div></div>
        <img src="{base}/img/items/blaze_rod.png" alt="" onerror="this.style.opacity=.3">
      </div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" style="color:#aaa">Kő/Cobblestone</div><div class="tt-desc" data-lang="hu">Kavicsos kő</div><div class="tt-desc" data-lang="en">Cobblestone</div></div>
        <img src="{base}/img/blocks/stone.png" alt="" onerror="this.style.opacity=.3">
      </div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" style="color:#aaa">Kő/Cobblestone</div></div>
        <img src="{base}/img/blocks/stone.png" alt="" onerror="this.style.opacity=.3">
      </div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot empty"></div>
      <div class="craft-slot empty"></div>
    </div>
    <div class="craft-arrow-box">➜</div>
    <div class="craft-output">
      <div class="craft-slot">
        <div class="mc-tooltip"><div class="tt-name" data-lang="hu" style="color:#4ecca3">Főzőállvány</div><div class="tt-name" data-lang="en" style="color:#4ecca3">Brewing Stand</div></div>
      </div>
    </div>
    <div class="craft-label" data-lang="hu">Főzőállvány</div>
    <div class="craft-label" data-lang="en">Brewing Stand</div>
  </div>
</div>

<p>A bájitalfőzés folyamata:</p>
<ol>
  <li><strong>Vízpalack</strong> → Akármelyik vízforrásból (Glass Bottle + víz)</li>
  <li>Vízpalack a Főzőállványba + <strong>Netheri Szemölcs (Nether Wart)</strong> → Zavaros Bájital (Awkward Potion)</li>
  <li>Zavaros Bájital + hatóanyag → kész bájital</li>
  <li>Opcionális: + <strong>Lőpor</strong> → Fröccsenő (Splash) változat</li>
</ol>

<h4 data-lang="hu">1. lépés — Zavaros Bájital alapja</h4>
<BrewingGrid
  ingredient="Netheri Szemölcs"
  ingredientImg="img/items/nether_wart.png"
  inputLabel="Vízpalack × 3"
  inputImg="img/items/glass_bottle.png"
  result="Zavaros Bájital (Awkward Potion)"
  resultColor="#c0a0ff"
  hu="Minden bájital receptjének kiindulópontja"
  en="Starting point for every potion recipe"
/>

<h4 data-lang="hu">2. lépés — Hatóanyag hozzáadása (példák)</h4>
<div style="display:flex;flex-wrap:wrap;gap:16px;margin:8px 0 16px">
  <div>
    <BrewingGrid
      ingredient="Cukor"
      ingredientImg="img/items/sugar.png"
      inputLabel="Zavaros Bájital"
      result="Sebesség Bájital"
      resultColor="#88ff88"
    />
  </div>
  <div>
    <BrewingGrid
      ingredient="Blaze Por"
      ingredientImg="img/items/blaze_powder.png"
      inputLabel="Zavaros Bájital"
      result="Erő Bájital"
      resultColor="#ff8844"
    />
  </div>
  <div>
    <BrewingGrid
      ingredient="Magma Krém"
      ingredientImg="img/items/magma_cream.png"
      inputLabel="Zavaros Bájital"
      result="Tűzállóság Bájital"
      resultColor="#ff4444"
    />
  </div>
  <div>
    <BrewingGrid
      ingredient="Ghast Könny"
      ingredientImg="img/items/ghast_tear.png"
      inputLabel="Zavaros Bájital"
      result="Regeneráció Bájital"
      resultColor="#ff88cc"
    />
  </div>
</div>

<h4 data-lang="hu">3. lépés — Fröccsenő változat (opcionális)</h4>
<BrewingGrid
  ingredient="Lőpor (Gunpowder)"
  inputLabel="Bármilyen kész bájital"
  result="Fröccsenő Bájital"
  resultColor="#ffcc44"
  hu="Dobható — ellenfelekre vagy szövetségesekre"
  en="Throwable — at enemies or allies"
/>

<!-- ─── Brewer Profession ─── -->
<h2 id="brewer-profession">Brewer Foglalkozás</h2>
<div class="warning-box">⚠️ <strong>A foglalkozások jelenleg nincsenek aktiválva a v0.9.0-ban.</strong> Ez az adat a játék fájljaiban megtalálható, de valószínűleg még nem készült el teljesen — érdekességképp szerepel a wikiben.</div>

<p>A Brewer foglalkozás előnyei:</p>
<ul>
  <li>🧪 Bájitalfőzés (Brewing Stand használata)</li>
  <li>🧀 Sajt készítése (Keménykő Tejesvödörből)</li>
  <li>⚗️ Speciális Üst receptek elérése</li>
  <li>💊 Varázstalanító Palack elkészítése</li>
</ul>

<table>
  <tr><th>Szint</th><th>XP szükséglet</th><th>Hatás</th></tr>
  <tr><td>1</td><td>0</td><td>Alapszintű bájitalok (Erő I, Sebesség I, Regeneráció I...)</td></tr>
  <tr><td>2</td><td>~500 XP</td><td>Bájital II szintek elérhetők; splash potions hatékonyabb</td></tr>
  <tr><td>3</td><td>~2000 XP</td><td>Bájital III szintek; hosszabb időtartam</td></tr>
  <tr><td>4</td><td>~8000 XP</td><td>Bájital IV szintek (max erő/sebesség); sajt 5× hatékonyabb recept</td></tr>
</table>

<div class="tip">💡 <strong>Tipp:</strong> Brewer és Blacksmith/Enchanter kombinálás nem lehetséges — csak 1 foglalkozás választható. Ha harcra fókuszálsz, fontold meg, hogy Brewer helyett Enchanterrel indul-e a karaktered.</div>

<!-- ─── Cauldron ─── -->
<h2 id="cauldron">Üst (Cauldron) Mechanikák</h2>
<p>Az Üst nem csak vizet tárol — egyedi MITE receptek forrása, amelyek normál Főzőállványon NEM készíthetők el.</p>

<div class="info">ℹ️ Az Üst <strong>Vas Munkaasztalon</strong> craftolható (blacksmithing skill szükséges): 7× Vas Rúd, U alakban (3×3 rács).</div>

<table>
  <tr><th>Recept neve</th><th>Folyamat</th><th>Eredmény</th><th>Felhasználás</th></tr>
  <tr>
    <td><strong style="color:var(--gold)">Folyékony Arany</strong></td>
    <td>Üst lávaforrás alá helyezve + Arany érc beledobás → 10 mp várakozás</td>
    <td>Folyékony arany az üstben</td>
    <td>4× Aranyalma (Golden Apple) készíthető belőle</td>
  </tr>
  <tr>
    <td><strong style="color:var(--silver)">Folyékony Higany</strong></td>
    <td>Higany érc + Láva az üstben → olvasztás</td>
    <td>Folyékony higany (vödörrel szedhető)</td>
    <td>Ötvözési alapanyag; Ősi Fém Hátizsák recepthez</td>
  </tr>
  <tr>
    <td><strong style="color:var(--ancient)">Ősi Fém Hátizsák</strong></td>
    <td>Bőr Hátizsák + 4× Ősi Fém Rúd higanyba → 30 mp várakozás</td>
    <td>Ősi Fém Hátizsák</td>
    <td>Több tárgy slot, tartósabb hátizsák</td>
  </tr>
</table>

<div class="tip">💡 <strong>Higany forrás:</strong> Mocsár biome-ban található Higany érc (Y 0–40). Olvasztáshoz @3 kemence (Obszidián Kemence) szükséges!</div>

<!-- ─── Potion Effects ─── -->
<h2 id="potions">Bájital Hatások</h2>
<p>A MITE: Break Everything 20 különböző bájital effektet tartalmaz, köztük vanilla és egyedi MITE hatásokat:</p>

<table>
  <tr><th>Bájital / Hatás</th><th>Típus</th><th>Leírás</th><th>Szintek</th></tr>
  <tr><td><strong>Sebesség</strong></td><td>Pozitív</td><td>Gyorsabb mozgás</td><td>I–IV</td></tr>
  <tr><td><strong>Erő</strong></td><td>Pozitív</td><td>Több ütés sebzés</td><td>I–IV</td></tr>
  <tr><td><strong>Regeneráció</strong></td><td>Pozitív</td><td>Folyamatos gyógyulás</td><td>I–IV</td></tr>
  <tr><td><strong>Gyógyítás</strong></td><td>Pozitív (azonnali)</td><td>Azonnali HP visszatöltés</td><td>I–II</td></tr>
  <tr><td><strong>Tűzállóság</strong></td><td>Pozitív</td><td>Tűz és láva nem sebez</td><td>I</td></tr>
  <tr><td><strong>Láva Ellenállás</strong> ⭐</td><td>Pozitív (MITE)</td><td>Speciális MITE effekt — láva sebzés csökkentés</td><td>I</td></tr>
  <tr><td><strong>Éjszakai Látás</strong></td><td>Pozitív</td><td>Teljes látás sötétben</td><td>I</td></tr>
  <tr><td><strong>Vízben Való Légzés</strong></td><td>Pozitív</td><td>Víz alatti lélegzés korlátlanul</td><td>I</td></tr>
  <tr><td><strong>Láthatatlanság</strong></td><td>Pozitív</td><td>Szörnyek nem látnak (kivétel: HIM)</td><td>I</td></tr>
  <tr><td><strong>Sebzés (Harming)</strong></td><td>Negatív/Fegyver</td><td>Azonnali sebzés — Tűz Elementális ellen kiváló!</td><td>I–II</td></tr>
  <tr><td><strong>Mérgezés</strong></td><td>Negatív</td><td>Folyamatos mérgezési sebzés</td><td>I–IV</td></tr>
  <tr><td><strong>Gyengeség</strong></td><td>Negatív</td><td>Csökkentett ütési sebzés</td><td>I–II</td></tr>
  <tr><td><strong>Lassúság</strong></td><td>Negatív</td><td>Lassabb mozgás</td><td>I–II</td></tr>
  <tr><td><strong>Sorvadás (Wither)</strong></td><td>Negatív</td><td>Wither betegség hatás</td><td>I–II</td></tr>
  <tr><td><strong>Korrózió</strong> ⭐</td><td>Negatív (MITE)</td><td>Felszerelés tartósság csökkentés</td><td>I</td></tr>
  <tr><td><strong>Alvászavar</strong> ⭐</td><td>Negatív (MITE)</td><td>Alvás nem lehetséges az effekt alatt</td><td>I</td></tr>
  <tr><td><strong>Hideg</strong> ⭐</td><td>Negatív (MITE)</td><td>Fagyás — melegítsd magad tűzzel!</td><td>I</td></tr>
  <tr><td><strong>Napszúrás</strong> ⭐</td><td>Negatív (MITE)</td><td>Hőség hatás</td><td>I</td></tr>
  <tr><td><strong>Paralízis</strong> ⭐</td><td>Negatív (MITE)</td><td>Teljes mozgásképtelenség</td><td>I</td></tr>
  <tr><td><strong>Sebezhetőség</strong> ⭐</td><td>Negatív (MITE)</td><td>Több bekapott sebzés minden forrásból</td><td>I</td></tr>
</table>
<p style="font-size:.82em;color:var(--text2)">⭐ = MITE egyedi effekt, vanilla Minecraft-ban nem szerepel</p>

<h3>Hatóanyagok → Effektek</h3>
<table>
  <tr><th>Hatóanyag</th><th>Bázis effekt</th><th>Megjegyzés</th></tr>
  <tr><td>Nether Wart (Pokoli Szemölcs)</td><td>Zavaros bájital (alap)</td><td>Minden recept kezdete</td></tr>
  <tr><td>Cukor</td><td>Sebesség</td><td>–</td></tr>
  <tr><td>Blaze Por</td><td>Erő</td><td>Blaze Rod-ból</td></tr>
  <tr><td>Ghast Könny</td><td>Regeneráció</td><td>Ghast dropja</td></tr>
  <tr><td>Magma Krém</td><td>Tűzállóság</td><td>Magma Cube dropja</td></tr>
  <tr><td>Arany Sárgarépa</td><td>Éjszakai Látás</td><td>–</td></tr>
  <tr><td>Pókszem</td><td>Mérgezés</td><td>–</td></tr>
  <tr><td>Puffer Hal</td><td>Vízben Légzés</td><td>–</td></tr>
  <tr><td>Csillogó Dinnyeszelet</td><td>Gyógyítás</td><td>–</td></tr>
  <tr><td>Fermentált Pókszem</td><td>Gyengeség / Sebzés</td><td>Negatív effektekhez</td></tr>
  <tr><td>+ Szikkasztó Lőpor (Gunpowder)</td><td>Fröccsenő változat</td><td>Minden bájitalra alkalmazható</td></tr>
  <tr><td>+ Redstone</td><td>Hosszabb időtartam</td><td>Effekt szintet nem növeli</td></tr>
  <tr><td>+ Glistering Melon / Blaze Por (szint)</td><td>Erősebb hatás (II)</td><td>Redstone VAGY Glowstone — nem mindkettő!</td></tr>
</table>

<!-- ─── Splash ─── -->
<h2 id="splash-potions">Fröccsenő Bájitalok (Splash Potions)</h2>
<p>A legtöbb bájital Fröccsenő változatban is elkészíthető — a kész bájitalhoz <strong>Lőport (Gunpowder)</strong> adj a Főzőállványban.</p>

<div class="tip">💡 Fröccsenő bájitalok dobhatók ellenfelekre (Sebzés, Lassúság, Gyengeség) VAGY szövetségesekre (Gyógyítás, Erő). A Harming Splash különösen hatékony a tüzet nem félő Tűz Elementális ellen!</div>

<table>
  <tr><th>Stratégia</th><th>Bájital</th><th>Célpont</th></tr>
  <tr><td>Erős boss harc</td><td>Erő IV Splash</td><td>Magad</td></tr>
  <tr><td>Menekülés</td><td>Sebesség IV Splash</td><td>Magad</td></tr>
  <tr><td>Tűz Elementális</td><td>Harming Splash</td><td>Ellenség (nem sebzi magát!)</td></tr>
  <tr><td>Mérgezés tömbök</td><td>Mérgezés IV Splash</td><td>Szörny csoportok</td></tr>
  <tr><td>Sérült szövetséges</td><td>Gyógyítás II Splash</td><td>Partner NPC</td></tr>
</table>

<!-- ─── Disenchanting ─── -->
<h2 id="disenchanting">Varázstalanító Palack (Disenchanting Bottle)</h2>
<p>Egyedi MITE bájital amelyet <strong>Főzőállványon</strong> kell elkészíteni (Brewer kell). Recept: Pokoli Szemölcs + Szén → Vízpalackokon.</p>

<BrewingGrid
  ingredient="Nether Wart + Szén"
  ingredientImg="img/items/nether_wart.png"
  inputLabel="Vízpalack × 3"
  inputImg="img/items/glass_bottle.png"
  result="Varázstalanító Palack"
  resultColor="#7ec8e3"
  hu="Varázstalanító Palack"
  en="Disenchanting Bottle"
/>

<p><strong>Hatásai:</strong></p>
<ul>
  <li>✅ Bűvölések eltávolítása tárgyakról (az XP visszakapható!)</li>
  <li>✅ Aktív bájital hatások törlése saját magadról</li>
  <li>✅ Boszorkány átkok eltávolítása</li>
  <li>⚠️ Tárgy minőségét (Quality) NEM érinti</li>
</ul>

<div class="tip">💡 Rendkívül hasznos ha rossz bűvölést kaptál az Enchanting Table-nél, vagy ha Boszorkány megátkozta a felszerelésed!</div>

<!-- ─── Cheese ─── -->
<h2 id="cheese">Sajt Készítés</h2>
<p><strong>Brewer skill</strong> szükséges. Bármilyen anyagú tejesvödör használható — Keménykő, Réz, Ezüst, Arany, Vas, Ős Fém, Mithril, Adamantium. A vödör szintje határozza meg, melyik munkaasztalon craftolható a sajt.</p>

<div class="info">ℹ️ A tehenek fejéséhez az adott anyagú vödör kell (pl. Keménykő Vödör a Keménykő Tehénhez). A receptek <strong>6400 nehézség/db</strong> értékkel dolgoznak, függetlenül a vödör anyagától.</div>

<table>
  <tr><th>Vödörszám</th><th>Eredmény</th><th>Nehézség/db</th><th>Hatékonyság</th></tr>
  <tr><td>1× vödör</td><td>1× Sajt</td><td style="color:var(--accent)">6 400</td><td>Alap (1×)</td></tr>
  <tr><td>2× vödör</td><td>2× Sajt</td><td style="color:var(--gold)">3 200/db</td><td>2× hatékonyabb</td></tr>
  <tr><td>3× vödör</td><td>3× Sajt</td><td style="color:var(--gold)">2 133/db</td><td>3× hatékonyabb</td></tr>
  <tr><td>4× vödör</td><td>4× Sajt</td><td style="color:var(--green)">1 600/db</td><td>4× hatékonyabb</td></tr>
  <tr><td>5× vödör</td><td>5× Sajt</td><td style="color:var(--green)">1 280/db</td><td>5× hatékonyabb</td></tr>
  <tr><td>9× vödör</td><td>9× Sajt</td><td style="color:var(--green)">711/db</td><td style="color:var(--green)">9× hatékonyabb (MAX)</td></tr>
</table>

<p><strong>Sajt tápértéke:</strong> Az egyik legjobb étel MITE-ben — magas jóllakottság és szaturáció. Különösen hasznos hosszú expedíciókon.</p>

<div class="tip">💡 <strong>Pro tipp:</strong> Mindig tegyél be annyi vödröt amennyit csak tudsz — a receptek 9 vödörig skálázódnak, és minden extra vödör csökkenti a nehézség/db arányt!</div>

</div><!-- end hu -->

<!-- ═══════════════════════════════════════════════ ENGLISH ═══ -->
<div data-lang="en">
<h2 id="brewing-overview">🧪 Brewing — Potion Brewing</h2>
<p>MITE: Break Everything's potion system builds on vanilla Minecraft foundations, extended with unique effects and the Cauldron mechanics.</p>

<div class="warning-box">⚠️ <strong>The Brewer profession is not currently active in v0.9.0.</strong> Brewing and cheese-making are <strong>available without a profession</strong> in the current version — the Brewer profession system is documented here as a curiosity.</div>

<div class="info">⚗️ <strong>Quick overview:</strong> Brewing Stand → potions (no profession needed). Cauldron → special recipes (Liquid Gold, Mercury, Ancient Metal Backpack). Cheese = any metal milk bucket.</div>

<!-- ─── Brewing Stand EN ─── -->
<h2 id="brewing-stand">Brewing Stand</h2>
<p>Craft the Brewing Stand at a <strong>Flint Workbench</strong> (or higher):</p>
<ul>
  <li><strong>Ingredients:</strong> 1× Blaze Rod + 2× Cobblestone</li>
  <li><strong>Station:</strong> Flint Workbench or higher</li>
</ul>

<p>Brewing process:</p>
<ol>
  <li><strong>Water Bottle</strong> → any water source (Glass Bottle + water)</li>
  <li>Water Bottle in Brewing Stand + <strong>Nether Wart</strong> → Awkward Potion</li>
  <li>Awkward Potion + ingredient → finished potion</li>
  <li>Optional: + <strong>Gunpowder</strong> → Splash variant</li>
</ol>

