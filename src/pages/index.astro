  <tr><td>Wight</td><td>25</td><td>5</td><td>10</td><td>Slowness + hunger drain</td></tr>
  <tr><td>Wight Guard</td><td>30</td><td>6</td><td>15</td><td>Armored variant</td></tr>
  <tr><td>Invisible Stalker</td><td>20</td><td>5</td><td>12</td><td>Invisible! Only damaged by <strong>silver/mithril+</strong> weapons</td></tr>
  <tr><td>Black Widow Spider</td><td>16</td><td>4</td><td>8</td><td>Strong poison</td></tr>
  <tr><td>Phase Spider</td><td>16</td><td>4</td><td>8</td><td>Walks through walls! Only <strong>Ancient Metal sword</strong> deals damage</td></tr>
  <tr><td>Vampire Bat</td><td>6</td><td>2</td><td>3</td><td>Life steal</td></tr>
  <tr><td>Giant Vampire Bat</td><td>30</td><td>6</td><td>15</td><td>Life steal + high damage</td></tr>
