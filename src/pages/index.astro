---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import HubCard from '../components/HubCard.astro';
import { getSidebarGroups } from '../data/sidebar-config.ts';
import '../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups('none');
---
<BaseLayout title="MITE: Break Everything — Wiki & Progression Guide" description="Unofficial wiki for the MITE: Break Everything mod. Progression guide, item catalogue, recipes, bestiary — trilingual (HU/EN/RU).">
  <Header />
  <TopNav currentPage="home" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<!-- ═══════════════════ HUNGARIAN ═══════════════════ -->
<div data-lang="hu">

<h2 id="intro">MITE: Break Everything Wiki</h2>
<p>A <strong>MITE:BE</strong> (Minecraft Is Too Easy: Break Everything) egy rendkívül nehéz túlélési mod a Minecraft 1.6.4-hez. Puszta kézzel semmit nem tudsz törni — lépésről lépésre kell haladnod a növényszáltól az adamantium felszerelésen át az Ender-sárkány legyőzéséig.</p>

<h3>Fejlődési Útvonal</h3>
<div class="prog-tree">
<span class="prog-node n-fiber"><img src="/mite-be-wiki/img/items/plant_fiber.png" alt="">Növényszál</span>
<span class="prog-arrow">→</span><span class="prog-node n-fiber"><img src="/mite-be-wiki/img/items/straw_rope.png" alt="">Szalmakötél</span>
<span class="prog-arrow">→</span><span class="prog-node n-flint"><img src="/mite-be-wiki/img/shards/flint.png" alt="">Kovakés</span>
<span class="prog-arrow">→</span><span class="prog-node n-flint"><img src="/mite-be-wiki/img/blocks/crafting_table_front.png" alt="">Munkaasztal</span>
<span class="prog-arrow">→</span><span class="prog-node n-flint"><img src="/mite-be-wiki/img/blocks/sieve.png" alt="">Szita</span>
<span class="prog-arrow">→</span><span class="prog-node n-flint"><img src="/mite-be-wiki/img/items/clay_furnace_idle.png" alt="">Agyagkemence</span>
<span class="prog-arrow">→</span><span class="prog-node n-flint"><img src="/mite-be-wiki/img/blocks/furnace_hardened_clay.png" alt="">Keményített Agyagkemence</span>
<span class="prog-arrow">→</span><span class="prog-node n-copper"><img src="/mite-be-wiki/img/ingots/copper.png" alt="">Réz</span>
<span class="prog-arrow">→</span><span class="prog-node n-silver"><img src="/mite-be-wiki/img/ingots/silver.png" alt="">Ezüst</span>
<span class="prog-arrow">→</span><span class="prog-node n-iron"><img src="/mite-be-wiki/img/items/blast_furnace.png" alt="">Nagy Kemence</span>
<span class="prog-arrow">→</span><span class="prog-node n-iron"><img src="/mite-be-wiki/img/items/iron_ingot.png" alt="">Vas</span>
<span class="prog-arrow">→</span><span class="prog-node n-hard"><img src="/mite-be-wiki/img/ingots/hardstone.png" alt="">Keménykő</span>
<span class="prog-arrow">→</span><span class="prog-node n-underground">🕳️ Földalatti világ</span>
<span class="prog-arrow">→</span><span class="prog-node n-ancient"><img src="/mite-be-wiki/img/ingots/ancient_metal.png" alt="">Ősi Fém</span>
<span class="prog-arrow">→</span><span class="prog-node n-mithril"><img src="/mite-be-wiki/img/ingots/mithril.png" alt="">Mithril</span>
<span class="prog-arrow">→</span><span class="prog-node n-nether">🔥 Alvilág</span>
<span class="prog-arrow">→</span><span class="prog-node n-adam"><img src="/mite-be-wiki/img/ingots/adamantium.png" alt="">Adamantium</span>
<span class="prog-arrow">→</span><span class="prog-node n-end">Ender-sárkány</span>
</div>

<div class="hub-grid">
  <HubCard
    href={`${base}/introduction/`}
    icon="🆕"
    title={{ hu: "Új Játékos?", en: "New Player?", ru: "Новый игрок?" }}
    description={{ hu: "Mi a MITE:BE, mire számíts, hogyan olvasd a wikit.", en: "What is MITE:BE, what to expect, how to use this wiki.", ru: "Что такое MITE:BE, чего ожидать, как пользоваться вики." }}
    accentColor="var(--green)"
  />
  <HubCard
    href={`${base}/progression/`}
    icon="📈"
    title={{ hu: "Haladási Útmutató", en: "Progression Guide", ru: "Руководство по прогрессии" }}
    description={{ hu: "7 lépéses részletes útmutató a kovakortól az endgame-ig.", en: "7-step detailed guide from flint age to endgame.", ru: "7-шаговое подробное руководство от кремниевого века до конца игры." }}
    accentColor="var(--gold)"
  />
  <HubCard
    href={`${base}/systems/`}
    icon="⚙"
    title={{ hu: "Játékrendszerek", en: "Game Systems", ru: "Игровые системы" }}
    description={{ hu: "Táplálkozás, harc, túlélés, képességek — a mod mechanikái.", en: "Nutrition, combat, survival, skills — the mod's mechanics.", ru: "Питание, бой, выживание, навыки — механики мода." }}
    accentColor="var(--mithril)"
  />
  <HubCard
    href={`${base}/reference/`}
    icon="📚"
    title={{ hu: "Referencia", en: "Reference", ru: "Справочник" }}
    description={{ hu: "Itemek, receptek, bestiary, biome-ok és referencia táblák.", en: "Items, recipes, bestiary, biomes and reference tables.", ru: "Предметы, рецепты, бестиарий, биомы и справочные таблицы." }}
    accentColor="var(--copper)"
  />
</div>

<h3>Gyorslinkek</h3>
<div class="flow" style="flex-wrap:wrap;gap:8px;margin:12px 0 24px">
  <a href={`${base}/install/`} class="flow-item" style="text-decoration:none;color:var(--text)">📦 Telepítés</a>
  <a href={`${base}/progression/early-game/`} class="flow-item" style="text-decoration:none;color:var(--text)">🪨 Korai játék</a>
  <a href={`${base}/systems/nutrition/`} class="flow-item" style="text-decoration:none;color:var(--text)">🍖 Táplálkozás</a>
  <a href={`${base}/systems/combat/`} class="flow-item" style="text-decoration:none;color:var(--text)">⚔ Harc</a>
  <a href={`${base}/systems/skills/`} class="flow-item" style="text-decoration:none;color:var(--text)">📜 Képességek</a>
  <a href={`${base}/recipes/`} class="flow-item" style="text-decoration:none;color:var(--text)">🔧 Receptek</a>
  <a href={`${base}/biomes/`} class="flow-item" style="text-decoration:none;color:var(--text)">🌍 Biome-ok</a>
  <a href={`${base}/faq/`} class="flow-item" style="text-decoration:none;color:var(--text)">❓ GYIK</a>
</div>

<h2 id="mob-explorer">Ellenségek</h2>
<div class="mob-teaser-box">
  <p class="mob-teaser-meta"><span class="mob-teaser-num">124</span> szörny · <span class="mob-teaser-num">3</span> régió · <span class="mob-teaser-num">10</span> boss · <span class="mob-teaser-num">4</span> nehézségi szint</p>
  <div class="mob-teaser-cards">
    <div class="mob-card"><div class="mob-card-icon">🐺</div><div class="mob-card-name">Vérfarkas</div><span class="diff-badge diff-mid">II</span></div>
    <div class="mob-card"><div class="mob-card-icon">💀</div><div class="mob-card-name">Csontváz Úr</div><span class="diff-badge diff-boss">★</span></div>
    <div class="mob-card"><div class="mob-card-icon">👻</div><div class="mob-card-name">Ghoul</div><span class="diff-badge diff-early">I</span></div>
    <div class="mob-card"><div class="mob-card-icon">🔥</div><div class="mob-card-name">Tűz Elementális</div><span class="diff-badge diff-late">III</span></div>
  </div>
  <a href={`${base}/mobs/`} class="mob-teaser-btn">Szörny Enciklopédia →</a>
</div>

</div>

