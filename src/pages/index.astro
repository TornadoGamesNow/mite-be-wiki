  <tr><td><strong>Highland Portal</strong></td><td>Stone</td><td>Stone + Obsidian</td><td>Highland/Plateau</td></tr>
  <tr><td><strong>Forest Portal</strong></td><td>Log</td><td>Log + Obsidian</td><td>Forest</td></tr>
  <tr><td><strong>Ocean Portal</strong></td><td>Clay</td><td>Clay + Obsidian</td><td>Ocean</td></tr>
  <tr><td><strong>Tundra Portal</strong></td><td>White Wool</td><td>White Wool + Obsidian</td><td>Snowy biome</td></tr>
