  <tr><td><strong>Mutant Zombie</strong></td><td>30</td><td>8+weapon</td><td>Blood Moon only; breaks blocks</td></tr>
  <tr><td><strong>Skeleton</strong></td><td>6 (norm.) / 12 (hard)</td><td>4</td><td>Standard ranged attacker</td></tr>
  <tr><td><strong>Ancient Skeleton</strong></td><td>12 (norm.) / 25 (hard)</td><td>6+weapon</td><td>Group spawning; Sharpness I melee, Strength I ranged · 20 XP</td></tr>
  <tr style="background:rgba(255,200,0,0.08)"><td><strong>Skeleton Lord</strong></td><td>20–50</td><td>5–10</td><td>Calls skeletons (70% archer, 30% melee); never despawns · 25–40 XP</td></tr>
  <tr><td><strong>Wood Spider</strong></td><td>6–15</td><td>3–4</td><td>Attacks by day too; poison on hit; moves through leaves</td></tr>
  <tr><td><strong>Chaotic Creeper</strong></td><td>10</td><td>2+explosion</td><td>Nighttime; explosion scrambles the player's inventory!</td></tr>
  <tr style="background:rgba(255,100,50,0.10)"><td><strong>Fire Elemental</strong></td><td>20–50</td><td>5–8</td><td>Lava areas; 1–3% instant kill on burning players; 4HP/s regen in lava</td></tr>
  <tr style="background:rgba(150,150,150,0.10)"><td><strong>Earth Elemental</strong></td><td>30–90</td><td>6–16</td><td>5 variants; only damageable with the correct tier pickaxe; stun; 5% chance to evolve</td></tr>
