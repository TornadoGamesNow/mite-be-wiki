---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import MobExplorer from '../islands/MobExplorer.tsx';
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Bestiary — MITE:BE Wiki" description="MITE:BE bestiary: ellenségek HP, sebzés, XP, drop és spawnzóna szerint — felszín, föld alatti, Nether és ismeretlen.">
  <Header />
  <TopNav currentPage="mobs" />
  <main id="mobs-page" style="max-width:1800px; margin:0 auto; padding:8px 32px 24px;">
    <div data-lang="hu">
      <h2 style="padding-top:8px; margin-bottom:6px">Szörny Enciklopédia</h2>
    </div>
    <div data-lang="en">
      <h2 style="padding-top:8px; margin-bottom:6px">Bestiary</h2>
    </div>
    <div data-lang="ru">
      <h2 style="padding-top:8px; margin-bottom:6px">Бестиарий</h2>
    </div>
    <MobExplorer client:load />
  </main>
</BaseLayout>
<style is:global>
  @media (min-width: 640px) {
    body:has(#mobs-page) .wiki-search { display: none; }
  }
</style>
<script is:inline src={`${base}/js/app.js`}></script>
