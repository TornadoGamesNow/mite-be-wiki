---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import MobExplorer from '../islands/MobExplorer.tsx';
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Bestiary — MITE:BE Wiki" description="MITE:BE bestiary: ellenségek HP, sebzés, XP, drop és spawnhelyek szerint — felszín, föld alatti, Nether.">
  <Header />
  <TopNav currentPage="mobs" />
  <main style="max-width:1440px; margin:0 auto; padding:24px 32px;">
    <div data-lang="hu">
      <h2>Szörny Enciklopédia</h2>
      <p style="color:var(--text2)">124 szörny · 4 zóna · egyedi mechanikák</p>
    </div>
    <div data-lang="en">
      <h2>Bestiary</h2>
      <p style="color:var(--text2)">124 mobs · 4 zones · unique mechanics</p>
    </div>
    <div data-lang="ru">
      <h2>Бестиарий</h2>
      <p style="color:var(--text2)">124 моба · 4 зоны · уникальные механики</p>
    </div>
    <MobExplorer client:load />
  </main>
</BaseLayout>
<script is:inline src={`${base}/js/app.js`}></script>
