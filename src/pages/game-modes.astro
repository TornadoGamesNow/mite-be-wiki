    <td>1 pt/30s during fog</td>
    <td>10: Weakness I · 20: +Slowness I (damage every 40s) · 30: +Hunger I + Blindness I (damage every 20s)</td>
  </tr>
  <tr style="background:rgba(100,150,255,0.10)">
    <td><strong>Oxygen Deficiency</strong></td>
    <td>1 pt/30s during fog</td>
    <td>10: Weakness I · 20: 0.5 hearts/40s + Slowness I · 30: 0.5 hearts/30s + Blindness I</td>
  </tr>
