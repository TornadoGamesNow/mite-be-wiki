---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import CraftingTree from '../islands/CraftingTree.tsx';
import '../styles/global.css';
import { getSidebarGroups } from '../data/sidebar-config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sidebarGroups = getSidebarGroups('crafting-tree');
---
<BaseLayout
  title="Crafting Fa — MITE:BE Wiki"
  description="MITE:BE crafting fa vizualizáló: keress bármely itemet és lásd a teljes gyártási fát visszafelé, minden alapanyaggal."
>
  <Header />
  <TopNav currentPage="reference" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

      <div data-lang="hu">
        <h2>Crafting Fa Vizualizáló</h2>
        <p style="color:var(--text2)">Keress bármely craftolható itemet, és lásd a teljes gyártási fát — az alapanyagoktól egészen a késztermékig. Ha egy itemnek több receptje van, a <strong>recept váltó</strong> gombbal választhatsz közöttük.</p>
      </div>
      <div data-lang="en">
        <h2>Crafting Tree Visualizer</h2>
        <p style="color:var(--text2)">Search for any craftable item and see the full production tree — from raw materials to finished product. If an item has multiple recipes, use the <strong>recipe switcher</strong> to pick between them.</p>
      </div>
      <div data-lang="ru">
        <h2>Дерево крафта</h2>
        <p style="color:var(--text2)">Найдите любой крафтируемый предмет и увидите полное дерево производства — от сырья до готового изделия. Если у предмета несколько рецептов, используйте <strong>переключатель рецептов</strong>.</p>
      </div>

      <CraftingTree client:load />

    </main>
  </div>
</BaseLayout>
<script is:inline src={`${base}/js/app.js`}></script>
