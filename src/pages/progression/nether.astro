---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TopNav from '../../components/TopNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import CraftingGrid from '../../components/CraftingGrid.astro';
import PageSummary from '../../components/PageSummary.astro';
import ProgressionBreadcrumb from '../../components/ProgressionBreadcrumb.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ProgressComplete from '../../components/ProgressComplete.astro';
import '../../styles/global.css';

import { getSidebarGroups } from '../../data/sidebar-config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = getSidebarGroups('progression/nether');
---
<BaseLayout title="Nether | MITE:BE Wiki" description="MITE:BE Nether: Nether Portal, Fire Resistance, adamantium smelting, and the Core Block.">
  <Header />
  <TopNav currentPage="progression" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<ProgressionBreadcrumb current="nether" />

<PageSummary keyPoints={{
  hu: [
    'Köpeny (Mantle) a bedrock rétegen — Pokoli Portal a magma szintjén',
    'Tűzállóság ital erősen ajánlott — Tűzelementalok és láva mindenütt',
    'Magblokk (Core Block) megsemmisítése — End Portal nyílik',
  ],
  en: [
    'Find Mantle on bedrock layer — build Hell Portal at magma level',
    'Fire Resistance potion strongly recommended — Fire Elementals and lava are everywhere',
    'Destroy the Core Block — End Portal opens (only path to The End)',
  ],
  ru: [
    'Мантия на уровне бедрока — Адский портал на уровне магмы',
    'Зелье огнестойкости настоятельно рекомендуется — Огненные элементали и лава повсюду',
    'Уничтожь Ядровый Блок — открывается портал в Край',
  ],
}} />

<div data-lang="hu">

<!-- ===== NETHER ===== -->

<h2 id="nether">Alvilág</h2>
<p>Az Alvilág eléréséhez meg kell találnod a <strong>Köpenyt</strong> a Földalatti világ alapkőrétegében, és portált kell elhelyezned.</p>
<div class="info">Nehéz módban 3 alapkő-réteg van!</div>

<div class="warning-box">🔥 <strong>Az Alvilág a játék legnehezebb dimenziója!</strong> Teljes <strong>Mithril felszerelés</strong> erősen ajánlott. Tűzálló bájital kötelező a Tűz Elementális és a láva veszélyek miatt. Ne menj be felkészületlenül!</div>

<h3 id="nether-mobs">Alvilág Szörnyei</h3>
<table class="compare-table">
  <tr><th>Szörny</th><th>HP</th><th>Sebzés</th><th>XP</th><th>Speciális</th></tr>
  <tr><td>Démon Pók (Demon Spider)</td><td>14</td><td>4</td><td>30</td><td>Tűzálló, mérgező</td></tr>
  <tr><td>Pokol Kutya (Hell Hound)</td><td>20</td><td>4–8</td><td>6</td><td>Tűzálló, gyors, falkában támad</td></tr>
  <tr><td>Alvilági Creeper</td><td>40</td><td>2–40</td><td>15</td><td>Tűzálló, nagyobb robbanás</td></tr>
  <tr><td>Vörös Blaze</td><td>40</td><td>10</td><td>20</td><td><strong>6 tűzgolyó egyszerre!</strong> Blaze Pálcát ejt</td></tr>
  <tr><td>Tűz Elementális (Fire Elemental)</td><td>40</td><td>6</td><td>25</td><td><strong>1-3% azonnali ölés</strong> égő játékoson! Víz/hógolyó/Sértés bájital hat rá</td></tr>
  <tr><td>Nagy Ghast</td><td>100</td><td>9 (tűzgolyó)</td><td>20</td><td>Óriási, repülő, tűzokádó — golyóit visszaütheted!</td></tr>
  <tr><td>Zombi Disznóember</td><td>60</td><td>8</td><td>15</td><td>Semleges, amíg nem provokálod; az egyik megtámadása az egész közeli csoportot berántja</td></tr>
  <tr><td>Vámpír/Óriás Vámpír Denevér</td><td>3/6</td><td>1/2</td><td>5/10</td><td>Életlopás</td></tr>
</table>
<div class="info-box">🔥 <strong>Tűz Elementális:</strong> Az Alvilág egyik leghírhedtebb szörnye. Ha <strong>éppen égsz</strong> amikor megtámad, van <strong>1-3% esélye azonnal megölni</strong> téged! Varázstárgyak, víz, hógolyók és Sértés bájital hat rá — tűz és ezüst fegyver NEM sebzi. Tűzálló bájital kötelező ellene!</div>

<h3 id="core-blocks">Magblokkok</h3>
<p>Az Alvilág mélyén találhatók a <strong>Magblokkok</strong> — lávatextúrájú blokkok, amelyek fényt adnak (fényszint 15).</p>
<ul>
  <li><strong>8 blokkon belül</strong> láva sebzést okoznak a játékosnak (v0.8.0+)</li>
  <li>Az egyetlen módja az elpusztításuknak a <strong>Magpusztító</strong></li>
  <li>Egy Magblokk elpusztításakor <strong>End portál nyílik</strong> — ez az egyetlen út az End dimenzióba!</li>
</ul>
<div class="warning-box">⚠️ <strong>End Dimenzió:</strong> Egy Magblokk elpusztítása a Magpusztító segítségével megnyitja az End portált. Ez az Ender-sárkány legyőzéséhez szükséges egyetlen belépési pont!</div>

<h3>Alvilági erőforrások</h3>
<ul>
  <li><strong>Alvilágkő:</strong> Az Alvilág alapkőzete — Alvilágkőkemence építéséhez kell (hőfok 4)</li>
  <li><strong>Blaze Pálca:</strong> Vörös Lángoszlopokból ejthető — <strong>hőfok 4 tüzelőanyag</strong>, Adamantium olvasztáshoz nélkülözhetetlen!</li>
  <li><strong>Izzókő:</strong> Fényforrás, bájital készítéshez is szükséges</li>
  <li><strong>Netherkvarc:</strong> Bájital- és bűvölésreceptekhez</li>
  <li><strong>Fonnyasztóvirág:</strong> Alvilág-erőd jutalomládáiból — Wither boss idézéséhez kell</li>
</ul>

<h3>Alvilág-erőd</h3>
<p>Fedezd fel az Alvilág-erődöt! Az erőd jutalomládájából <strong>Fonnyasztóvirág</strong> kerülhet elő.</p>

<h3>Stratégiai Tippek</h3>
<div class="tip-card">💡 <strong>Alvilági túlélési útmutató:</strong>
<ul style="margin:4px 0 0 0">
  <li><strong>Tűzálló bájital</strong> kötelező — Tűz Elementális nélküle szinte lehetetlen</li>
  <li>A <strong>Zombi Disznóembereket ne üsd meg</strong> feleslegesen — csoportosan agresszívvá válnak</li>
  <li>Blaze-vadászat: készülj a Blaze Pálcák gyűjtésére (ez az Adamantium olvasztás kulcsa)</li>
  <li>Lávavödör beszerzés: az Alvilágban rengeteg láva van, tölts vödröket a kemencéidhez</li>
  <li>Tartalék páncél és fegyver ajánlott — az Alvilág halálos!</li>
</ul></div>

<h3>Alvilágkőkemence</h3>
<div class="recipe">Alvilágkő blokkok + Alvilágkőkemencemag → Alvilágkő többblokkos kemence</div>
<p>Ez kell az <strong><span class="wiki-item" data-id="adamantium_bar">adamantium</span> olvasztásához</strong>!</p>

<h3 id="portals">Portál Típusok</h3>
<p>A MITE:BE-ben 5 féle portál létezik, amelyek különböző dimenziók között teleportálnak. A portál alapja Obszidián keretből és Tűzgyújtóből áll.</p>
<table class="compare-table">
  <tr><th>#</th><th>Portál</th><th>Hol építsd</th><th>Célpont</th><th>Szín</th></tr>
  <tr><td>1</td><td><strong>Normál Portál</strong></td><td>Fővilág (nincs alapkő alatta)</td><td>Világ megjelenési pontja</td><td style="color:#88aaff">Kék</td></tr>
  <tr><td>2</td><td><strong>Alvilágportál</strong></td><td>Fővilág alapkő-rétege</td><td>Földalatti világ</td><td style="color:#b388ff">Lila</td></tr>
  <tr><td>3</td><td><strong>Visszatérő Portál</strong></td><td>Bárhol a föld alatti világban</td><td>Fővilág</td><td style="color:#4ecca3">Cián</td></tr>
  <tr><td>4</td><td><strong>Pokol Portál</strong></td><td>Földalatti világ magma-rétege</td><td>Alvilág dimenzió</td><td style="color:#ff5555">Piros</td></tr>
  <tr><td>5</td><td><strong>Pokol Visszatérő Portál</strong></td><td>Bárhol az Alvilágban</td><td>Földalatti világ</td><td style="color:#b388ff">Lila</td></tr>
</table>
<div class="info-box">🔮 <strong>v0.9.0 különlegesség:</strong> Fővilágban, az alapkőrétegen normál Obszidián portál gyújtásával → 10 másodperc Hányinger → 5 másodperc múlva az összes játékost a Pillager-erőd romjaira teleportálja!</div>

<h3 id="biome-portals">Biom Portálok (v0.8.0+)</h3>
<p>8 különböző Biom portál érhető el <strong>Átalakítókövek</strong> segítségével. Minden Átalakítókövet egy megfelelő anyag + Obszidián keverékéből készítesz egy normál munkaasztalon, majd az Obszidián keret helyett ezt a követ használod.</p>
<div class="warning-box">⚠️ <strong>v0.9.0 változás:</strong> A Biom portálok <strong>már nem struktúrák közelébe</strong> teleportálnak — csak az adott Biom általános terépre visznek véletlenszerű helyre. Minden belépés más-más helyhez vezet. A visszatéréshez bármely szabályos Obszidián keret (NEM alapkőn) → megjelenési ponthoz visz vissza.</div>
<table class="compare-table">
  <tr><th>Portál</th><th>Átalakítókő alapanyag</th><th>Készítés</th><th>Cél Biom</th></tr>
  <tr><td><strong>Sivatag Portál</strong></td><td>Homok</td><td>Homok + Obszidián</td><td>Sivatag</td></tr>
  <tr><td><strong>Mocsár Portál</strong></td><td>Mohás Kőhalom</td><td>Mohás Kőhalom + Obszidián</td><td>Mocsár</td></tr>
  <tr><td><strong>Síkság Portál</strong></td><td>Föld</td><td>Föld + Obszidián</td><td>Síkság</td></tr>
  <tr><td><strong>Magasföld Portál</strong></td><td>Kő</td><td>Kő + Obszidián</td><td>Magasföld (Highland)</td></tr>
  <tr><td><strong>Erdő Portál</strong></td><td>Rönk</td><td>Rönk + Obszidián</td><td>Erdő</td></tr>
  <tr><td><strong>Óceán Portál</strong></td><td>Agyag</td><td>Agyag + Obszidián</td><td>Óceán</td></tr>
  <tr><td><strong>Tundra Portál</strong></td><td>Fehér Gyapjú</td><td>Fehér Gyapjú + Obszidián</td><td>Havas Biom</td></tr>
  <tr><td><strong>Dzsungel Portál</strong></td><td>Falevél</td><td>Falevél + Obszidián</td><td>Dzsungel</td></tr>
</table>

<!-- ===== ADAMANTIUM ===== -->

<h2 id="adamantium">Adamantium — Az Alvilág Mélyéről</h2>
<p>Az Alvilág mélyének gonosz erejével átitatott fém. Adamantiumércet <strong>mithril csákánnyal vagy háborús kalapáccsal</strong> bányászhatsz.</p>
<div class="warning-box">🔥 <strong>Olvasztás:</strong> Adamantiumérc olvasztásához kizárólag <strong>Blaze Pálca</strong> (heat level 4) és <strong>Alvilágkőkemence</strong> szükséges — az olvadáspontja (6210°C) meghaladja az Obszidiánkemence maximumát (5000°C). A jelenlegi v0.9.0 adatok alapján itt sem kezelem aktív követelményként a Bányász foglalkozást.</div>

<p><span class="wiki-item" data-id="adamantium_arrow">Adamantium nyilak</span> rendkívül hasznosak — ezekkel kell elpusztítanod az Ender-kristályokat!</p>

<div class="tip">Az Adamantiumcsákány képes az Alapkőzet-zúzó kiásására is!</div>

<div class="craft-section">
  <CraftingGrid recipeOutput="adamantium_short_sword" label={{hu: "Adamantium Rövidkard", en: "Adamantium Short Sword"}}/>
  <CraftingGrid recipeOutput="adamantium_hand_axe" label={{hu: "Adamantium Kézbalta", en: "Adamantium Hand Axe"}}/>
  <CraftingGrid recipeOutput="adamantium_war_hammer" label={{hu: "Adamantium Háborús Kalapács", en: "Adamantium War Hammer"}}/>
</div>

</div>

<div data-lang="en">

<!-- ===== NETHER ===== -->

<h2 id="nether">The Nether</h2>
<p>To reach the Nether, find the <strong>Mantle</strong> in the Underground's bedrock layer and place a portal.</p>
<div class="info">On Hard Difficulty, there are 3 bedrock layers!</div>

<div class="warning-box">🔥 <strong>The Nether is the hardest realm in the game!</strong> Full <strong>Mithril gear</strong> strongly recommended. Fire Resistance potion is mandatory against Fire Elementals and lava hazards. Do not enter unprepared!</div>

<h3 id="nether-mobs">Nether Mobs</h3>
<table class="compare-table">
  <tr><th>Mob</th><th>HP</th><th>Damage</th><th>XP</th><th>Special</th></tr>
  <tr><td>Demon Spider</td><td>14</td><td>4</td><td>30</td><td>Fire resistant, poisonous</td></tr>
  <tr><td>Hell Hound</td><td>20</td><td>4–8</td><td>6</td><td>Fire resistant, fast, hunts in packs</td></tr>
  <tr><td>Nether Creeper</td><td>40</td><td>2–40</td><td>15</td><td>Fire resistant, larger explosion</td></tr>
  <tr><td>Red Blaze</td><td>40</td><td>10</td><td>20</td><td><strong>6 fireballs at once!</strong> Drops Blaze Rods</td></tr>
  <tr><td>Fire Elemental</td><td>40</td><td>6</td><td>25</td><td><strong>Hardcore: 1-3% instant kill</strong> on already-burning players; water/snowballs/harming potions work</td></tr>
  <tr><td>Greater Ghast</td><td>100</td><td>9 (fireball)</td><td>20</td><td>Huge, flying, fire-breathing — deflect its fireballs!</td></tr>
  <tr><td>Zombie Pigman</td><td>60</td><td>8</td><td>15</td><td>Neutral unless provoked; hitting one pulls nearby pigmen into group aggro</td></tr>
  <tr><td>Vampire/Giant Vampire Bat</td><td>3/6</td><td>1/2</td><td>5/10</td><td>Life steal</td></tr>
</table>
<div class="info-box">🔥 <strong>Fire Elemental:</strong> The local mob data says it sets you on fire on hit, regenerates in lava, and in <strong>Hardcore</strong> has a <strong>1-3% instant-kill chance</strong> against an already-burning player. Enchanted items, water, snowballs, and Harming Potions work against it. Fire Resistance is strongly recommended.</div>

<h3 id="core-blocks">Core Blocks</h3>
<p>Deep in the Nether you'll find <strong>Core Blocks</strong> — lava-textured blocks that emit light (light level 15).</p>
<ul>
  <li>Within <strong>8 blocks</strong>, they deal lava damage to the player (v0.8.0+)</li>
  <li>The only way to destroy them is with the <strong>Core Destroyer</strong></li>
  <li>Destroying a Core Block <strong>opens an End Portal</strong> — this is the only way to the End!</li>
</ul>
<div class="warning-box">⚠️ <strong>The End:</strong> Destroying a Core Block (with the Core Destroyer) opens the End Portal. This is the only entry point required to defeat the Ender Dragon!</div>

<h3>Nether Resources</h3>
<ul>
  <li><strong>Netherrack:</strong> The Nether's base stone — required for building the Netherrack Furnace (heat 4)</li>
  <li><strong>Blaze Rod:</strong> Dropped by Red Blazes — <strong>heat level 4 fuel</strong>, essential for Adamantium smelting!</li>
  <li><strong>Glowstone:</strong> Light source, also required for potion brewing</li>
  <li><strong>Nether Quartz:</strong> Used in potion and enchanting recipes</li>
  <li><strong>Wither Rose:</strong> Found in Nether Fortress loot chests — required to summon the Wither Boss</li>
</ul>

<h3>Nether Fortress</h3>
<p>Explore the Nether Fortress! Reward chests may contain <strong>Wither Rose</strong>.</p>

<h3>Strategy Tips</h3>
<div class="tip-card">💡 <strong>Nether survival guide:</strong>
<ul style="margin:4px 0 0 0">
  <li><strong>Fire Resistance potion</strong> is mandatory — Fire Elemental is nearly impossible without it</li>
  <li>Do <strong>not provoke Zombie Pigmen</strong> needlessly — hitting one can aggro the whole nearby pack</li>
  <li>Blaze Farming: prepare for Blaze Rod hunting (Blaze Rods = key to Adamantium smelting)</li>
  <li>Lava bucket collection: the Nether has abundant lava, fill buckets for your furnaces</li>
  <li>Spare armor and weapons recommended — the Nether is lethal!</li>
</ul></div>

<h3>Netherrack Furnace</h3>
<div class="recipe">Netherrack Blocks + Netherrack Furnace Core → Netherrack Multiblock Furnace</div>
<p>Needed for <strong>adamantium smelting</strong>!</p>

<h3 id="portals">Portal Types</h3>
<p>MITE:BE has 5 portal types that teleport between different worlds. Each portal requires an Obsidian frame and Flint and Steel.</p>
<table class="compare-table">
  <tr><th>#</th><th>Portal</th><th>Where to Build</th><th>Destination</th><th>Color</th></tr>
  <tr><td>1</td><td><strong>Normal Portal</strong></td><td>Overworld (no bedrock beneath)</td><td>World spawn point</td><td style="color:#88aaff">Blue</td></tr>
  <tr><td>2</td><td><strong>Nether Portal</strong></td><td>Overworld bedrock layer</td><td>Underground World</td><td style="color:#b388ff">Purple</td></tr>
  <tr><td>3</td><td><strong>Return Portal</strong></td><td>Anywhere in Underground</td><td>Overworld</td><td style="color:#4ecca3">Turquoise</td></tr>
  <tr><td>4</td><td><strong>Hell Portal</strong></td><td>Underground magma layer</td><td>The Nether</td><td style="color:#ff5555">Red</td></tr>
  <tr><td>5</td><td><strong>Hell Return Portal</strong></td><td>Anywhere in the Nether</td><td>Underground World</td><td style="color:#b388ff">Purple</td></tr>
</table>
<div class="info-box">🔮 <strong>v0.9.0 special:</strong> Lighting a normal Obsidian portal on the bedrock layer in the Overworld → 10 seconds of Nausea → after 5 seconds, all players are teleported to the ruins of a Pillager Fortress!</div>

<h3 id="biome-portals">Biome Portals (v0.8.0+)</h3>
<p>8 Biome portals are available using <strong>Transmutation Stones</strong>. Each Transmutation Stone is crafted from its corresponding material + Obsidian on a regular Workbench, then used in place of regular Obsidian in the portal frame.</p>
<div class="warning-box">⚠️ <strong>v0.9.0 change:</strong> Biome portals <strong>no longer teleport near Structures</strong> — they only bring you to general Biome terrain at a random location. Each entry takes you somewhere different. To return home: any standard Obsidian frame (NOT on bedrock) → returns to world spawn.</div>
<table class="compare-table">
  <tr><th>Portal</th><th>Transmutation Stone material</th><th>Crafting</th><th>Destination Biome</th></tr>
  <tr><td><strong>Desert Portal</strong></td><td>Sand</td><td>Sand + Obsidian</td><td>Desert</td></tr>
  <tr><td><strong>Swamp Portal</strong></td><td>Mossy Cobblestone</td><td>Mossy Cobblestone + Obsidian</td><td>Swamp</td></tr>
  <tr><td><strong>Plains Portal</strong></td><td>Dirt</td><td>Dirt + Obsidian</td><td>Plains</td></tr>
  <tr><td><strong>Highland Portal</strong></td><td>Stone</td><td>Stone + Obsidian</td><td>Highland/Plateau</td></tr>
  <tr><td><strong>Forest Portal</strong></td><td>Log</td><td>Log + Obsidian</td><td>Forest</td></tr>
  <tr><td><strong>Ocean Portal</strong></td><td>Clay</td><td>Clay + Obsidian</td><td>Ocean</td></tr>
  <tr><td><strong>Tundra Portal</strong></td><td>White Wool</td><td>White Wool + Obsidian</td><td>Snowy Biome</td></tr>
  <tr><td><strong>Jungle Portal</strong></td><td>Leaves</td><td>Leaves + Obsidian</td><td>Jungle</td></tr>
</table>

<!-- ===== ADAMANTIUM ===== -->

<h2 id="adamantium">Adamantium — From the Depths of the Nether</h2>
<p>From the depths of the Nether, imbued with evil essence and terrible power. Mine adamantium ore with a <strong>mithril pickaxe/war hammer</strong>.</p>
<div class="warning-box">🔥 <strong>Smelting:</strong> Adamantium ore requires a <strong>Blaze Rod</strong> (heat level 4) and a <strong>Netherrack Furnace</strong> — its melting point (6210°C) exceeds the Obsidian Furnace max (5000°C). Based on the current v0.9.0 data, the Miner profession is not treated as an active requirement here.</div>

<p>Adamantium arrows are extremely useful — you'll need them to destroy End Crystals!</p>

<div class="tip">The adamantium pickaxe can also dig out the Bedrock Pulverizer!</div>

<div class="craft-section">
  <CraftingGrid recipeOutput="adamantium_short_sword" label={{hu: "Adamantium Rövidkard", en: "Adamantium Short Sword"}}/>
  <CraftingGrid recipeOutput="adamantium_hand_axe" label={{hu: "Adamantium Kézbalta", en: "Adamantium Hand Axe"}}/>
  <CraftingGrid recipeOutput="adamantium_war_hammer" label={{hu: "Adamantium Háborús Kalapács", en: "Adamantium War Hammer"}}/>
</div>

</div>

<div data-lang="ru">

<h2 id="nether">Незер</h2>
<p>Для входа в Незер найди <strong>Мантию</strong> в подземном слое коренной породы и создай портал.</p>
<div class="info">В сложном режиме 3 слоя коренной породы!</div>

<div class="warning-box">🔥 <strong>Незер — самое сложное измерение игры!</strong> Настоятельно рекомендуется полный комплект <strong>мифрила</strong>. Зелье огнестойкости обязательно против Огненных элементалей и лавы. Не входи неподготовленным!</div>

<h3 id="nether-mobs">Мобы Незера</h3>
<table class="compare-table">
  <tr><th>Моб</th><th>HP</th><th>Урон</th><th>XP</th><th>Особое</th></tr>
  <tr><td>Демонический паук</td><td>14</td><td>4</td><td>30</td><td>Огнестойкий, ядовитый</td></tr>
  <tr><td>Адская гончая</td><td>20</td><td>4–8</td><td>6</td><td>Огнестойкая, быстрая, стайная</td></tr>
  <tr><td>Незер-крипер</td><td>40</td><td>2–40</td><td>15</td><td>Огнестойкий, больший взрыв</td></tr>
  <tr><td>Красный Бласт</td><td>40</td><td>10</td><td>20</td><td><strong>6 огненных шаров одновременно!</strong> Роняет Стержни Бласта</td></tr>
  <tr><td>Огненный элементаль</td><td>40</td><td>6</td><td>25</td><td><strong>1-3% мгновенное убийство</strong> горящего игрока!</td></tr>
  <tr><td>Великий гаст</td><td>100</td><td>9 (огн. шар)</td><td>20</td><td>Огромный, летающий — можно отбить шары!</td></tr>
  <tr><td>Зомби-свинолюд</td><td>60</td><td>8</td><td>15</td><td>Нейтрален, пока не спровоцирован; удар по одному агрит всю ближайшую группу</td></tr>
  <tr><td>Вампир/Гигантская летучая мышь</td><td>3/6</td><td>1/2</td><td>5/10</td><td>Кража жизни</td></tr>
</table>
<div class="info-box">🔥 <strong>Огненный элементаль:</strong> Если ты <strong>горишь</strong> в момент атаки — <strong>1-3% шанс мгновенной смерти</strong>! Вода, снежки и Зелье вреда работают, огонь и серебро — нет. Зелье огнестойкости обязательно!</div>

<h3 id="core-blocks">Ядро-блоки</h3>
<p>В глубинах Незера находятся <strong>Ядро-блоки</strong> — блоки с текстурой лавы (уровень освещённости 15).</p>
<ul>
  <li>В радиусе <strong>8 блоков</strong> наносят урон как лава (v0.8.0+)</li>
  <li>Уничтожить можно только <strong>Разрушителем ядра</strong></li>
  <li>Уничтожение блока ядра <strong>открывает портал в Энд</strong> — это единственный путь в измерение Энд!</li>
</ul>

<h3>Ресурсы Незера</h3>
<ul>
  <li><strong>Адский камень:</strong> Основной камень Незера — нужен для Печи из адского камня (тепловой уровень 4)</li>
  <li><strong>Стержень Бласта:</strong> Роняют Красные Бласты — <strong>тепловой уровень 4</strong>, необходим для плавки Адаманта!</li>
  <li><strong>Светокамень:</strong> Источник света, нужен для зелий</li>
  <li><strong>Незер-кварц:</strong> Для зелий и чар</li>
  <li><strong>Завядшая роза:</strong> Из сундуков крепости Незера — нужна для призыва Иссушителя</li>
</ul>

<h3>Крепость Незера</h3>
<p>Исследуй крепость Незера! В сундуках с наградами может попасться <strong>Завядшая роза</strong>.</p>

<h3>Советы по выживанию</h3>
<div class="tip-card">💡 <strong>Руководство по выживанию в Незере:</strong>
<ul style="margin:4px 0 0 0">
  <li><strong>Зелье огнестойкости</strong> обязательно — Огненный элементаль почти непобедим без него</li>
  <li><strong>Не провоцируй зомби-свинолюдей</strong> без необходимости — удар по одному агрит всех рядом</li>
  <li>Фарм Красных Бластов: готовься к охоте за Стержнями Бласта (они нужны для плавки Адаманта)</li>
  <li>Собирай вёдра лавы: в Незере её в изобилии, наполняй вёдра для печей</li>
  <li>Рекомендуется запасная броня и оружие — Незер смертоносен!</li>
</ul></div>

<h3>Печь из адского камня</h3>
<div class="recipe">Блоки адского камня + Ядро печи из адского камня → Многоблочная печь из адского камня</div>
<p>Необходима для <strong>плавки адаманта</strong>!</p>

