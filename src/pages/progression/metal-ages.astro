---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TopNav from '../../components/TopNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import CraftingGrid from '../../components/CraftingGrid.astro';
import PageSummary from '../../components/PageSummary.astro';
import ProgressionBreadcrumb from '../../components/ProgressionBreadcrumb.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ProgressComplete from '../../components/ProgressComplete.astro';
import '../../styles/global.css';

import { getSidebarGroups } from '../../data/sidebar-config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = getSidebarGroups('progression/metal-ages');
---
<BaseLayout title="Metal Ages | MITE:BE Wiki" description="MITE:BE metal ages: copper, silver, alloys (bronze, silver-copper, carbon steel), multiblock furnace, iron and steel.">
  <Header />
  <TopNav currentPage="progression" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<ProgressionBreadcrumb current="metal-ages" />

<PageSummary keyPoints={{
  hu: [
    'Réz és ezüst: szitából vagy bányászatból — az első igazi fémek',
    'Ötvözetek (bronz, ezüst-réz, HCS) ötvöző kemencében készülnek',
    'Vas olvasztáshoz 26 blokkos Nagy Kemence (Blast Furnace) szükséges',
  ],
  en: [
    'Copper & silver from sieve or mining — your first real metals',
    'Alloys (bronze, silver-copper, HCS) are made in the Alloying Furnace',
    'Iron smelting needs a 26-block Blast Furnace with Furnace Core',
  ],
  ru: [
    'Медь и серебро из сита или шахты — первые настоящие металлы',
    'Сплавы (бронза, серебро-медь, HCS) — в плавильной печи',
    'Железо плавится в 26-блочной Доменной печи с Ядром',
  ],
}} />

<div data-lang="hu">

<!-- ===== RÉZ & EZÜST ===== -->

<h2 id="copper-silver">Réz & Ezüst Korszak</h2>
<p>Az első igazi fémek! Réz és ezüst szerszámokat, fegyvereket és páncélt készíthetsz.</p>

<h3>Réz készlet</h3>
<p>Csákány, fejsze, ásó, kés, tőr, kard, háborús kalapács, sarló, kapa, sisak, mellvért, lábvért, csizma, lánc változatok, vödör, pajzs...</p>

<h3>Ezüst készlet</h3>
<p>Azonos készlet az ezüsthöz. Az ezüst fegyverek <strong>extra sebzést okoznak élőholtak ellen</strong>!</p>

<div class="tip">Réz vödör szükséges a láva és a víz szállításához. Arany vödör nem létezik az elején!</div>

<div class="craft-section">
  <CraftingGrid recipeOutput="copper_pickaxe" label={{hu: "Rézcsákány", en: "Copper Pickaxe"}}/>
  <CraftingGrid recipeOutput="copper_axe" label={{hu: "Réz Fejsze", en: "Copper Axe"}}/>
  <CraftingGrid recipeOutput="copper_sword" label={{hu: "Rézkard", en: "Copper Sword"}}/>
  <CraftingGrid recipeOutput="copper_war_hammer" label={{hu: "Réz Háborús Kalapács", en: "Copper War Hammer"}}/>
  <CraftingGrid recipeOutput="silver_sword" label={{hu: "Ezüstkard", en: "Silver Sword"}}/>
</div>

<!-- ===== ÖTVÖZETEK ===== -->

<h2 id="alloys">Ötvözetek</h2>
<p>Az olvasztóban (Smelter) különböző ötvözeteket készíthetsz, amelyek erősebbek az alap fémeknél!</p>

<table>
  <tr><th>Ötvözet</th><th>Összetétel</th><th>Különleges képesség</th></tr>
  <tr class="alloy-row"><td><span class="tier t-copper">Bronz</span></td><td>Réz + Ón</td><td>+20% futás sebesség (teljes szett)</td></tr>
  <tr class="alloy-row"><td><span class="tier t-silver">Ezüst-Réz</span></td><td>Ezüst + Réz</td><td>-10% elszenvedett sérülés, extra sebzés élőholtak ellen, debuff csökkentés. Réz és ezüst darabokkal javítható.</td></tr>
  <tr class="alloy-row"><td><span class="tier t-iron">Szénacél</span></td><td>Vas + Szénkristály</td><td>5% sérülés csökkentés darabonként, lánc bányászat (tartsd a gombot). Elég erős a földalatti világ bejárásához.</td></tr>
</table>

<div class="info"><strong>Szénkristály</strong> szerzése két módon lehetséges:<br>
① Természetesen előfordul a <strong>mély barlangoban</strong> (Y&lt;35)<br>
② <strong>Szénblokk olvasztása Blast Furnace-ban</strong> — tedd a szénblokkot az olvasztórésbe (bal felső slot), <em>nem az üzemanyag slotba!</em></div>


<!-- ===== TÖBBBLOKKOS KEMENCE ===== -->

<h2 id="multiblock">Nagy Kemence (Blast Furnace)</h2>
<p>A magasabb olvadáspontú fémekhez (vas, mithril, adamantium) Nagy Kemence (Blast Furnace) kell.</p>

<h3>Építés</h3>
<div class="recipe">Kemence Mag készítése → 3×3×3-as üreges kocka szerkezet (26 blokk) → Kemence Mag elhelyezése bármelyik oldalra (felső/alsó kivételével)</div>
<div class="craft-section">
  <CraftingGrid recipeOutput="furnace_core_stone" label={{hu: "Kő Kemence Mag", en: "Stone Furnace Core"}}/>
  <CraftingGrid recipeOutput="furnace_core_obsidian" label={{hu: "Obszidiánkemencemag", en: "Obsidian Furnace Core"}}/>
  <CraftingGrid recipeOutput="furnace_core_netherrack" label={{hu: "Alvilágkőkemencemag", en: "Netherrack Furnace Core"}}/>
</div>


<h3>Típusok</h3>
<table>
  <tr><th>Nagy Kemence típus</th><th>Anyag</th><th>Mire jó</th></tr>
  <tr><td>Nagy Kemence + Kő Kemence Mag</td><td>Kő blokkok + Kő Kemence Mag</td><td>Vas, arany olvasztás</td></tr>
  <tr><td>Nagy Kemence + Obszidián Kemence Mag</td><td>Obszidián blokkok + Obszidián Kemence Mag</td><td>Mithril olvasztás</td></tr>
  <tr><td>Nagy Kemence + Alvilágkő Kemence Mag</td><td>Alvilágkő blokkok + Alvilágkő Kemence Mag</td><td>Adamantium olvasztás</td></tr>
</table>

<h3>Hőkezelés</h3>
<p>A kemencében a hőmérséklet-kijelző az aktuális hőmérsékletet mutatja. Különböző érceknek más az olvadáspontja. A kemence hőmérséklete idővel csökken.</p>

<div class="tip"><strong>Végtelen fűtés:</strong> Végtelen lávaforrást a többblokkos kemence aljára téve végtelen fűtést kapsz! Több láva hatása összeadódik.</div>
<div class="info-box">🌋 <strong>Lávakezelés pontosan:</strong> a helyi bucket-docok alapján a sima lávakiöntés csak <strong>folyó lávát</strong> hoz létre, ami egy idő után eltűnik, és vízzel érintkezve <strong>nem</strong> csinál obszidiánt. Valódi <strong>lávaforrást</strong> csak <strong>Ctrl + jobb klikkel</strong>, XP elköltésével tudsz lerakni. Emiatt a modban a láva tényleg <strong>farmolható / visszameríthető</strong>, nem egyszer használatos erőforrás.</div>
<div class="tip-card">🪨 <strong>Bucket of Stone:</strong> ha lávás vödörrel vízbe esel, a helyi itemadat szerint a vödör <strong>kővel telt vödörré</strong> alakul. Ezt vissza lehet craftolni üres vödörré, de <strong>nem</strong> ad ingyen követ vagy kavicsot.</div>
<div class="tip-card">🚤 <strong>Vascsónak:</strong> a helyi item-doc szerint <strong>láván is tud közlekedni</strong>, és ha összetörik, <strong>visszakerül a leltárba</strong> normál fa csónakos szétesés helyett. Az aktuális receptkészletben <strong>Vas Munkaasztalon</strong>, <strong>5 vasrúdból</strong> készül.</div>

<h3>Láva Vödör Olvadási Esély</h3>
<p>Lávás fűtésnél az olvasztott fémtárgyaknak <strong>anyagfüggő esélye</strong> van véletlenszerűen megolvadni és elveszni. Magasabb szintű fémek nagyobb hőállékonysággal bírnak.</p>
<table class="compare-table">
  <tr><th>Anyag</th><th>Olvadási Esély</th></tr>
  <tr style="background:rgba(255,100,50,0.15)"><td><span class="tier t-copper">Réz / Ezüst</span></td><td>16%</td></tr>
  <tr style="background:rgba(255,150,30,0.20)"><td><span class="tier t-silver">Arany</span></td><td>20% ⚠️</td></tr>
  <tr><td><span class="tier t-iron">Vas</span></td><td>8%</td></tr>
  <tr><td><span class="tier t-hard">Keménykő</span></td><td>4%</td></tr>
  <tr><td><span class="tier t-ancient">Ősi Fém</span></td><td>2%</td></tr>
  <tr><td><span class="tier t-mithril">Mithril</span></td><td>1%</td></tr>
  <tr style="background:rgba(100,200,100,0.12)"><td><span class="tier t-adamantium">Adamantium</span></td><td>0% ✅</td></tr>
</table>
<div class="tip-card">🔥 <strong>Arany figyelmeztetés:</strong> Az arany tárgyak a legmagasabb olvadási eséllyel rendelkeznek (20%)! Lávás kemencében való olvasztás közben figyelj az arany tárgyakra.</div>


<!-- ===== VAS ===== -->

<h2 id="iron">Vas & Acél</h2>
<p>A vas a többblokkos kemencéből nyerhető ki. A vas korszak után jön a Szénacél.</p>

<h3>Vascsákány — fontos mérföldkő!</h3>
<p>Vas csákánnyal bányászhatsz <strong>Mithrilércet</strong>! Ez az első igazi belépő a mitikus korba.</p>

<h3>Szénacél</h3>
<p>Vas + Szénkristály = Szénacél. Az utolsó ötvözet. Teljesítménye elég a földalatti világ sötétségének átvágásához.</p>
<div class="info">A Szénacél csákány képes a <strong>lánc bányászatra</strong>: tartsd a gombot és egyszerre több blokkot törsz! Bányászási sebessége meghaladja a mithrilét — a felszíni és underground kitermeléshez ez a legjobb választás.</div>
<div class="tip-card">⚒️ <strong>Ötvözés a kemencében:</strong> Tedd a <strong>vas tárgyat</strong> (kard, csákány stb.) az üzemanyag slot FELETTI slotba, a <strong>Szénkristályt</strong> a bal oldali slotba. Így alakítja át acéllá.</div>
<div class="tip-card">💡 <strong>XP-vel készíts nagyobb tartósságért:</strong> Barkácsolás közben az XP-d belekerül a tárgyba — minél több XP van rajtad, annál tartósabb lesz az elkészült eszköz. Érdemes sok XP-vel elkészíteni a Szénacél tárgyakat!</div>
<div class="tip-card">⚔️ <strong>Szénacél háborús kalapács Underground-ban:</strong> A <strong>Szénacél háborús kalapács + Élőholt Ölő V</strong> bűvölettel a föld alatti világ legjobb fegyvere — olcsó, tartós, és egy csapással legyőzi a csontvázakat és más élőholtakat. Max szintű smaragd bűvölőasztalon 5. szintre bűvölhető.</div>


<div class="craft-section">
  <CraftingGrid recipeOutput="iron_sword" label={{hu: "Vaskard", en: "Iron Sword"}}/>
  <CraftingGrid recipeOutput="iron_pickaxe" label={{hu: "Vascsákány", en: "Iron Pickaxe"}}/>
  <CraftingGrid recipeOutput="iron_axe" label={{hu: "Vas Fejsze", en: "Iron Axe"}}/>
  <CraftingGrid recipeOutput="iron_war_hammer" label={{hu: "Vas Háborús Kalapács", en: "Iron War Hammer"}}/>
</div>

<!-- ===== Fémhierarchia ===== -->

<h2 id="metal-hierarchy">Fémhierarchia</h2>
<table>
  <tr><th>Szint</th><th>Anyag</th><th>Honnan?</th><th>Mire kell bányászni? (Érc / Blokk)</th></tr>
  <tr><td><span class="tier t-flint">1</span></td><td>Kova (Kőzet)</td><td>Kavicsból</td><td>Kézi bányászat</td></tr>
  <tr><td><span class="tier t-copper">2</span></td><td>Réz / Ezüst</td><td>Szitálás / Bányászat</td><td>Kovacsákány</td></tr>
  <tr><td><span class="tier t-gold">3</span></td><td>Arany / Vas</td><td>Mély bányászat</td><td>Réz/Ezüstcsákány (érc) · Vascsákány (blokk)</td></tr>
  <tr><td><span class="tier t-hard">5</span></td><td>Keménykő</td><td>Földalatti világ</td><td>Vascsákány</td></tr>
  <tr><td><span class="tier t-ancient">6</span></td><td>Ősi Fém</td><td>Földalatti világ</td><td>Vascsákány</td></tr>
  <tr><td><span class="tier t-mithril">7</span></td><td>Mithril</td><td>Földalatti világ</td><td>Vascsákány / háborús kalapács (érc) · Mithrilcsákány (blokk)</td></tr>
  <tr><td><span class="tier t-adamantium">8</span></td><td>Adamantium</td><td>Földalatti világ legmélye</td><td>Mithrilcsákány / háborús kalapács</td></tr>
</table>

<h3>Érc Mélység Térkép</h3>
<div class="ore-map">
<div class="ore-layer"><img src="/mite-be-wiki/img/items/coal.png" alt=""><span class="ore-label">Szén</span><span class="ore-bar" style="width:90%;background:#333">Y 0-128</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/ingots/copper.png" alt=""><span class="ore-label">Réz / Ezüst</span><span class="ore-bar" style="width:60%;background:#cd7f32">Y 0-64</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/items/gold_ingot.png" alt=""><span class="ore-label">Arany</span><span class="ore-bar" style="width:35%;background:#f0c040">Y 0-32</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/items/iron_ingot.png" alt=""><span class="ore-label">Vas</span><span class="ore-bar" style="width:45%;background:#d4d4d4">Y 0-48</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/shards/diamond.png" alt=""><span class="ore-label">Gyémánt</span><span class="ore-bar" style="width:18%;background:#7ec8e3">Y 0-16</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/items/emerald.png" alt=""><span class="ore-label">Smaragd</span><span class="ore-bar" style="width:25%;background:#4ecca3">Y 4-32</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/ingots/mithril.png" alt=""><span class="ore-label">Mithril</span><span class="ore-bar" style="width:22%;background:#7ec8e3">Földalatti világ egész területe</span></div>
<div class="ore-layer"><img src="/mite-be-wiki/img/ingots/adamantium.png" alt=""><span class="ore-label">Adamantium</span><span class="ore-bar" style="width:15%;background:#b388ff">Földalatti világ legmélye</span></div>
<div class="ore-layer"><span class="ore-label">🌊 Higany</span><span class="ore-bar" style="width:22%;background:#8899aa">Y 0-25 — Mocsár Biom</span></div>
<div class="ore-layer"><span class="ore-label">⚫ Szén Kristály</span><span class="ore-bar" style="width:20%;background:#444">Fővilág, magma közelében, kb. Y&lt;30</span></div>
</div>

<h3>Érc-eloszlás Biom-onként</h3>
<p>A korábbi részletes biome-táblázat több pontja régi vagy közösségi eredetű adatokra támaszkodott. Itt csak a helyi v0.9.0 fájlokkal biztosan igazolható pontokat tartjuk meg:</p>
<ul>
  <li><strong>Higany:</strong> 0.9.0-ban csak mocsárban, 25-ös szint alatt frissül.</li>
  <li><strong>Szén Kristály:</strong> a fővilágban, magma közelében, nagyjából Y30 alatt jelenik meg.</li>
  <li><strong>Mithril:</strong> az egész földalatti világban véletlenszerűen frissül.</li>
  <li><strong>Adamantium:</strong> a földalatti világ legmélyebb részein jelenik meg.</li>
</ul>

<!-- ===== ÖTVÖZÉSI RENDSZER ===== -->

<h2 id="alloying">Ötvözési Rendszer (Ötvöző Kemence)</h2>
<p>A MITE:BE-ben a normál fém felszerelések <strong>tovább fejleszthetők ötvözéssel</strong> egy Ötvöző Kemencében. Az ötvözés NEM alapanyagokból készít ötvözetet — meglévő, <strong>teljes tartósságú felszereléspéldányokat</strong> alakít át.</p>
<div class="warning-box">⚠️ <strong>Kritikus szabály:</strong> Kizárólag <strong>100% tartósságú (sértetlen)</strong> eszközöket és páncélokat lehet ötvözni! Sérült tárgyak nem olvaszthatók be.</div>

<h3>Ötvöző Kemence Elkészítése</h3>
<table class="compare-table">
  <tr><th>Recept</th><th>Alapanyagok</th><th>Szükséges munkaasztal</th></tr>
  <tr><td><strong>Réz (legolcsóbb)</strong></td><td>4× Rézrúd + 1× Kőkemence</td><td>Réz Munkaasztal</td></tr>
  <tr><td>Ezüst</td><td>4× Ezüstrúd + 1× Kőkemence</td><td>Réz Munkaasztal</td></tr>
  <tr><td>Vas</td><td>6× Kő + 2× Vasrúd + 1× Kőkemence</td><td>Vas Munkaasztal</td></tr>
</table>
<p><strong>Tüzelőanyag:</strong> Szén (30mp), Szénkocka (270mp), Lávavödör (120mp). <strong>Kötegméret:</strong> 1/köteg.</p>

<h3>Ötvözetek</h3>
<table class="compare-table">
  <tr><th>Ötvözet</th><th>Alap felszerelés</th><th>Hozzáadott anyag</th><th>Eredmény</th><th>Bónusz (teljes szett)</th></tr>
  <tr style="background:rgba(205,127,50,0.12)"><td><strong>Bronz</strong></td><td>Teljes tartósságú Réz eszköz/páncél</td><td>Ón Rudak</td><td>Bronz eszköz/páncél</td><td>Tűz időtartam −50% · Futási sebesség +20%</td></tr>
  <tr style="background:rgba(192,192,128,0.12)"><td><strong>Ezüst-Réz</strong></td><td>Teljes tartósságú Ezüst eszköz/páncél</td><td>Réz Rudak</td><td>Ezüst-Réz eszköz/páncél</td><td>Tűz időtartam −80% · Összes sebzés −10%</td></tr>
  <tr style="background:rgba(180,180,180,0.12)"><td><strong>Szénacél</strong></td><td>Teljes tartósságú Vas eszköz/páncél</td><td>Szénkristály-szilánkok</td><td>Szénacél eszköz/páncél</td><td>Sebzés −5%/darab · Saválló · Lánc-bányászás képesség</td></tr>
</table>

<h3>Szükséges alapanyag-mennyiségek (teljes szett)</h3>
<table class="compare-table">
  <tr><th>Ötvözet</th><th>Sisak</th><th>Mellvért</th><th>Lábvért</th><th>Csizma</th><th>Összesen</th></tr>
  <tr><td>Bronz (Ón)</td><td>3</td><td>6</td><td>5</td><td>2</td><td><strong>16 Ón Rúd</strong></td></tr>
  <tr><td>Ezüst-Réz (Réz)</td><td>5</td><td>7</td><td>6</td><td>3</td><td><strong>21 Rézrúd</strong></td></tr>
  <tr><td>Szénacél (Szén Kristály)</td><td>2</td><td>4</td><td>3</td><td>1</td><td><strong>10 Szén Kristály</strong></td></tr>
</table>

<h3>Szén Kristály megszerzése</h3>
<p>A helyi v0.9.0 itemadat szerint a <strong>Szén Kristály</strong> a fővilágban, magma közelében, nagyjából Y30 alatt jelenik meg. Biztosan igazolt források:</p>
<ul>
  <li>Természetes lelőhely bányászata a magma közeli fővilági rétegekben; a lelőhely közvetlenül <code>carbon_crystal</code>-t ad.</li>
  <li><code>Blast Furnace</code>-ben 1 <code>coal_block</code> + 1 <code>coal</code> receptből 1 <code>carbon_crystal_shard</code> készíthető.</li>
</ul>
<div class="tip-card">🧪 <strong>Gyakorlati shard route:</strong> 1 teljes <code>carbon_crystal</code> 4 <code>carbon_crystal_shard</code>-dá bontható, ezért ha valódi kristályt találsz, azt gyakran érdemes inkább szilánkokra bontani a szénacél fejlesztésekhez.</div>
<div class="tip-card">💡 <strong>Higany Üst fejlesztés (Ősi Fém páncélhoz):</strong> Ha teljes tartósságú Ősi Fém páncéldarabot kattintasz egy láva fölé helyezett Higany Üstra (Higany Érc + Üst a mocsárból), a teljes szett viselésénél a testhőmérséklet stabilan marad! Ez a fejlesztés független az Ötvöző Kemencétől.</div>
<div class="info-box">📝 <strong>Más ötvözetek:</strong> A játék referencia adatai szerint <em>csak</em> a fenti 3 ötvözet létezik az Ötvöző Kemencében. Keménykő, Mithril és Adamantium felszerelések NEM ötvözhetők — standard nagy kemencéből kerülnek ki.</div>

</div>

<div data-lang="en">

<!-- ===== COPPER & SILVER ===== -->

<h2 id="copper-silver">Copper & Silver Age</h2>
<p>Your first real metals! Craft tools, weapons, and armor from copper and silver.</p>

<h3>Full equipment set per metal</h3>
<p>Pickaxe, axe, shovel, knife, dagger, sword, war hammer, battle axe, scythe, hoe, helmet, chestplate, leggings, boots (plate + chain variants), bucket, shield, shears, coins...</p>

<h3>Silver Bonus</h3>
<p>Silver weapons deal <strong>extra damage to undead</strong> mobs!</p>

