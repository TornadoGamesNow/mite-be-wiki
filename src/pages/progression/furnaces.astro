  <tr><td><img src="/mite-be-wiki/img/blocks/furnace_obsidian_front.png" alt="" style="width:20px;vertical-align:middle;image-rendering:pixelated"> Обсидиановая печь</td><td>3</td><td>Плавка мифрила</td><td>8× Обсидиан</td></tr>
