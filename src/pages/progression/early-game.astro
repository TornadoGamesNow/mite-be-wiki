---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TopNav from '../../components/TopNav.astro';
import Sidebar from '../../components/Sidebar.astro';
import CraftingGrid from '../../components/CraftingGrid.astro';
import PageSummary from '../../components/PageSummary.astro';
import ProgressionBreadcrumb from '../../components/ProgressionBreadcrumb.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ProgressComplete from '../../components/ProgressComplete.astro';
import '../../styles/global.css';

import { getSidebarGroups } from '../../data/sidebar-config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = getSidebarGroups('progression/early-game');
---
<BaseLayout title="Early Game | MITE:BE Wiki" description="MITE:BE early game: first minutes, flint age, workbench, sieve. Starting from scratch with flint shards and plant fiber.">
  <Header />
  <TopNav currentPage="progression" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">

<ProgressionBreadcrumb current="early-game" />

<PageSummary keyPoints={{
  hu: [
    'Puszta kézzel semmit sem törhetsz — kovaszilánk + növényszál az első lépés',
    'Kova Fejsze = első favágás — ez nyitja meg a teljes receptfát',
    'Szitálj rendszeresen — a szita a legmegbízhatóbb korai fémforrás',
  ],
  en: [
    'No bare-hand mining — flint shard + plant fiber are your first steps',
    'Flint Hatchet = first wood chop — unlocks the full recipe tree',
    'Sieve gravel constantly — the most reliable early metal source',
  ],
  ru: [
    'Голыми руками ничего не сломать — кремень и волокно — первые шаги',
    'Кремнёвый Топорик = первая рубка дерева — открывает все рецепты',
    'Постоянно просеивай гравий — самый надёжный ранний источник металла',
  ],
}} />

<div data-lang="hu">

<!-- ===== KORAI JÁTÉK ===== -->

<h2 id="first-minutes">Első Percek — Túlélés Csupasz Kézzel</h2>
<p>Az elején még nem tudsz puszta kézzel fát törni, ezért előbb füvet, kavicsot és földre esett botokat kell gyűjtened. Az első lépések a következők:</p>
<div style="background:rgba(78,204,163,0.08);border:1px solid rgba(78,204,163,0.35);border-radius:8px;padding:10px 16px;margin-bottom:14px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
  <span style="font-size:1.3em">🗺️</span>
  <span style="flex:1;font-size:.9em;color:#ccc">Nem tudod, hol kezdj? Megvizsgáltunk egy kiváló kezdő seed-et — lebegő sziget, kanyon vas+ezüst bányával, alma-erdő közel.</span>
  <a href={`${base}/faq/#seed`} style="background:rgba(78,204,163,0.18);border:1px solid #4ecca3;color:#4ecca3;border-radius:6px;padding:6px 12px;font-size:.82em;font-weight:600;white-space:nowrap;text-decoration:none">Ajánlott Seed →</a>
</div>

<div class="timeline">
  <div class="timeline-item">
    <h4>1. Fű gyűjtés</h4>
    <p>Üsd ki a <strong>magas füvet</strong> – <em>Búzamag</em> vagy <em>Növényszál</em> hullhat belőle. A búzamag legfeljebb vészételnek jó, a <em>Növényszál</em> viszont kulcsfontosságú a kötélhez.</p>
  </div>
  <div class="timeline-item">
    <h4>2. Szalmakötél készítés</h4>
    <div class="recipe">4× Növényszál → Szalmakötél</div>
  <CraftingGrid recipeOutput="straw_rope" label={{hu: "Szalmakötél", en: "Straw Rope"}}/>

  </div>
  <div class="timeline-item">
    <h4>3. Bot szerzés</h4>
    <p>Törd a <strong>leveleket</strong> – <em>bot</em> eshet belőlük. Tölgyfák alatt a földön is megjelenhetnek lehullott botok.</p>
  </div>
  <div class="timeline-item">
    <h4>4. Kovaszilánk szerzés</h4>
    <p>Áss <strong>kavicsot</strong> (Zuzalék) kézzel – <em>Kovaszilánk (Kova Csipke)</em> eshet ki belőle. Ez az első „szerszám-anyag".</p>
  </div>
</div>

<div class="tip">A tölgyfák alatti lehullott botokkal megspórolhatod a levéltördelést. A búzamag csak ritka esetben ad érdemi telítettséget.</div>


<!-- ===== KOVA KORSZAK ===== --><h3>Gyakori Hibák & Tippek</h3>
<div class="tips-grid">
<div class="tip-card"><strong>Ne égessed meg a húst!</strong> Használj tábortüzet vagy sütőt. A megégett hús mérgezést okoz!</div>
<div class="tip-card"><strong>Szitálj rendszeresen!</strong> A szita az elsődleges módja a korai fémszerzésnek. Ne hanyagold el!</div>
<div class="tip-card"><strong>Őrizd az öntőformát!</strong> Csak 20 használat! Mindig legyen pár tartalék.</div>
<div class="tip-card"><strong>Változatos étrend!</strong> Egyoldalú táplálkozás Alultápláltságot okoz. Egyél húst, gyümölcsöt és zöldséget!</div>
<div class="tip-card"><strong>Kovacsákány = szénérc!</strong> A Kovacsákány már képes szénércet bányászni, bár 1.5× tartósság költséggel.</div>
<div class="tip-card"><strong>Bőrkötél korán!</strong> Ölj állatokat bőrért amint van késed — a bőrkötél a továbbfejlesztett eszközökhöz kell.</div>
<div class="tip-card"><strong>Víz szűrés!</strong> A nyers víz betegséget okozhat. Készíts szűrőpapírt a tiszta vízhez!</div>
<div class="tip-card"><strong>Munkaasztal szint!</strong> Magasabb szintű receptekhez magasabb szintű munkaasztal kell (réz, vas, stb.)</div>
<div class="tip-card"><strong>🐑 Birka = top prioritás!</strong> Szürke birka gyapjúja → Zsinór → Zsinórhálós Szita — ez a leggyorsabb út a szitáláshoz, megelőzheti a kovakorszakot!</div>
<div class="tip-card"><strong>Kavics dobható!</strong> Kézben tartott kavics dobható mobokra. Veszélyes helyzetben hasznos, ha nincs fegyvered.</div>
<div class="tip-card"><strong>Kavics → Kőzet!</strong> Kavicsdarabok <strong>Ezüst Munkaasztalon</strong> összegyúrhatók kőzetté — jó alternatíva ha nem akarod a Rézcsákány tartósságát kövekre vesztegetni.</div>
<div class="tip-card"><strong>A csontfegyverek valódi early-game opciók!</strong> A helyi item-docok szerint a <strong>Bone Cudgel</strong> olcsó vészfegyver <strong>2 csont + szalmakötél</strong> recepttel, a <strong>Bone Club</strong> pedig az erősebb folytatás <strong>3 csont + madzag/ín</strong> alapon. A mostani balanszban <strong>4 sebzést</strong>, <strong>550 tartósságot</strong> kap, és még blokkolni is tud.</div>
</div>


<h2 id="flint-age">Kova Korszak</h2>
<p>A kovaszilánkokból és a nagyobb kovadarabokból készíted az első igazi szerszámaidat.</p>

<h3>Egyszerű Kovakés</h3>
<div class="recipe">Szalmakötél + Kovaszilánk + Fabot → Kovakés</div>
  <CraftingGrid recipeFullId="simple_stone_knife" label={{hu: "Kovakés", en: "Simple Flint Knife"}}/>

<p>Az első vágóeszközöd. A következő nagy lépés a kova és a Kova Munkaasztal.</p>

<h3>Kova készítés</h3>
<div class="recipe">4× Kovaszilánk → 1× Kova</div>
  <CraftingGrid recipeOutput="flint" label={{hu: "Kova", en: "Flint", ru: "Кремень"}}/>

<p>A nagyobb kovadarab kell a munkaasztalhoz és a komolyabb eszközökhöz.</p>


<div class="tip-card">🌿 <strong>Következő cél: Kova Munkaasztal.</strong> Ehhez kova, fabot, deszka és valamilyen kötőanyag kell. Az első darabhoz általában madzagot vagy selyemszálat használsz; a bőrkötél már a munkaasztalon készül.</div>

<div class="warning-box">🕷️ <strong>Vigyázat:</strong> Ha madzagra hajtasz, a pókok korai vadászata még mindig veszélyes. Keress biztonságos forrást, vagy válts bőrkötélre, amint megvan a munkaasztal.</div>

<!-- ===== MUNKAASZTAL ===== -->

<h2 id="Munkaasztal">Kova Munkaasztal</h2>
<div class="recipe">Kova + Selyemszál/Madzag/Bőrkötél + Fabot + Deszka → Kova Munkaasztal</div>
  <CraftingGrid recipeOutput="flint_workbench" label={{hu: "Kova Munkaasztal", en: "Flint Workbench"}}/>

<p>Itt nyílik meg a 3×3-as barkácsolás. Innentől jön a bőrkötél, a fakitermelés és az első rendes bányászeszközök.</p>

<h3>Bőrkötél</h3>
<div class="recipe">Egyszerű kovakés + Bőr → Bőrkötél</div>
  <CraftingGrid recipeId="leather_rope" label={{hu: "Bőrkötél", en: "Leather Rope", ru: "Кожаная верёвка"}}/>

<p>A bőrkötél kell a Kova Baltához, és ettől a ponttól sokkal simább lesz a korai progresszió.</p>

<h3>Kova Balta</h3>
<div class="recipe">Kova + Bőrkötél + Fabot → Kova Balta</div>
  <CraftingGrid recipeOutput="flint_hatchet" label={{hu: "Kova Balta", en: "Flint Hatchet", ru: "Кремниевый топорик"}}/>

<p>Végre tudsz fát vágni. Ez az igazi fordulópont a korai játékban.</p>

<div class="recipe">1× Deszka + 2× Fabot → Fa Lapát (Kova Munkaasztalon)</div>
  <CraftingGrid recipeOutput="wooden_shovel" label={{hu: "Fa Lapát", en: "Wooden Shovel"}}/>

<p>Gyorsabb kavicsbányászat = több kovaszilánk!</p>

<h3>Kova Fejsze</h3>
<div class="recipe">3× Kova + Ín/Madzag + 2× Fabot → Kova Fejsze</div>
  <CraftingGrid recipeOutput="flint_axe" label={{hu: "Kova Fejsze", en: "Flint Axe", ru: "Кремниевый топор"}}/>

<h3>Kovacsákány</h3>
<div class="recipe">Kova + 2× Kovaszilánk + 2× Ín/Madzag + 2× Fabot → Kovacsákány</div>
  <CraftingGrid recipeOutput="flint_pickaxe" label={{hu: "Kovacsákány", en: "Flint Pickaxe", ru: "Кремниевая кирка"}}/>
<p>Az első rendes bányászeszközöd. Ezzel már tudsz szenet és rezet bányászni töredékekben.</p>
<div class="info">A kő törésénél Éles Kova Szilánk is hullhat, a szénércet pedig 1,5× tartósságköltséggel bányássza.</div>

<h3>Éles Kova Lándzsa</h3>
<div class="recipe">Éles Kova Szilánk + Ín/Madzag + 2× Fabot → Éles Kova Lándzsa</div>
  <CraftingGrid recipeOutput="sharp_flint_spear" label={{hu: "Éles Kova Lándzsa", en: "Sharp Flint Spear", ru: "Острое кремниевое копьё"}}/>

<p>Hatékonyabb harceszköz, mint a bot, és már valóban használható önvédelemre.</p>


<!-- ===== SZITA & ÉRCEK ===== -->

<h2 id="sieve">Szita & Ércdarabok</h2>
<div class="recipe">Rönkök + Deszka + Botok → Fa Szita</div>
  <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-top:12px;">
    <CraftingGrid recipeId="wooden_sieve" label={{hu: "Fa Szita", en: "Wooden Sieve", ru: "Деревянное сито"}}/>
    <div style="font-size:1.4em;font-weight:700;color:#d4a94f;">--&gt;</div>
    <CraftingGrid recipeOutput="mesh_leather" label={{hu: "Bőr Szitaháló", en: "Leather Sieve Mesh", ru: "Кожаная сетка для сита"}}/>
  </div>

<p>A szita a MITE:BE egyik legfontosabb eszköze! A fa szita önmagában még nem működik: előbb tegyél bele egy <strong>szitahálót</strong>, utána mehet bele a <strong>kavics</strong> — ebből <strong>ércdarabok</strong> szűrődnek ki (réz, ezüst, arany stb.). A <strong>zsinórháló tovább bírja</strong>, a <strong>bőrháló</strong> pedig akkor kényelmes, ha már van <strong>bőrkötél</strong>.</p>

<div class="tip">A szitáláskor <strong>Obszidián szilánk</strong> is eshet — ez később az öntőformához kell!</div>
<div class="info-box">🪨 <strong>Közvetlen kavicstörés is számít:</strong> a helyi item-info szerint a <strong>kavics kézi vagy sima törése</strong> is dobhat <strong>fémszemcséket vagy ásványtöredékeket</strong>, és a Szerencse ezt javítja. A <strong>szita továbbra is a megbízhatóbb, jobb hozamú út</strong>, de nem ez az egyetlen forrás.</div>

<div class="warning">A szitát nem szabad elhanyagolni — ez az elsődleges módja a fémhez jutásnak a korai játékban!</div>

<div class="info-box">🐑 <strong>Birkás gyorsítóút a zsinórhálóhoz</strong><br>
<strong>Gyapjú + Egyszerű kovakés → 4 fonal → Zsinórháló</strong><br>
Ha korán találsz birkát, a <strong>Kova Munkaasztal</strong> után gyorsan át tudsz állni a tartósabb <strong>zsinórhálóra</strong>. Ez nem előzi meg a munkaasztalt, de jó gyorsítás utána.
  <div style="margin-top:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
    <CraftingGrid recipe={{
      gridSize: '2x2',
      pattern: [['white_wool', 'flint_knife'], ['_', '_']],
      output: 'string',
      outputCount: 4,
      label: { hu: 'Fonal', en: 'String', ru: 'Нить' }
    }}/>
    <div style="font-size:1.25em;font-weight:700;color:#d4a94f;">--&gt;</div>
    <CraftingGrid recipeOutput="mesh_string" label={{hu: "Zsinórháló", en: "String Mesh", ru: "Сетчатая вставка из нитей"}}/>
  </div>
  <div style="margin-top:10px;font-size:.95em;opacity:.92;">A zsinórhálót jobb klikkel kell a szitába helyezni.</div>
</div>

<h3>Kavics szitálás esési arányok</h3>
<p>80% eséllyel kapsz valamit kavics szitálásakor. A ritka anyagok esélye alacsony, de sok szitálással felhalmozható!</p>
<div id="sieve-table-gravel"></div>
<h3>Alvilági Kavics Szitálás</h3>
<p>A Nether kavicsból sokkal több Arany esik — az arany farmolás lényegesen hatékonyabb a Netherben!</p>
<div id="sieve-table-nether"></div>

</div>

<div data-lang="en">

<!-- ===== EARLY GAME ===== -->

<h2 id="first-minutes">First Minutes — Survival with Bare Hands</h2>
<p>At the start, you cannot break wood with bare hands, so your opening route is grass, gravel, and sticks from the ground. Your first steps:</p>
<div style="background:rgba(78,204,163,0.08);border:1px solid rgba(78,204,163,0.35);border-radius:8px;padding:10px 16px;margin-bottom:14px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
  <span style="font-size:1.3em">🗺️</span>
  <span style="flex:1;font-size:.9em;color:#ccc">Not sure where to start? We analyzed an excellent starter seed — floating island, canyon with iron+silver mine, apple forest nearby.</span>
  <a href={`${base}/faq/#seed-en`} style="background:rgba(78,204,163,0.18);border:1px solid #4ecca3;color:#4ecca3;border-radius:6px;padding:6px 12px;font-size:.82em;font-weight:600;white-space:nowrap;text-decoration:none">Recommended Seed →</a>
</div>

<div class="timeline">
  <div class="timeline-item">
    <h4>1. Collect Grass</h4>
    <p>Break <strong>tall grass</strong> – <em>Wheat Seeds</em> or <em>Plant Fiber</em> may drop. Seeds are at best emergency food, while <em>Plant Fiber</em> is the important part for rope.</p>
  </div>
  <div class="timeline-item">
    <h4>2. Craft Straw Rope</h4>
    <div class="recipe">4× Plant Fiber → Straw Rope</div>
  <CraftingGrid recipeOutput="straw_rope" label={{hu: "Szalmakötél", en: "Straw Rope"}}/>
  </div>
  <div class="timeline-item">
    <h4>3. Get a Stick</h4>
    <p>Break <strong>leaves</strong> – <em>sticks</em> may drop from them. Fallen sticks can also appear on the ground under oak trees.</p>
  </div>
  <div class="timeline-item">
    <h4>4. Get Flint Shards</h4>
    <p>Dig <strong>gravel</strong> by hand – <em>Flint Shards</em> may drop. This is the first "tool material".</p>
  </div>
</div>

<div class="tip">Fallen sticks under oak trees can save you from breaking leaves. Wheat seeds only rarely provide any meaningful saturation.</div>

<h3>Common Mistakes & Tips</h3>
<div class="tips-grid">
<div class="tip-card"><strong>Don't burn your meat!</strong> Use a campfire or furnace. Burned meat causes poisoning!</div>
<div class="tip-card"><strong>Sieve regularly!</strong> The sieve is the primary source of early metals. Don't neglect it!</div>
<div class="tip-card"><strong>Guard your ingot mould!</strong> Only 20 uses! Always keep a few spares.</div>
<div class="tip-card"><strong>Varied diet!</strong> Eating only one food type causes Malnourishment. Eat meat, fruit and vegetables!</div>
<div class="tip-card"><strong>Flint pickaxe = coal ore!</strong> The Flint Pickaxe can mine coal ore, at 1.5× durability cost.</div>
<div class="tip-card"><strong>Leather rope early!</strong> Kill animals for leather as soon as you have a knife — leather rope is needed for better tools.</div>
<div class="tip-card"><strong>Filter water!</strong> Raw water can cause illness. Craft filter paper for clean water!</div>
<div class="tip-card"><strong>Workbench tier!</strong> Higher-level recipes need higher-tier workbenches (copper, iron, etc.)</div>
<div class="tip-card"><strong>🐑 Sheep = top priority!</strong> Gray sheep wool → Twine → Twine Mesh Sieve — the fastest way to sieve, can skip the flint age!</div>
<div class="tip-card"><strong>Gravel is throwable!</strong> Held gravel can be thrown at mobs. Useful in dangerous situations without a weapon.</div>
<div class="tip-card"><strong>Gravel → Rock!</strong> Gravel chunks can be combined into rock at a <strong>Silver Workbench</strong> — good alternative to wasting copper pickaxe durability on stones.</div>
<div class="tip-card"><strong>Bone weapons are real early options!</strong> Local item docs show the <strong>Bone Cudgel</strong> is a very cheap emergency weapon from <strong>2 bones + straw rope</strong>, while the <strong>Bone Club</strong> is the stronger upgrade from <strong>3 bones + string/sinew</strong> and in current balance has <strong>4 damage</strong>, <strong>550 durability</strong>, and can still block.</div>
</div>


<h2 id="flint-age">Flint Age</h2>
<p>From flint shards and flint chunks you craft your first real tools.</p>

<h3>Simple Flint Knife</h3>
<div class="recipe">Straw Rope + Flint Shard + Stick → Flint Knife</div>
  <CraftingGrid recipeFullId="simple_stone_knife" label={{hu: "Kovakés", en: "Simple Flint Knife"}}/>

<p>Your first cutting tool. After this, your next real target is flint and the flint workbench.</p>

<h3>Crafting Flint</h3>
<div class="recipe">4× Flint Shard → 1× Flint</div>
  <CraftingGrid recipeOutput="flint" label={{hu: "Kova", en: "Flint", ru: "Кремень"}}/>

<p>The larger flint chunk is what unlocks the workbench and your real early tools.</p>


<div class="tip-card">🌿 <strong>Next goal: Flint Workbench.</strong> You need flint, a stick, a plank, and some binding material. For the first one that usually means string or silk; leather rope is crafted after the workbench is already up.</div>

<div class="warning-box">🕷️ <strong>Warning:</strong> If you are forcing a string route, early spider hunting is still dangerous. Take it safely, or pivot to leather rope once your workbench is online.</div>

<!-- ===== WORKBENCH ===== -->

<h2 id="Munkaasztal">Flint Workbench</h2>
<div class="recipe">Flint + Silk/String/Leather Rope + Stick + Plank → Flint Workbench</div>
  <CraftingGrid recipeOutput="flint_workbench" label={{hu: "Kova Munkaasztal", en: "Flint Workbench"}}/>

<p>This is where the real 3×3 progression starts: leather rope, wood chopping, and your first proper mining tools.</p>

<h3>Leather Rope</h3>
<div class="recipe">Simple Flint Knife + Leather → Leather Rope</div>
  <CraftingGrid recipeId="leather_rope" label={{hu: "Bőrkötél", en: "Leather Rope", ru: "Кожаная верёвка"}}/>

<p>Leather rope is the key unlock for your flint hatchet and a much smoother early route.</p>

<h3>Flint Hatchet</h3>
<div class="recipe">Flint + Leather Rope + Stick → Flint Hatchet</div>
  <CraftingGrid recipeOutput="flint_hatchet" label={{hu: "Kova Balta", en: "Flint Hatchet", ru: "Кремниевый топорик"}}/>

<p>Now you can actually chop wood. This is the milestone that changes everything.</p>

<h3>Wooden Shovel</h3>
<div class="recipe">1× Plank + 2× Stick → Wooden Shovel (at Flint Workbench)</div>
  <CraftingGrid recipeOutput="wooden_shovel" label={{hu: "Fa Lapát", en: "Wooden Shovel"}}/>

<p>Faster gravel mining = more flint shards!</p>

<h3>Flint Axe</h3>
<div class="recipe">3× Flint + Sinew/String + 2× Stick → Flint Axe</div>
  <CraftingGrid recipeOutput="flint_axe" label={{hu: "Kova Fejsze", en: "Flint Axe", ru: "Кремниевый топор"}}/>

<h3>Flint Pickaxe</h3>
<div class="recipe">Flint + 2× Flint Shard + 2× Sinew/String + 2× Stick → Flint Pickaxe</div>
  <CraftingGrid recipeOutput="flint_pickaxe" label={{hu: "Kovacsákány", en: "Flint Pickaxe", ru: "Кремниевая кирка"}}/>
<p>Your first real mining tool. You can now mine coal and copper in fragments.</p>
<div class="info">Breaking stone may also drop Sharp Flint Shards, and coal ore costs 1.5× durability.</div>

<h3>Sharp Flint Spear</h3>
<div class="recipe">Sharp Flint Shard + Sinew/String + 2× Stick → Sharp Flint Spear</div>
  <CraftingGrid recipeOutput="sharp_flint_spear" label={{hu: "Éles Kova Lándzsa", en: "Sharp Flint Spear", ru: "Острое кремниевое копьё"}}/>

<p>Far more practical than a stick, and finally a real early weapon.</p>


<!-- ===== SIEVE & ORES ===== -->

<h2 id="sieve">Sieve & Ore Fragments</h2>
<div class="recipe">Logs + Sticks → Wooden Sieve</div>
  <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-top:12px;">
    <CraftingGrid recipeId="wooden_sieve" label={{hu: "Fa Szita", en: "Wooden Sieve", ru: "Деревянное сито"}}/>
    <div style="font-size:1.4em;font-weight:700;color:#d4a94f;">--&gt;</div>
    <CraftingGrid recipeOutput="mesh_leather" label={{hu: "Bőr Szitaháló", en: "Leather Sieve Mesh", ru: "Кожаная сетка для сита"}}/>
  </div>

<p>The sieve is one of MITE:BE's most important tools! The wooden sieve does not work on its own: first install a <strong>sieve mesh</strong>, then add <strong>gravel</strong> — that is what produces <strong>ore fragments</strong> (copper, silver, gold, etc.). <strong>String mesh lasts longer</strong>, while <strong>leather mesh</strong> is a convenient fallback if you already have <strong>leather rope</strong>.</p>

<div class="tip">Sieving gravel may also yield <strong>Obsidian shards</strong> — needed later for the ingot mould!</div>
<div class="info-box">🪨 <strong>Direct gravel breaking also matters:</strong> the local item-info says that <strong>breaking gravel normally</strong> can already drop <strong>metal particles or mineral fragments</strong>, and Luck improves that chance. The <strong>sieve is still the more reliable, higher-yield route</strong>, but it is not the only source.</div>

<div class="warning">Never neglect the sieve — it's the primary way to get metals in early game!</div>

<div class="info-box">🐑 <strong>Sheep shortcut into string mesh</strong><br>
<strong>Wool + Simple Flint Knife → 4 string → String Mesh</strong><br>
If you find sheep early, you can swap into the more durable <strong>string mesh</strong> soon after your <strong>Flint Workbench</strong> is online. It does not skip the workbench, but it is a strong follow-up.
  <div style="margin-top:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
    <CraftingGrid recipe={{
      gridSize: '2x2',
      pattern: [['white_wool', 'flint_knife'], ['_', '_']],
      output: 'string',
      outputCount: 4,
      label: { hu: 'Fonal', en: 'String', ru: 'Нить' }
    }}/>
    <div style="font-size:1.25em;font-weight:700;color:#d4a94f;">--&gt;</div>
    <CraftingGrid recipeOutput="mesh_string" label={{hu: "Zsinórháló", en: "String Mesh", ru: "Сетчатая вставка из нитей"}}/>
  </div>
  <div style="margin-top:10px;font-size:.95em;opacity:.92;">Install the mesh into the sieve with right-click.</div>
</div>

<h3>Gravel Sieve Drop Rates</h3>
<p>80% chance to get something when sieving gravel. Rare materials have low odds, but are farmable with enough sieving!</p>
<div id="sieve-table-gravel"></div>
<h3>Nether Gravel Sieving</h3>
<p>Nether gravel drops much more gold — gold farming is far more efficient in the Nether!</p>
<div id="sieve-table-nether"></div>

</div>

<div data-lang="ru">

<h2 id="first-minutes">Первые минуты — Выживание голыми руками</h2>
<p>В самом начале дерево голыми руками не добыть, поэтому старт идёт через траву, гравий и палки с земли. Первые шаги:</p>

<div style="background:rgba(78,204,163,0.08);border:1px solid rgba(78,204,163,0.35);border-radius:8px;padding:10px 16px;margin-bottom:14px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
  <span style="font-size:1.3em">🗺️</span>
  <span style="flex:1;font-size:.9em;color:#ccc">Не знаешь, где начать? Мы проанализировали отличный стартовый сид — парящий остров, каньон с шахтой железа+серебра, рядом яблоневый лес.</span>
  <a href={`${base}/faq/#seed-ru`} style="background:rgba(78,204,163,0.18);border:1px solid #4ecca3;color:#4ecca3;border-radius:6px;padding:6px 12px;font-size:.82em;font-weight:600;white-space:nowrap;text-decoration:none">Рекомендуемый сид →</a>
</div>

<div class="timeline">
  <div class="timeline-item">
    <h4>1. Сбор травы</h4>
    <p>Ломай <strong>высокую траву</strong> — может выпасть <em>Пшеничное зерно</em> или <em>Растительное волокно</em>. Зерно здесь годится разве что как аварийная еда, а <em>растительное волокно</em> нужно для верёвки.</p>
  </div>
  <div class="timeline-item">
    <h4>2. Крафт соломенной верёвки</h4>
    <div class="recipe">4× Растительное волокно → Соломенная верёвка</div>
    <CraftingGrid recipeOutput="straw_rope" label={{hu: "Szalmakötél", en: "Straw Rope"}}/>
  </div>
  <div class="timeline-item">
    <h4>3. Получить палку</h4>
    <p>Ломай <strong>листья</strong> — из них может выпасть <em>палка</em>. Под дубами на земле тоже могут лежать упавшие палки.</p>
  </div>
  <div class="timeline-item">
    <h4>4. Получить кремниевые осколки</h4>
    <p>Копай <strong>гравий</strong> голыми руками — могут выпасть <em>кремниевые осколки</em>. Это первый «материал для инструментов».</p>
  </div>
</div>

<div class="tip">Упавшие палки под дубами экономят время на ломание листьев. Пшеничное зерно лишь изредка даёт заметную сытость.</div>

<h3>Частые ошибки и советы</h3>
<div class="tips-grid">
<div class="tip-card"><strong>Не сжигай мясо!</strong> Используй костёр или печь. Сгоревшее мясо вызывает отравление!</div>
<div class="tip-card"><strong>Постоянно просеивай!</strong> Сито — основной ранний источник металла. Не пренебрегай им!</div>
<div class="tip-card"><strong>Береги форму для слитков!</strong> Только 20 использований! Всегда держи несколько запасных.</div>
<div class="tip-card"><strong>Разнообразное питание!</strong> Однотипное питание вызывает Истощение. Ешь мясо, фрукты и овощи!</div>
<div class="tip-card"><strong>Кремниевая кирка = уголь!</strong> Кремниевая кирка может добывать угольную руду, хотя и с 1.5× расходом прочности.</div>
<div class="tip-card"><strong>Кожаная верёвка пораньше!</strong> Убивай животных ради кожи как только появится нож — кожаная верёвка нужна для лучших инструментов.</div>
<div class="tip-card"><strong>Фильтруй воду!</strong> Сырая вода может вызвать болезнь. Скрафти фильтровальную бумагу для чистой воды!</div>
<div class="tip-card"><strong>Уровень верстака!</strong> Рецепты высокого уровня требуют верстак более высокого уровня (медный, железный и т.д.)</div>
<div class="tip-card"><strong>🐑 Овца = главный приоритет!</strong> Шерсть серой овцы → Шпагат → Шпагатная сетчатая шахта — самый быстрый путь к просеиванию, можно пропустить кремниевую эпоху!</div>
<div class="tip-card"><strong>Гравий можно бросать!</strong> Гравий в руке можно бросить в моба. Полезно в опасных ситуациях без оружия.</div>
<div class="tip-card"><strong>Костяное оружие тоже рабочее!</strong> По локальным item-docs <strong>Bone Cudgel</strong> — очень дешёвое аварийное оружие из <strong>2 костей + соломенной верёвки</strong>, а <strong>Bone Club</strong> — более сильное продолжение из <strong>3 костей + нити/жилы</strong>; в текущем балансе у него <strong>4 урона</strong>, <strong>550 прочности</strong>, и он всё ещё умеет блокировать.</div>
</div>

<h2 id="flint-age">Кремниевая эпоха</h2>
<p>Из кремниевых осколков и кусков кремня делаешь первые настоящие инструменты.</p>

<h3>Простой кремниевый нож</h3>
<div class="recipe">Соломенная верёвка + Кремниевый осколок + Палка → Кремниевый нож</div>
  <CraftingGrid recipeFullId="simple_stone_knife" label={{hu: "Kovakés", en: "Simple Flint Knife"}}/>

<p>Первый режущий инструмент. Следующая большая цель после него — кремень и кремниевый верстак.</p>

<h3>Создание кремня</h3>
<div class="recipe">4× Кремниевый осколок → 1× Кремень</div>
  <CraftingGrid recipeOutput="flint" label={{hu: "Kova", en: "Flint", ru: "Кремень"}}/>

<p>Полный кусок кремня нужен для верстака и для нормальных ранних инструментов.</p>

<div class="tip-card">🌿 <strong>Следующая цель: кремниевый верстак.</strong> Для него нужен кремень, палка, доска и связующий материал. Первый верстак обычно делается через нить или шёлк; кожаная верёвка уже крафтится после него.</div>

<div class="warning-box">🕷️ <strong>Осторожно:</strong> Если идёшь через нить, ранняя охота на пауков всё ещё опасна. Ищи безопасный источник или переходи на кожаную верёвку уже после верстака.</div>

<h3>Кремниевый Верстак</h3>
<div class="recipe">Кремень + Шёлк/Нить/Кожаная верёвка + Палка + Доска → Кремниевый Верстак</div>
  <CraftingGrid recipeOutput="flint_workbench" label={{hu: "Kova Munkaasztal", en: "Flint Workbench"}}/>

<p>С него по-настоящему начинается 3×3 крафт: кожаная верёвка, рубка дерева и первые нормальные шахтёрские инструменты.</p>

<h3>Кожаная верёвка</h3>
<div class="recipe">Простой кремниевый нож + Кожа → Кожаная верёвка</div>
  <CraftingGrid recipeId="leather_rope" label={{hu: "Bőrkötél", en: "Leather Rope", ru: "Кожаная верёвка"}}/>

<p>Кожаная верёвка открывает кремниевый топорик и делает ранний прогресс намного ровнее.</p>

<h3>Кремниевый топорик</h3>
<div class="recipe">Кремень + Кожаная верёвка + Палка → Кремниевый топорик</div>
  <CraftingGrid recipeOutput="flint_hatchet" label={{hu: "Kova Balta", en: "Flint Hatchet", ru: "Кремниевый топорик"}}/>

<p>Наконец можно рубить дерево. Это и есть настоящий перелом ранней игры.</p>

<h3>Деревянная лопата</h3>
<div class="recipe">1× Доска + 2× Палка → Деревянная лопата (на кремниевом верстаке)</div>
  <CraftingGrid recipeOutput="wooden_shovel" label={{hu: "Fa Lapát", en: "Wooden Shovel"}}/>

<p>Более быстрая добыча гравия = больше кремниевых осколков!</p>

<h3>Большой кремниевый топор</h3>
<div class="recipe">3× Кремень + Жила/Нить + 2× Палка → Большой кремниевый топор</div>
  <CraftingGrid recipeOutput="flint_axe" label={{hu: "Kova Fejsze", en: "Flint Axe", ru: "Кремниевый топор"}}/>

<h3>Кремниевая кирка</h3>
<div class="recipe">Кремень + 2× Кремниевый осколок + 2× Жила/Нить + 2× Палка → Кремниевая кирка</div>
  <CraftingGrid recipeOutput="flint_pickaxe" label={{hu: "Kovacsákány", en: "Flint Pickaxe", ru: "Кремниевая кирка"}}/>
<p>Ваш первый нормальный инструмент для добычи. Теперь можно добывать уголь и медь фрагментами.</p>
<div class="info">При добыче камня может выпасть острый кремниевый осколок, а угольная руда тратит 1,5× прочности.</div>

<h3>Острое кремниевое копьё</h3>
<div class="recipe">Острый кремниевый осколок + Жила/Нить + 2× Палка → Острое кремниевое копьё</div>
  <CraftingGrid recipeOutput="sharp_flint_spear" label={{hu: "Éles Kova Lándzsa", en: "Sharp Flint Spear", ru: "Острое кремниевое копьё"}}/>

<p>Намного практичнее дубины и уже действительно подходит для самообороны.</p>

<h2 id="sieve">Сито и фрагменты руды</h2>
<div class="recipe">Брёвна + Доски + Палки → Деревянное сито</div>
  <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-top:12px;">
    <CraftingGrid recipeId="wooden_sieve" label={{hu: "Fa Szita", en: "Wooden Sieve", ru: "Деревянное сито"}}/>
    <div style="font-size:1.4em;font-weight:700;color:#d4a94f;">--&gt;</div>
    <CraftingGrid recipeOutput="mesh_leather" label={{hu: "Bőr Szitaháló", en: "Leather Sieve Mesh", ru: "Кожаная сетка для сита"}}/>
  </div>
<p>Сито — один из важнейших инструментов MITE:BE! Деревянное сито само по себе не работает: сначала установи в него <strong>сетку</strong>, потом засыпь <strong>гравий</strong> — и из него начнут отсеиваться <strong>фрагменты руды</strong> (медь, серебро, золото и т.д.). <strong>Сетка из нитей служит дольше</strong>, а <strong>кожаная сетка</strong> удобна как запасной вариант, если у тебя уже есть <strong>кожаная верёвка</strong>.</p>

<div class="tip">При просеивании гравия также может выпасть <strong>осколок обсидиана</strong> — позже понадобится для формы для слитков!</div>
<div class="info-box">🪨 <strong>Обычная добыча гравия тоже полезна:</strong> по локальному item-info <strong>простое разрушение гравия</strong> уже может давать <strong>металлические крупицы и минеральные осколки</strong>, а Удача повышает этот шанс. <strong>Сито всё равно остаётся более надёжным и выгодным путём</strong>, но это не единственный источник.</div>

<div class="warning">Не пренебрегай ситом — это основной способ получить металлы в ранней игре!</div>

<div class="info-box">🐑 <strong>Овцы как быстрый путь к сетке из нитей</strong><br>
<strong>Шерсть + простой кремниевый нож → 4 нити → Сетка из нитей</strong><br>
Если рано найти овец, то вскоре после <strong>кремниевого верстака</strong> можно быстро перейти на более долговечную <strong>сетку из нитей</strong>. Это не пропускает сам верстак, но хорошо ускоряет следующий шаг.
  <div style="margin-top:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
    <CraftingGrid recipe={{
      gridSize: '2x2',
      pattern: [['white_wool', 'flint_knife'], ['_', '_']],
      output: 'string',
      outputCount: 4,
      label: { hu: 'Fonal', en: 'String', ru: 'Нить' }
    }}/>
    <div style="font-size:1.25em;font-weight:700;color:#d4a94f;">--&gt;</div>
    <CraftingGrid recipeOutput="mesh_string" label={{hu: "Zsinórháló", en: "String Mesh", ru: "Сетчатая вставка из нитей"}}/>
  </div>
  <div style="margin-top:10px;font-size:.95em;opacity:.92;">Сетку нужно установить в сито правым кликом.</div>
</div>

<h3>Шансы выпадения при просеивании гравия</h3>
<p>80% шанс получить что-нибудь при просеивании гравия. Редкие материалы редки, но накапливаются при большом объёме просеивания!</p>
<div id="sieve-table-gravel"></div>
