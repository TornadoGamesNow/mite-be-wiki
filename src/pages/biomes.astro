  <tr><td>Y (-30) – (-60)</td><td>Древний камень</td><td>Страж Вайт, Повелитель скелетов</td><td>Хрустальные пещеры, руда мифрила</td></tr>
  <tr><td>Y (-60)+</td><td>Первозданный камень</td><td>Ревенант, особые враги</td><td>Руда адаманта, таинственные руины</td></tr>
