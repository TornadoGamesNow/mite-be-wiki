---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';
import PageSummary from '../components/PageSummary.astro';
import { getSidebarGroups } from '../data/sidebar-config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sidebarGroups = getSidebarGroups('biomes');
---

<BaseLayout title="Biome Guide — MITE: Break Everything Wiki" description="MITE:BE biome guide: plains, forest, taiga, desert, swamp, mountains, jungle — temperature, dangers, special features.">
  <Header />
  <TopNav currentPage="biomes" />
  <div class="container">
    <Sidebar groups={sidebarGroups} />
    <main class="content">
<PageSummary keyPoints={{
  hu: [
    'Minden biome más hőmérsékletet jelent — sivatag túlmelegít, hó megfagyaszt',
    'Vadász Cabin: erdőkben, értékes zsákmány + tudáskönyvek',
    'Gombás biome: normál mobok nem spawnolnak, de a struktúrák továbbra is veszélyesek',
  ],
  en: [
    'Every biome has different temperature — desert overheats, snow freezes you',
    'Hunter Cabin: found in forests, valuable loot + knowledge books',
    'Mushroom biome: normal mobs do not spawn, but structures can still be dangerous',
  ],
  ru: [
    'Каждый биом — разная температура: пустыня перегревает, снег замораживает',
    'Охотничья хижина: в лесах, ценный лут + книги знаний',
    'Грибной биом: обычные мобы не спавнятся, но структуры всё ещё могут быть опасны',
  ],
}} />

<!-- ════════════════════════ HUNGARIAN ════════════════════════ -->
<div data-lang="hu">
<h2 id="attekintes">🌍 Biom Útmutató</h2>
<p>A MITE:BE minden biomot egyedi kihívásokkal és lehetőségekkel ruház fel. Az alábbiakban összefoglaljuk a legfontosabb tudnivalókat biomonként — a veszélyektől a stratégiai tanácsokig.</p>

<div class="info-box">🌡️ <strong>A hőmérséklet mindenhol számít!</strong> A hideg biomokban (Tajga, Hegyvidék) éjjel és esőben gyorsan csökken a testhőmérséklet. Mindig legyen nálad meleg étel és tűzgyújtó eszköz!</div>

<table class="compare-table">
  <tr><th>Biom</th><th>Hőmérséklet</th><th>Fő veszély</th><th>Különlegesség</th></tr>
  <tr><td>🌾 Síkság</td><td>Mérsékelt</td><td>Átlagos szörny-megjelenés</td><td>A fáklyák sosem alszanak ki!</td></tr>
  <tr><td>🌲 Erdő</td><td>Mérsékelt</td><td>Csökkentett látótávolság</td><td>Bőséges faanyag</td></tr>
  <tr><td>🌨 Tajga</td><td>Hideg</td><td>Fagyás éjszaka</td><td>Lucfenyő</td></tr>
  <tr><td>🏜 Sivatag</td><td>Meleg</td><td>Sivatagi őr, hőguta</td><td>Homok és kaktusz</td></tr>
  <tr><td>🌿 Mocsár</td><td>Mérsékelt</td><td>Boszorkányok, sár</td><td>Iszapbarlangok</td></tr>
  <tr><td>⛰ Hegyvidék</td><td>Hideg</td><td>Zuhanás, fagyás</td><td>Ritka ércek a felszínen</td></tr>
  <tr><td>🌴 Dzsungel</td><td>Meleg</td><td>Mérgezés, creeper-ek</td><td>Bambusz, kakaó, banán</td></tr>
  <tr><td>🍄 Gombaszigetek</td><td>Mérsékelt</td><td>Harcitorony</td><td>Mooshroom, nincs szörny-megjelenés</td></tr>
  <tr><td>🌊 Óceán</td><td>Hideg</td><td>Fagyás, fulladás</td><td>Hal, korallok</td></tr>
  <tr><td>🔥 Nether</td><td>Extrém forró</td><td>Blaze, Wither csontváz, láva</td><td>Nether erőd, Blaze Pálca</td></tr>
  <tr><td>⛏ Földalatti világ</td><td>Normál</td><td>Lidérc, Holttetem, Csontvázúr</td><td>Ritka ércek, Tudáskönyvek</td></tr>
</table>
</div>

<!-- ════ PLAINS ════ -->
<div data-lang="hu" id="plains">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌾 Síkság (Plains)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Erős kezdő ajánlás. Nyílt terep, jó látótávolság, kevesebb meglepetés.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>Mérsékelt — nincs fagyásveszély</td></tr>
  <tr><td>Fáklya különlegesség</td><td><strong>Fáklyák soha nem alszanak ki a Síkságon!</strong> Egyetlen biom, ahol ez igaz</td></tr>
  <tr><td>Szörny-megjelenés</td><td>Átlagos — éjszakai védekezés szükséges</td></tr>
  <tr><td>Erőforrások</td><td>Búza, ló, tehén, birka — jó élelmiszerforrás</td></tr>
  <tr><td>Falvak</td><td>Legtöbbször síkságon jelennek meg!</td></tr>
</table>

<div class="info-box">💡 <strong>Kezdő tipp:</strong> Ha a világ kezdőpontja (world spawn) a Síkságon van, maradj ott az első napokban — a fáklyák nem alszanak ki, ami sokat segít a védekezésben!</div>

</div></div></div>
</div>

<!-- ════ FOREST ════ -->
<div data-lang="hu" id="forest">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌲 Erdő (Forest)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Bőséges faforrás, de a sűrű növényzet csökkenti a látótávolságot és megkönnyíti a szörnyek meglepetésszerű támadásait.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>Mérsékelt</td></tr>
  <tr><td>Erőforrások</td><td>Tölgy, nyírfa, lucfenyő — rengeteg fa; gomba; alma</td></tr>
  <tr><td>Veszélyek</td><td>Csökkentett látótávolság → a szörnyek közel kerülhetnek</td></tr>
  <tr><td>Fáklyák</td><td>Kialszanak 3 nap után (Hardcore módban)</td></tr>
</table>

<div class="warning-box">⚠️ <strong>Erdőben légy óvatos éjjel!</strong> A fák között a zombik és pókok közvetlen közelről támadnak. Kerítéssel és jól megvilágított bázissal védekezz.</div>

</div></div></div>
</div>

<!-- ════ TAIGA ════ -->
<div data-lang="hu" id="taiga">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌨 Tajga (Taiga)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Hideg biom — a hőmérséklet-rendszer itt számít legjobban. Éjjel és esőben gyorsan megfagyhatsz.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td><strong>Hideg</strong> — éjjel fagyásveszély!</td></tr>
  <tr><td>Erőforrások</td><td>Lucfenyő (spruce), farkas, lisztbokor</td></tr>
  <tr><td>Havas Tajga</td><td>Még hidegebb — a hóban járás lelassít</td></tr>
  <tr><td>Fagyás megelőzése</td><td>Meleg étel (pörkölt, kása), tűz közelében tartózkodás, meleg ruházat</td></tr>
</table>

<div class="warning-box">🌡️ <strong>Testhőmérséklet:</strong> Tajgán éjjel + esőben gyorsan csökken. Ha nullára esik, megfagysz! Mindig legyen nálad pörkölt vagy meleg leves, és tartózkodj tűz közelében éjszaka.</div>

</div></div></div>
</div>

<!-- ════ DESERT ════ -->
<div data-lang="hu" id="desert">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🏜 Sivatag (Desert)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Forró, száraz biom egyedi ellenséggel — a Sivatagi őrrel. Ritka struktúrát (Sivatagi őrtorony) tartalmaz.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>Meleg nappal — hőguta lehetséges napközben</td></tr>
  <tr><td>Egyedi szörny</td><td><strong>Sivatagi őr</strong> — gyors, erős, ritka dropok</td></tr>
  <tr><td>Struktúra</td><td><strong>Sivatagi őrtorony</strong> — ritka zsákmányládákkal</td></tr>
  <tr><td>Erőforrások</td><td>Homok, homokkő, kaktusz, ördögszekér</td></tr>
  <tr><td>Víz</td><td>Nincs természetes vízforrás — hozz magaddal!</td></tr>
</table>

<div class="warning-box">🏜 <strong>Szitkozódó sivatagi őr:</strong> Ne becsüld alá! Gyors és erős. Mithril+ felszerelés ajánlott a torony megtámadásához.</div>

</div></div></div>
</div>

<!-- ════ SWAMP ════ -->
<div data-lang="hu" id="swamp">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌿 Mocsár (Swamp)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Nedves, sötét biom boszorkányokkal és iszapbarlangokkal. A mérgezés komoly veszélyt jelent.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>Mérsékelt de nedves — a vízben tartózkodás lehűt</td></tr>
  <tr><td>Egyedi veszély</td><td><strong>Boszorkányok</strong> — méregbájitalokat dobnak; elvadult tündérek</td></tr>
  <tr><td>Erőforrások</td><td>Iszap (clay), liliomlevél, mocsári fa</td></tr>
  <tr><td>Barlangok</td><td>Iszapbarlangok — vízzel teli, nehéz navigálni</td></tr>
</table>

<div class="warning-box">🧪 <strong>Boszorkány:</strong> Ha méregbájitalt dob rád, azonnal fogyassz tejet (antidote) vagy menekülj! A mérgezés gyorsan öl alacsony életerőnél (HP).</div>

</div></div></div>
</div>

<!-- ════ MOUNTAINS ════ -->
<div data-lang="hu" id="mountains">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>⛰ Hegyvidék (Mountains)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Látványos de veszélyes biom — az esés és a fagyás a két fő kockázat. Cserébe ritka ércek és kövek lelhetők fel a felszínen.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td><strong>Hideg</strong> nagy magasságban — fagyásveszély</td></tr>
  <tr><td>Esési kockázat</td><td>Meredek lejtők — csúszás és esés kockázata</td></tr>
  <tr><td>Erőforrások</td><td>Kőzet, kavics, hó; ritka esetben felszíni érc</td></tr>
  <tr><td>Vérhold hatás</td><td>Y&gt;100: Hányinger+Gyengeség — <strong>vonulj le a magasból!</strong></td></tr>
</table>

<div class="info-box">⛏ <strong>Hegyvidéki bányászat:</strong> A meredek sziklafalakon néha a felszínen is láthatóak ércek (réz, ezüst) — érdemes átvizsgálni a sziklákat mielőtt a föld alá mennél.</div>

</div></div></div>
</div>

<!-- ════ JUNGLE ════ -->
<div data-lang="hu" id="jungle">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌴 Dzsungel (Jungle)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Sűrű, bonyolult biom rengeteg természeti erőforrással — de nehéz navigálni és mérgező lények veszélyeztetik.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>Meleg és nedves</td></tr>
  <tr><td>Egyedi veszély</td><td>Mérgező pókok, dzsungel creeper variánsok</td></tr>
  <tr><td>Erőforrások</td><td><strong>Bambusz</strong>, banán, kakaóbab, kókuszfa — egyedi ételek</td></tr>
  <tr><td>Navigáció</td><td>Nagyon sűrű — könnyen elveszhetsz</td></tr>
</table>

<div class="info-box">🍌 <strong>Dzsungel ételek:</strong> A banán, kókusz és kakaóbab csak a dzsungelben található. Ha ételkészítési képességed van (vagy v0.9.0+ foglalkozások), különleges receptekhez szükséges!</div>

</div></div></div>
</div>

<!-- ════ MUSHROOM ════ -->
<div data-lang="hu" id="mushroom">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🍄 Gombaszigetek (Mushroom Island)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Egyedi, ritka biom — normál szörnyek nem jelennek meg itt! Azonban a MITE:BE saját egyedi struktúrát ad ide.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Szörny-megjelenés</td><td><strong>Normál szörnyek NEM jelennek meg!</strong> — de a MITE harcitorony igen</td></tr>
  <tr><td>Egyedi szörny</td><td>Mooshroom (gombatehén) — tejjel fejhető, gombás pörköltet ad</td></tr>
  <tr><td>Struktúra</td><td><strong>Gombaerdő harcitorony</strong> — fejlett zsákmány, erős ellenfelek</td></tr>
  <tr><td>Erőforrások</td><td>Óriás gombák, mycelium talaj</td></tr>
</table>

<div class="warning-box">⚔️ <strong>Harcitorony:</strong> A Gombaszigetek egyedi MITE struktúrája. Erős szörnyekkel, ritka jutalomládákkal. Mithril+ felszerelés szükséges a teljes megtisztításhoz.</div>

</div></div></div>
</div>

<!-- ════ OCEAN ════ -->
<div data-lang="hu" id="ocean">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌊 Óceán (Ocean)</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Hatalmas vízfelület — a hőmérséklet-rendszer és a fulladás veszélye kíséri. Horgászatra és víz alatti bányászatra ideális.</p>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>A vízben tartózkodás lehűt — <strong>gyors fagyásveszély hideg biomokban!</strong></td></tr>
  <tr><td>Fő veszély</td><td>Fulladás, hőmérséklet-csökkenés, vízalatti ellenfelek</td></tr>
  <tr><td>Erőforrások</td><td>Hal, tintahal, korallok, homok, kavics</td></tr>
  <tr><td>Horgászat</td><td>Horgászat képességgel jobb fogási esély</td></tr>
</table>

<div class="info-box">🎣 <strong>Horgászat tipp:</strong> Az óceán szélén állva a legegyszerűbb halat fogni — nem kell vízbe menni! Víz alatti légzés bájital kötelező a mélytengeri barlangokhoz.</div>

</div></div></div>
</div>

<!-- ════ NETHER ════ -->
<div data-lang="hu" id="nether">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🔥 Nether</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>A Netherbe belépni komoly felkészülést igényel — de a legfontosabb anyagok (Blaze Pálca, Wither-rózsa, Mithril+ olvasztás) csak innen szerezhetők.</p>

<div class="warning-box">🔥 <strong>Nether belépési feltételek:</strong> Mithrilcsákány (obszidián bányászáshoz) + obszidián öntőforma + tűzgyújtó eszköz. Tűzállóság bájital erősen ajánlott!</div>

<table class="compare-table">
  <tr><th>Tulajdonság</th><th>Részletek</th></tr>
  <tr><td>Hőmérséklet</td><td>Extrém forró — hőguta veszély</td></tr>
  <tr><td>Egyedi veszély</td><td>Tűzelementál: <strong>3% azonnali halál ha éppen égsz!</strong> Tűzállóság kötelező</td></tr>
  <tr><td>Portál mechanika</td><td>Obszidián portál az alapkőrétegen → Pillager-erőd (v0.9.0)</td></tr>
  <tr><td>Nether erőd</td><td>Blaze Pálca (hőfok 4 olvasztáshoz), Wither-rózsa, Alvilági szemölcs</td></tr>
  <tr><td>Blaze</td><td>Blaze Pálca szükséges az adamantium olvasztásához!</td></tr>
  <tr><td>Wither csontváz</td><td>Wither-rózsát dob — Wither boss idézéséhez</td></tr>
</table>

<div class="info-box">🌋 <strong>Lávavödör:</strong> Hőfok 3 (Mithril olvasztás) tüzelőanyaga. A Netherben töltsd fel — otthon nincs lávaforrás!</div>

</div></div></div>
</div>

<!-- ════ UNDERGROUND ════ -->
<div data-lang="hu" id="underground">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>⛏ Földalatti világ</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>A MITE:BE legkomplexebb "biomja" — Y=0 alatt speciális rétegek vannak saját szörnyekkel, struktúrákkal és ritka erőforrásokkal.</p>

<table class="compare-table">
  <tr><th>Réteg (Y)</th><th>Blokk</th><th>Jellemző szörny</th><th>Különlegesség</th></tr>
  <tr><td>Y 0 – (-30)</td><td>Keménykő</td><td>Holttetem, Lidérc</td><td>Keménykő érc, speciális barlangok</td></tr>
  <tr><td>Y (-30) – (-60)</td><td>Ősi kő (Ancient Stone)</td><td>Lidércgárda, Csontvázúr</td><td>Kristálybarlangok, mithrilérc</td></tr>
  <tr><td>Y (-60)+</td><td>Őskő</td><td>Holttetem, speciális ellenségek</td><td>Adamantiumérc, titokzatos romok</td></tr>
</table>

<div class="warning-box">💀 <strong>Csontvázúr:</strong> Erős mini-boss a mélyebb rétegekben. Értékes dropok, de nehéz legyőzni. Mithril+ felszerelés szükséges.</div>

<div class="info-box">🔮 <strong>Föld alatti romok (v0.9.0):</strong> Véletlenszerűen generált romok találhatók a barlangrendszerben — zsákmányládákkal és tudáskönyvekkel!</div>

<h4>Földalatti bányászati stratégia</h4>
<ul>
  <li><strong>Keménykő réteg:</strong> Kalapácsos zúzás keménykő blokkokra → 12 ércdarab</li>
  <li><strong>Holttetem ellen:</strong> Ezüst fegyver hatékony — élőholt-ölő bűvölés is segít</li>
  <li><strong>Lidércgárda ellen:</strong> Gyors, erős — a frontális harc kerülése ajánlott, csapda-stratégia</li>
  <li><strong>Visszaút:</strong> Jelöld meg az utat! Könnyen elveszhetsz a mélyben</li>
</ul>

</div></div></div>
</div>

<!-- ════════════════════════ ENGLISH ════════════════════════ -->
<div data-lang="en">
<h2 id="attekintes-en">🌍 Biome Guide</h2>
<p>MITE:BE gives every biome unique challenges and opportunities. Below is a summary of the key information for each biome — from dangers to strategic advice.</p>

<div class="info-box">🌡️ <strong>Temperature matters everywhere!</strong> In cold biomes (Taiga, Mountains) your body temperature drops fast at night and in rain. Always carry warm food and a fire starter!</div>

<table class="compare-table">
  <tr><th>Biome</th><th>Temperature</th><th>Main Danger</th><th>Special Feature</th></tr>
  <tr><td>🌾 Plains</td><td>Moderate</td><td>Normal mob spawning</td><td>Torches never burn out!</td></tr>
  <tr><td>🌲 Forest</td><td>Moderate</td><td>Reduced visibility</td><td>Abundant wood</td></tr>
  <tr><td>🌨 Taiga</td><td>Cold</td><td>Freezing at night</td><td>Spruce wood</td></tr>
  <tr><td>🏜 Desert</td><td>Warm</td><td>Desert Guardian, heat stroke</td><td>Sand and cactus</td></tr>
  <tr><td>🌿 Swamp</td><td>Moderate</td><td>Witches, mud</td><td>Mud caves</td></tr>
  <tr><td>⛰ Mountains</td><td>Cold</td><td>Falling, freezing</td><td>Surface ore veins</td></tr>
  <tr><td>🌴 Jungle</td><td>Warm</td><td>Poison, creepers</td><td>Bamboo, cocoa, banana</td></tr>
  <tr><td>🍄 Mushroom Islands</td><td>Moderate</td><td>Combat Tower</td><td>No normal mob spawning</td></tr>
  <tr><td>🌊 Ocean</td><td>Cold</td><td>Freezing, drowning</td><td>Fish, coral reefs</td></tr>
  <tr><td>🔥 Nether</td><td>Extreme heat</td><td>Blaze, Wither Skeleton, lava</td><td>Nether Fortress, Blaze Rod</td></tr>
  <tr><td>⛏ Underground World</td><td>Normal</td><td>Revenant, Wight, Skeleton Lord</td><td>Rare ores, Knowledge Books</td></tr>
</table>
</div>

<div data-lang="en" id="plains-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌾 Plains</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>A strong starting recommendation. Open terrain, good visibility, fewer surprises.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Moderate — no freezing risk</td></tr>
  <tr><td>Torch special</td><td><strong>Torches NEVER burn out on Plains!</strong> The only biome where this is true</td></tr>
  <tr><td>Mob spawning</td><td>Normal — nighttime defense required</td></tr>
  <tr><td>Resources</td><td>Wheat, horse, cow, sheep — good food source</td></tr>
  <tr><td>Villages</td><td>Most commonly spawn on Plains!</td></tr>
</table>

<div class="info-box">💡 <strong>Starter tip:</strong> If your world spawn is on Plains, stay there for the first few days — torches won't burn out, which greatly helps with defense!</div>

</div></div></div>
</div>

<div data-lang="en" id="forest-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌲 Forest</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Abundant wood supply, but dense vegetation reduces visibility and lets mobs sneak up on you.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Moderate</td></tr>
  <tr><td>Resources</td><td>Oak, birch, spruce — plenty of wood; mushrooms; apples</td></tr>
  <tr><td>Dangers</td><td>Reduced visibility → mobs can get very close</td></tr>
  <tr><td>Torches</td><td>Burn out after 3 days (in Hardcore mode)</td></tr>
</table>

<div class="warning-box">⚠️ <strong>Be careful at night in the Forest!</strong> Zombies and spiders attack from very close range between the trees. Defend with fences and a well-lit base.</div>

</div></div></div>
</div>

<div data-lang="en" id="taiga-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌨 Taiga</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Cold biome — the temperature system matters most here. You can freeze quickly at night and in rain.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td><strong>Cold</strong> — freezing risk at night!</td></tr>
  <tr><td>Resources</td><td>Spruce wood, wolves, berry bushes</td></tr>
  <tr><td>Snowy Taiga</td><td>Even colder — walking through snow slows you down</td></tr>
  <tr><td>Preventing freezing</td><td>Warm food (stew, porridge), stay near fire, warm clothing</td></tr>
</table>

<div class="warning-box">🌡️ <strong>Body temperature:</strong> Drops fast in Taiga at night + rain. If it hits zero, you die of cold! Always carry stew or warm soup, and stay near fire at night.</div>

</div></div></div>
</div>

<div data-lang="en" id="desert-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🏜 Desert</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Hot, dry biome with a unique enemy — the Desert Guardian. Contains a rare structure (Desert Guardian Tower).</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Warm during the day — heat stroke possible</td></tr>
  <tr><td>Unique mob</td><td><strong>Desert Guardian</strong> — fast, strong, rare drops</td></tr>
  <tr><td>Structure</td><td><strong>Desert Guardian Tower</strong> — rare loot chests</td></tr>
  <tr><td>Resources</td><td>Sand, sandstone, cactus, dead bushes</td></tr>
  <tr><td>Water</td><td>No natural water source — bring your own!</td></tr>
</table>

<div class="warning-box">🏜 <strong>Desert Guardian:</strong> Don't underestimate it! Fast and strong. Mithril+ gear recommended for attacking the Tower.</div>

</div></div></div>
</div>

<div data-lang="en" id="swamp-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌿 Swamp</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Wet, dark biome with witches and mud caves. Poison is a serious threat here.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Moderate but wet — standing in water cools you down</td></tr>
  <tr><td>Unique danger</td><td><strong>Witches</strong> — throw poison potions; hostile fairies</td></tr>
  <tr><td>Resources</td><td>Clay, lily pads, swamp wood</td></tr>
  <tr><td>Caves</td><td>Mud caves — water-filled, hard to navigate</td></tr>
</table>

<div class="warning-box">🧪 <strong>Witch:</strong> If it throws a poison potion at you, immediately drink milk (antidote) or flee! Poison kills quickly at low HP.</div>

</div></div></div>
</div>

<div data-lang="en" id="mountains-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>⛰ Mountains</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Spectacular but dangerous biome — falling and freezing are the two main risks. In return, rare ores and stones can be found on the surface.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td><strong>Cold</strong> at high altitude — freezing risk</td></tr>
  <tr><td>Fall risk</td><td>Steep slopes — risk of slipping and falling</td></tr>
  <tr><td>Resources</td><td>Stone, gravel, snow; occasionally surface ore veins</td></tr>
  <tr><td>Blood Moon effect</td><td>Y&gt;100: Nausea+Weakness — <strong>get down from the heights!</strong></td></tr>
</table>

<div class="info-box">⛏ <strong>Mountain mining:</strong> Steep cliff faces sometimes expose surface ores (copper, silver) — worth scanning the rock walls before going underground.</div>

</div></div></div>
</div>

<div data-lang="en" id="jungle-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌴 Jungle</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Dense, complex biome with lots of natural resources — but hard to navigate and threatened by poisonous creatures.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Warm and humid</td></tr>
  <tr><td>Unique danger</td><td>Poisonous spiders, jungle creeper variants</td></tr>
  <tr><td>Resources</td><td><strong>Bamboo</strong>, banana, cocoa beans, coconut palm — unique foods</td></tr>
  <tr><td>Navigation</td><td>Very dense — easy to get lost</td></tr>
</table>

<div class="info-box">🍌 <strong>Jungle foods:</strong> Bananas, coconuts, and cocoa beans are only found in the jungle. Needed for special recipes if you have food preparation skill (or v0.9.0+ professions)!</div>

</div></div></div>
</div>

<div data-lang="en" id="mushroom-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🍄 Mushroom Islands</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Unique, rare biome — normal mobs don't spawn here! However, MITE:BE adds its own unique structure to these islands.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Mob spawning</td><td><strong>Normal mobs DO NOT spawn!</strong> — but the MITE Combat Tower does</td></tr>
  <tr><td>Unique mob</td><td>Mooshroom — can be milked, gives mushroom stew</td></tr>
  <tr><td>Structure</td><td><strong>Mushroom Forest Combat Tower</strong> — advanced loot, strong enemies</td></tr>
  <tr><td>Resources</td><td>Giant mushrooms, mycelium soil</td></tr>
</table>

<div class="warning-box">⚔️ <strong>Combat Tower:</strong> The unique MITE structure of Mushroom Islands. Tough monsters, rare reward chests. Mithril+ gear required for full clearance.</div>

</div></div></div>
</div>

<div data-lang="en" id="ocean-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🌊 Ocean</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Vast water surface — the temperature system and drowning are the main threats. Ideal for fishing and underwater mining.</p>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Being in water cools you — <strong>rapid freezing risk in cold biomes!</strong></td></tr>
  <tr><td>Main danger</td><td>Drowning, temperature loss, underwater enemies</td></tr>
  <tr><td>Resources</td><td>Fish, squid, coral, sand, gravel</td></tr>
  <tr><td>Fishing</td><td>Better catch rates with the fishing skill</td></tr>
</table>

<div class="info-box">🎣 <strong>Fishing tip:</strong> Standing on the ocean shore is the easiest way to fish — no need to go in the water! Water Breathing potion is mandatory for deep-sea caves.</div>

</div></div></div>
</div>

<div data-lang="en" id="nether-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>🔥 Nether</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>Entering the Nether requires serious preparation — but key materials for late progression, such as Blaze Rods and Wither Roses, are obtained here.</p>

<div class="warning-box">🔥 <strong>Nether entry requirements:</strong> Mithril pickaxe (for mining obsidian) + obsidian ingot mould + flint and steel. Fire Resistance potion strongly recommended!</div>

<table class="compare-table">
  <tr><th>Property</th><th>Details</th></tr>
  <tr><td>Temperature</td><td>Extreme heat — heat stroke risk</td></tr>
  <tr><td>Unique danger</td><td>Fire Elemental: in <strong>Hardcore</strong>, an already-burning player faces a <strong>1-3% instant-kill chance</strong> on hit; Fire Resistance strongly recommended</td></tr>
  <tr><td>Portal mechanic</td><td>Obsidian portal at bedrock level → Pillager Fortress (v0.9.0)</td></tr>
  <tr><td>Nether Fortress</td><td>Blaze Rod (heat level 4 smelting), Nether Wart, reward chests that can contain Wither Rose</td></tr>
  <tr><td>Blaze</td><td>Blaze Rod required for Adamantium smelting!</td></tr>
  <tr><td>Wither Skeleton</td><td>Key Nether enemy; Wither Rose is treated here as Nether Fortress reward-chest loot for Wither summoning</td></tr>
</table>

<div class="info-box">🌋 <strong>Lava bucket:</strong> Fuel for heat level 3 (Mithril smelting). Fill it up in the Nether — there's no lava source at home!</div>

</div></div></div>
</div>

<div data-lang="en" id="underground-en">
<div class="collapsible"><div class="collapsible-toggle" role="button" tabindex="0" aria-expanded="true"><h3>⛏ Underground World</h3><span class="toggle-icon">▶</span></div><div class="collapsible-body open"><div class="collapsible-body-inner">

<p>MITE:BE's most complex "biome" — below Y=0 there are special layers with their own mobs, structures, and rare resources.</p>

<table class="compare-table">
  <tr><th>Layer (Y)</th><th>Block</th><th>Mobs</th><th>Special</th></tr>
  <tr><td>Y 0 – (-30)</td><td>Hardstone</td><td>Revenant, Wight</td><td>Hardstone ore, special caves</td></tr>
  <tr><td>Y (-30) – (-60)</td><td>Ancient Stone</td><td>Wight Guard, Skeleton Lord</td><td>Crystal caves, Mithril ore</td></tr>
  <tr><td>Y (-60)+</td><td>Primordial Stone</td><td>Revenant, special enemies</td><td>Adamantium ore, mysterious ruins</td></tr>
</table>

<div class="warning-box">💀 <strong>Skeleton Lord:</strong> Strong mini-boss in the deeper layers. Valuable drops but hard to defeat. Mithril+ gear required.</div>

<div class="info-box">🔮 <strong>Underground Ruins (v0.9.0):</strong> Randomly generated ruins are found throughout the cave system — with loot chests and Knowledge Books!</div>

<h4>Underground Mining Strategy</h4>
<ul>
  <li><strong>Hardstone layer:</strong> War hammer crushing on hardstone blocks → 12 ore particles</li>
  <li><strong>Vs Revenant:</strong> Silver weapons are effective — Smite enchantment also helps</li>
  <li><strong>Vs Wight Guard:</strong> Fast and strong — avoid frontal combat, use trap strategy</li>
  <li><strong>Way back:</strong> Mark your path! It's easy to get lost in the depths</li>
</ul>

</div></div></div>
</div>

