# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Force LF for web files
*.astro text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff2 binary
*.woff binary
